---
const cards = [
  {
    modifier: "dashboard",
    kicker: "Dashboard",
    title: "One place to handle all of your marketing.",
    description:
      "Campaigns, content, approvals, leads, web updates, email, and follow-up stay visible in one organized workspace. When you send the real dashboard image, this box becomes the live product view.",
    image: "/generated/website/markethink-system-dashboard.svg",
    alt: "One organized Markethink dashboard workspace",
    chips: ["Campaigns", "Approvals", "Leads"],
  },
  {
    modifier: "operator",
    kicker: "Operator",
    title: "Text the operator. The system moves.",
    description:
      "Send a request once — campaign, web update, email, lead follow-up — and Markethink keeps the context, organizes the work, and prepares the next move.",
    image: "/generated/website/markethink-system-operator.svg",
    alt: "Requests moving into the Markethink operator",
    chips: ["Campaign", "Web update", "Email", "Lead follow-up"],
  },
  {
    modifier: "team",
    kicker: "Expert Team",
    title: "The team behind the work.",
    description:
      "Strategy, copy, design, web, lead research, and follow-up support sharpen what ships. We can tighten this third box once the expert-team story is locked.",
    image: "/generated/website/markethink-system-team.svg",
    alt: "Expert marketing team workflow behind Markethink",
    chips: ["Strategy", "Design", "Follow-up"],
  },
];
---

<section class="system-overview" id="markethink-system" aria-label="How Markethink works">
  <div class="container">
    <div class="system-cards animate-stagger">
      {cards.map((card, cardIndex) => (
        <article class={`system-card system-card-${card.modifier}`}>
          <div class="system-visual">
            <img class="system-art" src={card.image} alt={card.alt} loading="lazy" decoding="async" />
            <img class="card-logo" src="/images/logo.svg" alt="Markethink" loading="lazy" decoding="async" />
            <div class="motion-layer" aria-hidden="true">
              {card.chips.map((chip, chipIndex) => (
                <span
                  class={`motion-chip chip-${chipIndex + 1}`}
                  style={`--delay: ${cardIndex * -0.75 + chipIndex * -1.35}s`}
                >
                  {chip}
                </span>
              ))}
            </div>
          </div>
          <div class="system-copy">
            <p>{card.kicker}</p>
            <h2>{card.title}</h2>
            <span>{card.description}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .system-overview {
    position: relative;
    overflow: hidden;
    padding: clamp(4.5rem, 7vw, 7.25rem) 0 2rem;
    background: #f5f5f1;
    color: #0f1213;
  }

  .system-overview::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 14%, rgba(105, 210, 84, 0.12), transparent 28rem),
      radial-gradient(circle at 86% 42%, rgba(237, 244, 234, 0.96), transparent 34rem);
    pointer-events: none;
  }

  .system-overview .container {
    position: relative;
    z-index: 1;
  }

  .system-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.4rem);
  }

  .system-card {
    position: relative;
    overflow: hidden;
    min-height: 37rem;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(15, 18, 19, 0.09);
    border-radius: 2rem;
    background: rgba(255, 255, 252, 0.86);
    box-shadow: 0 24px 76px rgba(15, 18, 19, 0.08);
  }

  .system-visual {
    position: relative;
    min-height: 20rem;
    overflow: hidden;
    background: #edf4ea;
    border-bottom: 1px solid rgba(15, 18, 19, 0.06);
    isolation: isolate;
  }

  .system-art {
    width: 100%;
    height: 100%;
    min-height: 20rem;
    display: block;
    object-fit: cover;
    transform: scale(1.02);
  }

  .card-logo {
    position: absolute;
    z-index: 3;
    top: 1.05rem;
    left: 1.05rem;
    width: min(10.5rem, 46%);
    height: auto;
    padding: 0.52rem 0.64rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: 999px;
    background: rgba(245, 245, 241, 0.86);
    box-shadow: 0 12px 34px rgba(15, 18, 19, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .motion-layer {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .motion-chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.8rem;
    height: 2rem;
    padding: 0 0.74rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: 999px;
    background: rgba(245, 245, 241, 0.9);
    color: #0f1213;
    font-size: 0.66rem;
    font-weight: 760;
    letter-spacing: 0.01em;
    box-shadow: 0 14px 34px rgba(15, 18, 19, 0.11);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: float-chip 7.6s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .system-card-dashboard .chip-1 {
    left: 7%;
    top: 45%;
  }

  .system-card-dashboard .chip-2 {
    right: 8%;
    top: 18%;
    background: rgba(15, 18, 19, 0.9);
    color: #f5f5f1;
  }

  .system-card-dashboard .chip-3 {
    right: 11%;
    bottom: 11%;
    border-color: rgba(105, 210, 84, 0.36);
  }

  .system-card-operator .motion-chip {
    animation-name: request-slide;
    animation-duration: 8.8s;
  }

  .system-card-operator .chip-1 {
    left: 7%;
    top: 18%;
  }

  .system-card-operator .chip-2 {
    left: 6%;
    bottom: 20%;
  }

  .system-card-operator .chip-3 {
    right: 8%;
    top: 26%;
  }

  .system-card-operator .chip-4 {
    right: 7%;
    bottom: 18%;
    min-width: 7.25rem;
    border-color: rgba(105, 210, 84, 0.38);
  }

  .system-card-team .chip-1 {
    left: 8%;
    bottom: 13%;
  }

  .system-card-team .chip-2 {
    right: 9%;
    top: 18%;
  }

  .system-card-team .chip-3 {
    right: 10%;
    bottom: 15%;
    background: rgba(15, 18, 19, 0.88);
    color: #f5f5f1;
  }

  .chip-3::before,
  .system-card-operator .chip-4::before {
    content: "";
    width: 0.46rem;
    height: 0.46rem;
    margin-right: 0.42rem;
    border-radius: 50%;
    background: #69d254;
    box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.42);
    animation: pulse-dot 2.35s ease-out infinite;
  }

  .system-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: clamp(1.35rem, 2vw, 1.8rem);
  }

  .system-copy p {
    width: max-content;
    margin-bottom: 1.1rem;
    padding: 0.38rem 0.72rem;
    border: 1px solid rgba(105, 210, 84, 0.34);
    border-radius: 999px;
    color: #0f1213;
    background: rgba(237, 244, 234, 0.88);
    font-size: 0.7rem;
    font-weight: 820;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .system-copy h2 {
    max-width: 21rem;
    margin-bottom: 1rem;
    color: #0f1213;
    font-family: var(--font-display);
    font-size: clamp(2.18rem, 3.05vw, 3.2rem);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.052em;
  }

  .system-copy span {
    display: block;
    margin-top: auto;
    color: #686b6c;
    font-size: 0.97rem;
    line-height: 1.62;
  }

  @keyframes float-chip {
    0%, 100% {
      transform: translate3d(0, 0, 0);
      opacity: 0.9;
    }

    50% {
      transform: translate3d(0.55rem, -0.58rem, 0);
      opacity: 1;
    }
  }

  @keyframes request-slide {
    0%, 100% {
      transform: translate3d(-0.35rem, 0.15rem, 0);
      opacity: 0.72;
    }

    42% {
      transform: translate3d(0.75rem, -0.28rem, 0);
      opacity: 1;
    }

    72% {
      transform: translate3d(0.2rem, 0.35rem, 0);
      opacity: 0.92;
    }
  }

  @keyframes pulse-dot {
    0% {
      box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.42);
    }

    70%, 100% {
      box-shadow: 0 0 0 0.65rem rgba(105, 210, 84, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-chip,
    .chip-3::before,
    .system-card-operator .chip-4::before {
      animation: none;
    }
  }

  @media (max-width: 1040px) {
    .system-cards {
      grid-template-columns: 1fr;
    }

    .system-card {
      min-height: auto;
    }

    .system-copy span {
      margin-top: 0.5rem;
    }
  }

  @media (max-width: 560px) {
    .system-overview {
      padding-top: 4rem;
    }

    .system-card {
      border-radius: 1.35rem;
    }

    .system-visual,
    .system-art {
      min-height: 15.75rem;
    }

    .card-logo {
      width: 8.3rem;
      top: 0.8rem;
      left: 0.8rem;
    }

    .system-copy h2 {
      font-size: clamp(2.05rem, 10vw, 2.68rem);
    }

    .motion-chip {
      min-width: 4.9rem;
      height: 1.82rem;
      font-size: 0.58rem;
    }
  }
</style>
