---
const cards = [
  {
    kicker: "Dashboard",
    title: "See what needs to move.",
    description:
      "Campaigns, content, approvals, leads, assets, and next steps stay visible in one organized place instead of getting buried across chats and files.",
    image: "/generated/website/markethink-system-dashboard.svg",
    alt: "Organized Markethink dashboard illustration",
    chips: ["Campaigns", "Approvals", "Leads"],
  },
  {
    kicker: "24/7 Operator",
    title: "Ask once. Keep the context.",
    description:
      "Your trained operator learns the business, remembers approvals, and prepares the next piece of work so your team is not restarting from zero every week.",
    image: "/generated/website/markethink-system-operator.svg",
    alt: "Trained Markethink operator illustration",
    chips: ["Brand memory", "Next move", "Ready"],
  },
  {
    kicker: "Expert Team",
    title: "Real marketers sharpen what ships.",
    description:
      "Strategy, copy, design, web, lead research, and follow-up support work behind the system so Markethink delivers judgment, not just output.",
    image: "/generated/website/markethink-system-team.svg",
    alt: "Expert Markethink team workflow illustration",
    chips: ["Strategy", "Design", "Follow-up"],
  },
];
---

<section class="system-overview" id="markethink-system" aria-label="How Markethink works">
  <div class="container">
    <div class="system-cards animate-stagger">
      {cards.map((card, cardIndex) => (
        <article class="system-card">
          <div class="system-visual" aria-hidden="true">
            <img src={card.image} alt="" loading="lazy" decoding="async" />
            <div class="motion-layer">
              {card.chips.map((chip, chipIndex) => (
                <span
                  class={`motion-chip chip-${chipIndex + 1}`}
                  style={`--delay: ${cardIndex * -0.9 + chipIndex * -1.25}s`}
                >
                  {chip}
                </span>
              ))}
            </div>
          </div>
          <div class="system-copy">
            <p>{card.kicker}</p>
            <h2>{card.title}</h2>
            <span>{card.description}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .system-overview {
    position: relative;
    overflow: hidden;
    padding: clamp(4.5rem, 7vw, 7.5rem) 0 2rem;
    background: #f5f5f1;
    color: #0f1213;
  }

  .system-overview::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 12%, rgba(105, 210, 84, 0.12), transparent 28rem),
      radial-gradient(circle at 82% 36%, rgba(237, 244, 234, 0.9), transparent 32rem);
    pointer-events: none;
  }

  .system-overview .container {
    position: relative;
    z-index: 1;
  }

  .system-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.4rem);
  }

  .system-card {
    position: relative;
    overflow: hidden;
    min-height: 36rem;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(15, 18, 19, 0.09);
    border-radius: 2rem;
    background: rgba(255, 255, 252, 0.84);
    box-shadow: 0 22px 70px rgba(15, 18, 19, 0.08);
  }

  .system-visual {
    position: relative;
    min-height: 19rem;
    overflow: hidden;
    background: #edf4ea;
    border-bottom: 1px solid rgba(15, 18, 19, 0.06);
  }

  .system-visual img {
    width: 100%;
    height: 100%;
    min-height: 19rem;
    display: block;
    object-fit: cover;
    transform: scale(1.02);
  }

  .motion-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .motion-layer::before {
    content: "";
    position: absolute;
    inset: 12% 10%;
    border: 1px dashed rgba(105, 210, 84, 0.34);
    border-radius: 999px;
    opacity: 0.65;
    animation: soft-orbit 14s linear infinite;
  }

  .motion-chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.75rem;
    height: 2.05rem;
    padding: 0 0.72rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: 999px;
    background: rgba(245, 245, 241, 0.88);
    color: #0f1213;
    font-size: 0.68rem;
    font-weight: 760;
    letter-spacing: 0.01em;
    box-shadow: 0 12px 30px rgba(15, 18, 19, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    animation: float-chip 7.5s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .chip-1 {
    left: 8%;
    top: 14%;
  }

  .chip-2 {
    right: 9%;
    top: 42%;
    background: rgba(15, 18, 19, 0.9);
    color: #f5f5f1;
  }

  .chip-3 {
    left: 28%;
    bottom: 10%;
    border-color: rgba(105, 210, 84, 0.38);
  }

  .chip-3::before {
    content: "";
    width: 0.5rem;
    height: 0.5rem;
    margin-right: 0.42rem;
    border-radius: 50%;
    background: #69d254;
    box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.42);
    animation: pulse-dot 2.4s ease-out infinite;
  }

  .system-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: clamp(1.35rem, 2vw, 1.8rem);
  }

  .system-copy p {
    width: max-content;
    margin-bottom: 1.1rem;
    padding: 0.38rem 0.72rem;
    border: 1px solid rgba(105, 210, 84, 0.34);
    border-radius: 999px;
    color: #0f1213;
    background: rgba(237, 244, 234, 0.86);
    font-size: 0.7rem;
    font-weight: 820;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .system-copy h2 {
    max-width: 20rem;
    margin-bottom: 1rem;
    color: #0f1213;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 3.1vw, 3.35rem);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.052em;
  }

  .system-copy span {
    display: block;
    margin-top: auto;
    color: #686b6c;
    font-size: 0.98rem;
    line-height: 1.65;
  }

  @keyframes float-chip {
    0%, 100% {
      transform: translate3d(0, 0, 0);
      opacity: 0.92;
    }

    50% {
      transform: translate3d(0.5rem, -0.55rem, 0);
      opacity: 1;
    }
  }

  @keyframes soft-orbit {
    from {
      transform: rotate(0deg) scale(1);
    }

    to {
      transform: rotate(360deg) scale(1.02);
    }
  }

  @keyframes pulse-dot {
    0% {
      box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.42);
    }

    70%, 100% {
      box-shadow: 0 0 0 0.65rem rgba(105, 210, 84, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-chip,
    .motion-layer::before,
    .chip-3::before {
      animation: none;
    }
  }

  @media (max-width: 1040px) {
    .system-cards {
      grid-template-columns: 1fr;
    }

    .system-card {
      min-height: auto;
    }

    .system-copy span {
      margin-top: 0.5rem;
    }
  }

  @media (max-width: 560px) {
    .system-overview {
      padding-top: 4rem;
    }

    .system-card {
      border-radius: 1.35rem;
    }

    .system-visual,
    .system-visual img {
      min-height: 15.5rem;
    }

    .system-copy h2 {
      font-size: clamp(2.1rem, 11vw, 2.75rem);
    }

    .motion-chip {
      min-width: 4.7rem;
      height: 1.85rem;
      font-size: 0.61rem;
    }
  }
</style>
