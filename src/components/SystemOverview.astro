---
const cards = [
  {
    modifier: "dashboard",
    kicker: "Dashboard",
    title: "One place to handle all of your marketing.",
    description:
      "Campaigns, content, approvals, leads, web updates, email, and follow-up stay visible in one organized workspace.",
    image: "/generated/website/markethink-system-dashboard.svg",
    alt: "One organized Markethink dashboard workspace",
    chips: ["Campaigns", "Approvals", "Leads"],
  },
  {
    modifier: "operator",
    kicker: "24/7 AI OPERATOR",
    title: "Your own trained AI agent",
    description:
      "Text the operator once — campaign, web update, email, lead follow-up — and Markethink keeps the context, organizes the work, and prepares the next move.",
    image: "/generated/website/markethink-system-operator.svg",
    alt: "Requests moving into the Markethink AI operator",
    chips: ["Campaign", "Web update", "Email", "Lead follow-up"],
  },
  {
    modifier: "team",
    kicker: "Expert Team",
    title: "The team behind the work.",
    description:
      "Strategy, copy, design, web, lead research, and follow-up support sharpen what ships through the system.",
    image: "/generated/website/markethink-system-team.svg",
    alt: "Expert marketing team workflow behind Markethink",
    chips: ["Strategy", "Design", "Follow-up"],
  },
];
---

<section class="system-overview" id="markethink-system" aria-label="How Markethink works">
  <div class="container">
    <div class="system-cards animate-stagger">
      {cards.map((card, cardIndex) => (
        <article class={`system-card system-card-${card.modifier}`}>
          <div class="system-visual">
            <img class="system-art" src={card.image} alt={card.alt} loading="lazy" decoding="async" />
            <div class="motion-layer" aria-hidden="true">
              {card.chips.map((chip, chipIndex) => (
                <span
                  class={`motion-chip chip-${chipIndex + 1}`}
                  style={`--delay: ${cardIndex * -0.75 + chipIndex * -1.35}s`}
                >
                  {chip}
                </span>
              ))}
            </div>
          </div>
          <div class="system-copy">
            <p class="subtitle">{card.kicker}</p>
            <h3>{card.title}</h3>
            <span>{card.description}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .system-overview {
    position: relative;
    overflow: visible;
    padding: 0 0 7rem;
    background: #f5f5f1;
    color: var(--text-primary);
    z-index: 2;
  }

  .system-overview::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 84% 18%, rgba(237, 244, 234, 0.96), transparent 32rem);
    pointer-events: none;
  }

  .system-overview .container {
    position: relative;
    z-index: 1;
  }

  .system-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: -3.8rem;
  }

  .system-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-medium);
    background: transparent;
    transition: border-color 0.4s, transform 0.4s;
  }

  .system-card:hover {
    border-color: rgba(105, 210, 84, 0.3);
    transform: translateY(-4px);
  }

  .system-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 368 / 282;
    overflow: hidden;
    background: #edf4ea;
    border-bottom: 1px solid var(--neutral-200);
    isolation: isolate;
  }

  .system-art {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .system-card:hover .system-art {
    transform: scale(1.05);
  }

  .motion-layer {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .motion-chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.4rem;
    height: 1.9rem;
    padding: 0 0.7rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: var(--radius-button);
    background: rgba(245, 245, 241, 0.9);
    color: var(--text-primary);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0;
    box-shadow: 0 8px 22px rgba(15, 18, 19, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: float-chip 7.6s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .system-card-dashboard .chip-1 {
    left: 7%;
    top: 45%;
  }

  .system-card-dashboard .chip-2 {
    right: 8%;
    top: 18%;
    background: rgba(15, 18, 19, 0.9);
    color: #f5f5f1;
  }

  .system-card-dashboard .chip-3 {
    right: 11%;
    bottom: 11%;
    border-color: rgba(105, 210, 84, 0.36);
  }

  .system-card-operator .motion-chip {
    animation-name: request-slide;
    animation-duration: 8.8s;
  }

  .system-card-operator .chip-1 {
    left: 7%;
    top: 18%;
  }

  .system-card-operator .chip-2 {
    left: 6%;
    bottom: 20%;
  }

  .system-card-operator .chip-3 {
    right: 8%;
    top: 26%;
  }

  .system-card-operator .chip-4 {
    right: 7%;
    bottom: 18%;
    min-width: 7.25rem;
    border-color: rgba(105, 210, 84, 0.38);
  }

  .system-card-team .chip-1 {
    left: 8%;
    bottom: 13%;
  }

  .system-card-team .chip-2 {
    right: 9%;
    top: 18%;
  }

  .system-card-team .chip-3 {
    right: 10%;
    bottom: 15%;
    background: rgba(15, 18, 19, 0.88);
    color: #f5f5f1;
  }

  .chip-3::before,
  .system-card-operator .chip-4::before {
    content: "";
    width: 0.46rem;
    height: 0.46rem;
    margin-right: 0.42rem;
    border-radius: 50%;
    background: #69d254;
    box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.42);
    animation: pulse-dot 2.35s ease-out infinite;
  }

  .system-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.5rem;
  }

  .system-copy .subtitle {
    margin-bottom: 0.75rem;
    color: rgba(15, 18, 19, 0.5);
  }

  .system-copy h3 {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -0.015em;
    margin-bottom: 0.6rem;
    color: var(--text-primary);
  }

  .system-copy span {
    display: block;
    margin-top: auto;
    color: rgba(15, 18, 19, 0.56);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @keyframes float-chip {
    0%, 100% {
      transform: translate3d(0, 0, 0);
      opacity: 0.9;
    }

    50% {
      transform: translate3d(0.55rem, -0.58rem, 0);
      opacity: 1;
    }
  }

  @keyframes request-slide {
    0%, 100% {
      transform: translate3d(-0.35rem, 0.15rem, 0);
      opacity: 0.72;
    }

    42% {
      transform: translate3d(0.75rem, -0.28rem, 0);
      opacity: 1;
    }

    72% {
      transform: translate3d(0.2rem, 0.35rem, 0);
      opacity: 0.92;
    }
  }

  @keyframes pulse-dot {
    0% {
      box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.42);
    }

    70%, 100% {
      box-shadow: 0 0 0 0.65rem rgba(105, 210, 84, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-chip,
    .chip-3::before,
    .system-card-operator .chip-4::before {
      animation: none;
    }
  }

  @media (max-width: 920px) {
    .system-cards {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }

  @media (max-width: 767px) {
    .system-overview {
      padding: 0 0 4.5rem;
    }

    .system-cards {
      margin-top: -2.25rem;
    }
  }

  @media (max-width: 479px) {
    .motion-chip {
      min-width: 4.9rem;
      height: 1.82rem;
      font-size: 0.58rem;
    }
  }
</style>
