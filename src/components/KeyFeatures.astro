---
const pillars = [
  {
    title: "Plan",
    description: "Turn goals, offers, audience context, and scattered ideas into a campaign plan the business can actually use.",
  },
  {
    title: "Ship",
    description: "Create social posts, landing pages, lead lists, emails, and sales assets with approvals organized in one place.",
  },
  {
    title: "Learn",
    description: "Capture what was approved, what changed, and what worked so the next campaign starts sharper than the last one.",
  },
];
---

<section class="section light-green key-features-section" id="system-foundation">
  <div class="container">
    <div class="section-header text-center animate-fade-up">
      <p class="subtitle">THE MARKETHINK DIFFERENCE</p>
      <h2>A marketing system that learns your business<br />and keeps getting sharper every week.</h2>
      <p class="section-description">
        Most teams have enough tools. What they are missing is a connected rhythm for planning the work, shipping the assets, tracking approvals, and remembering what should happen next.
      </p>
    </div>
    <div class="feature-system-visual animate-fade-up">
      <img src="/images/key-feature-markethink-input-output-flow.avif" alt="Markethink system turning inputs into marketing outputs" />
    </div>
    <div class="pillar-grid animate-stagger" aria-label="Plan, ship, learn">
      {pillars.map((pillar) => (
        <article class="pillar-card">
          <span class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="img">
              <circle cx="24" cy="24" r="21" fill="none" stroke="currentColor" stroke-width="2" />
              <path d="M15 25.5h18M15 18.5h18M15 32.5h11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
          <h3>{pillar.title}</h3>
          <p>{pillar.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-description {
    font-size: 1.125rem;
    font-weight: 500;
    color: rgba(15, 18, 19, 0.8);
    margin-top: 1rem;
    max-width: 46rem;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .key-features-section .subtitle {
    color: rgba(0, 0, 0, 0.5);
  }

  .key-features-section h2 {
    color: var(--text-primary);
  }

  .feature-system-visual {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .feature-system-visual img {
    width: min(1040px, 100%);
    height: auto;
    border-radius: var(--radius-medium);
    transition: transform 0.6s ease;
  }

  .feature-system-visual:hover img {
    transform: scale(1.03);
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .pillar-card {
    display: flex;
    flex-direction: column;
    min-height: 15rem;
    padding: 1.75rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: var(--radius-medium);
    background: rgba(255, 255, 255, 0.56);
    transition: transform 0.35s ease, border-color 0.35s ease, background 0.35s ease;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
    border-color: rgba(105, 210, 84, 0.35);
    background: rgba(255, 255, 255, 0.82);
  }

  .pillar-icon {
    width: 3.2rem;
    height: 3.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    border-radius: 50%;
    background: #0f1213;
    color: #69d254;
  }

  .pillar-icon svg {
    width: 2rem;
    height: 2rem;
  }

  .pillar-card h3 {
    font-family: var(--font-body);
    font-size: 1.45rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    margin-bottom: 0.65rem;
    color: var(--text-primary);
  }

  .pillar-card p {
    color: rgba(15, 18, 19, 0.62);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  @media (max-width: 767px) {
    .pillar-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
