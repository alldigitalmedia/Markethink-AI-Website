---
const pillars = [
  {
    title: "Plan",
    description: "Turn goals, offers, audience context, and scattered ideas into a campaign plan the business can actually use.",
  },
  {
    title: "Ship",
    description: "Create social posts, landing pages, lead lists, emails, and sales assets with approvals organized in one place.",
  },
  {
    title: "Learn",
    description: "Capture what was approved, what changed, and what worked so the next campaign starts sharper than the last one.",
  },
];

const systemVideoUrl = "https://dashboard.markethink.ai/generated/social/markethink/mt-home-hero-phone-video-20260703234443.webp";
---

<section class="section light-green key-features-section" id="system-foundation">
  <div class="container">
    <div class="difference-grid">
      <div class="section-header difference-copy animate-fade-up">
        <p class="subtitle">THE MARKETHINK DIFFERENCE</p>
        <h2>A marketing system that learns your business<br />and keeps getting sharper every week.</h2>
        <p class="section-description">
          Most teams have enough tools. What they are missing is a connected rhythm for planning the work, shipping the assets, tracking approvals, and remembering what should happen next.
        </p>
      </div>
      <div class="feature-system-visual animate-fade-up">
        <img src={systemVideoUrl} alt="Animated Markethink phone workflow showing a request moving from AI operator to dedicated marketer and approval" loading="lazy" decoding="async" />
      </div>
    </div>
    <div class="pillar-grid animate-stagger" aria-label="Plan, ship, learn">
      {pillars.map((pillar) => (
        <article class="pillar-card">
          <span class="pillar-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="img">
              <circle cx="24" cy="24" r="21" fill="none" stroke="currentColor" stroke-width="2" />
              <path d="M15 25.5h18M15 18.5h18M15 32.5h11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
          <h3>{pillar.title}</h3>
          <p>{pillar.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .difference-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(24rem, 1.08fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }

  .difference-copy {
    text-align: left;
  }

  .section-description {
    font-size: 1.125rem;
    font-weight: 500;
    color: rgba(15, 18, 19, 0.8);
    margin-top: 1rem;
    max-width: 40rem;
    line-height: 1.6;
  }

  .key-features-section .subtitle {
    color: rgba(0, 0, 0, 0.5);
  }

  .key-features-section h2 {
    color: var(--text-primary);
  }

  .feature-system-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .feature-system-visual::before {
    content: "";
    position: absolute;
    inset: 9% -3% -6% 18%;
    z-index: 0;
    border-radius: 2rem;
    background: rgba(105, 210, 84, 0.18);
    filter: blur(32px);
    pointer-events: none;
  }

  .feature-system-visual img {
    position: relative;
    z-index: 1;
    width: min(560px, 100%);
    height: auto;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: 2rem;
    box-shadow: 0 28px 70px rgba(15, 18, 19, 0.13), inset 0 1px 0 rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.66);
    transition: transform 0.6s ease;
  }

  .feature-system-visual:hover img {
    transform: translateY(-4px) scale(1.015);
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: clamp(2.4rem, 5vw, 4rem);
  }

  .pillar-card {
    display: flex;
    flex-direction: column;
    min-height: 15rem;
    padding: 1.75rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: var(--radius-medium);
    background: rgba(255, 255, 255, 0.56);
    transition: transform 0.35s ease, border-color 0.35s ease, background 0.35s ease;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
    border-color: rgba(105, 210, 84, 0.35);
    background: rgba(255, 255, 255, 0.82);
  }

  .pillar-icon {
    width: 3.2rem;
    height: 3.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    border-radius: 50%;
    background: #0f1213;
    color: #69d254;
  }

  .pillar-icon svg {
    width: 2rem;
    height: 2rem;
  }

  .pillar-card h3 {
    font-family: var(--font-body);
    font-size: 1.45rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    margin-bottom: 0.65rem;
    color: var(--text-primary);
  }

  .pillar-card p {
    color: rgba(15, 18, 19, 0.62);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  @media (max-width: 980px) {
    .difference-grid {
      grid-template-columns: 1fr;
    }

    .difference-copy {
      text-align: center;
    }

    .section-description {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 767px) {
    .pillar-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
