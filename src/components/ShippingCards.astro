---
const lanes = [
  {
    name: "Web",
    label: "Website work in motion",
    icon: "M5 7.5A2.5 2.5 0 0 1 7.5 5h9A2.5 2.5 0 0 1 19 7.5v7A2.5 2.5 0 0 1 16.5 17h-9A2.5 2.5 0 0 1 5 14.5v-7Zm2.2 1.2h9.6M8 12h3.5m1.5 0h3",
    moments: [
      { value: "23", label: "updates prepared" },
      { value: "2", label: "new landing pages created" },
      { value: "1", label: "new blog post written" },
      { value: "6", label: "page sections moved to review" },
    ],
    live: "Website work no longer stuck in the queue",
    activity: ["Request captured", "Draft ready for review", "SEO pass", "Approval package"],
    chips: ["Landing", "Copy", "SEO", "QA"],
    bars: [36, 62, 78, 44, 90],
  },
  {
    name: "Grow",
    label: "Opportunities sorted",
    icon: "M12 4.5v15M5.5 12h13M7 7.2c2.8 2.2 7.2 2.2 10 0M7 16.8c2.8-2.2 7.2-2.2 10 0",
    moments: [
      { value: "234", label: "prospects reviewed" },
      { value: "18", label: "fit signals checked" },
      { value: "9", label: "follow-ups queued" },
      { value: "4", label: "warm opportunities flagged" },
    ],
    live: "Good-fit leads move before they go cold",
    activity: ["Fit signals checked", "Next follow-up queued", "Profiles enriched", "Owner assigned"],
    chips: ["ICP", "CRM", "Email", "Follow-up"],
    bars: [58, 44, 82, 68, 96],
  },
  {
    name: "Ads",
    label: "Campaign assets aligned",
    icon: "M6 16.5 10 7l3.2 6.2L18 5.5l-3 13-3.4-6.1-5.6 4.1Z",
    moments: [
      { value: "23", label: "assets mapped" },
      { value: "5", label: "campaign angles tightened" },
      { value: "3", label: "ad variants prepared" },
      { value: "1", label: "approval package ready" },
    ],
    live: "Campaign pieces stay connected",
    activity: ["Message angle tightened", "Audience matched", "Asset mapped", "Decision ready"],
    chips: ["Creative", "Offer", "Audience", "Tracking"],
    bars: [46, 76, 52, 88, 64],
  },
];

const railItems = [
  "Website update prepared",
  "Campaign angle tightened",
  "Lead follow-up queued",
  "Approval ready",
  "Landing page moved to review",
  "Follow-up context updated",
];
---

<section class="shipping-cards-section" id="shipping-now" aria-label="What Markethink is shipping">
  <div class="container shipping-container">
    <div class="shipping-header animate-fade-up">
      <div>
        <h2>Your marketing should not wait for another meeting.</h2>
      </div>
      <p>
        Text Markethink once. Website updates, campaign assets, lead follow-up, and approvals move into one organized production flow, so the work keeps moving without your team restarting from zero.
      </p>
    </div>

    <div class="production-console animate-scale-in">
      <div class="console-topbar" aria-hidden="true">
        <span></span>
        <strong>Work moving now</strong>
        <div class="console-pulse"><i></i><i></i><i></i></div>
      </div>

      <div class="live-rail" aria-hidden="true">
        <div class="rail-track">
          {[...railItems, ...railItems].map((item) => (
            <span><i></i>{item}</span>
          ))}
        </div>
      </div>

      <div class="shipping-panel" data-shipping-panel>
        {lanes.map((lane, index) => (
          <article class="shipping-card" data-shipping-card={index} tabindex="0">
            <div class="card-topline">
              <div class="lane-mark">
                <span class="icon-bubble" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d={lane.icon} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <div>
                  <p class="card-eyebrow">{lane.name}</p>
                  <strong>{lane.label}</strong>
                </div>
              </div>
              <span class="card-live"><i></i>Live</span>
            </div>

            <div class="card-core" aria-label={`${lane.name} work moments`}>
              <div class="metric-rotator">
                {lane.moments.map((moment, momentIndex) => (
                  <div class="metric-moment" style={`--moment-index: ${momentIndex}`}>
                    <strong>{moment.value}</strong>
                    <span>{moment.label}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="sparkline" aria-hidden="true">
              {lane.bars.map((bar, barIndex) => (
                <span style={`--bar: ${bar}%; --bar-delay: ${barIndex * -0.85}s`}></span>
              ))}
            </div>

            <div class="activity-feed" aria-label={`${lane.name} activity feed`}>
              <div class="feed-track">
                {[...lane.activity, ...lane.activity].map((item) => (
                  <span><i></i>{item}</span>
                ))}
              </div>
            </div>

            <div class="chip-row" aria-label={`${lane.name} work types`}>
              {lane.chips.map((chip, chipIndex) => (
                <span style={`--chip-delay: ${chipIndex * -1.2}s`}>{chip}</span>
              ))}
            </div>

            <div class="card-status">
              <span>{lane.live}</span>
              <i></i>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initShippingCards() {
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-shipping-card]"));
    if (!cards.length) return;

    const activate = (activeCard: HTMLElement) => {
      cards.forEach((card) => card.classList.toggle("active", card === activeCard));
    };

    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => activate(card));
      card.addEventListener("focus", () => activate(card));
      card.addEventListener("click", () => activate(card));
    });
  }

  document.addEventListener("DOMContentLoaded", initShippingCards);
  if (document.readyState !== "loading") {
    initShippingCards();
  }
</script>

<style>
  .shipping-cards-section {
    position: relative;
    overflow: hidden;
    padding: 6.6rem 0 7.4rem;
    background:
      radial-gradient(circle at 18% 10%, rgba(105, 210, 84, 0.18), transparent 25rem),
      radial-gradient(circle at 92% 18%, rgba(237, 244, 234, 0.1), transparent 27rem),
      linear-gradient(180deg, #0f1213 0%, #121617 100%);
    color: #f5f5f1;
  }

  .shipping-cards-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(245, 245, 241, 0.05) 1px, transparent 1px),
      linear-gradient(180deg, rgba(245, 245, 241, 0.035) 1px, transparent 1px);
    background-size: 5rem 5rem;
    mask-image: linear-gradient(180deg, black 0%, transparent 76%);
    pointer-events: none;
  }

  .shipping-cards-section::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 12rem;
    background: linear-gradient(180deg, transparent, rgba(105, 210, 84, 0.04));
    pointer-events: none;
  }

  .shipping-container {
    position: relative;
    z-index: 1;
  }

  .shipping-header {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(21rem, 0.66fr);
    gap: clamp(2rem, 5vw, 4.25rem);
    align-items: end;
    margin-bottom: 1.8rem;
  }

  .shipping-header h2 {
    max-width: 55rem;
    color: #f5f5f1;
    font-size: clamp(2.75rem, 5.45vw, 6.15rem);
    line-height: 0.94;
    letter-spacing: -0.058em;
  }

  .shipping-header p {
    max-width: 34rem;
    color: rgba(245, 245, 241, 0.76);
    font-size: clamp(1.02rem, 1.16vw, 1.14rem);
    line-height: 1.72;
  }

  .production-console {
    position: relative;
    overflow: hidden;
    padding: clamp(1rem, 1.7vw, 1.25rem);
    border: 1px solid rgba(245, 245, 241, 0.14);
    border-radius: 2.25rem;
    background:
      linear-gradient(180deg, rgba(245, 245, 241, 0.105), rgba(245, 245, 241, 0.035)),
      rgba(15, 18, 19, 0.84);
    box-shadow: 0 36px 120px rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .production-console::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 73% 0%, rgba(105, 210, 84, 0.16), transparent 22rem);
    pointer-events: none;
  }

  .console-topbar,
  .live-rail,
  .shipping-panel {
    position: relative;
    z-index: 1;
  }

  .console-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.55rem;
    padding: 0 0.35rem 0.8rem;
    color: rgba(245, 245, 241, 0.68);
    font-size: 0.78rem;
    font-weight: 750;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .console-topbar > span {
    width: 4.5rem;
    height: 0.7rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #69d254, rgba(105, 210, 84, 0.2));
  }

  .console-pulse {
    display: flex;
    gap: 0.34rem;
  }

  .console-pulse i {
    width: 0.44rem;
    height: 0.44rem;
    border-radius: 999px;
    background: rgba(245, 245, 241, 0.34);
    animation: pulse-soft 3.8s ease-in-out infinite;
  }

  .console-pulse i:nth-child(2) { animation-delay: 0.2s; }
  .console-pulse i:nth-child(3) { animation-delay: 0.4s; }

  .live-rail {
    overflow: hidden;
    margin-bottom: 1rem;
    border: 1px solid rgba(245, 245, 241, 0.09);
    border-radius: var(--radius-button);
    background: rgba(245, 245, 241, 0.055);
    mask-image: linear-gradient(90deg, transparent 0, black 8%, black 92%, transparent 100%);
  }

  .rail-track {
    display: flex;
    width: max-content;
    gap: 0.55rem;
    padding: 0.55rem;
    animation: rail-move 68s linear infinite;
  }

  .rail-track span {
    display: inline-flex;
    align-items: center;
    gap: 0.46rem;
    min-height: 2.25rem;
    padding: 0 0.92rem;
    border-radius: var(--radius-button);
    background: rgba(245, 245, 241, 0.085);
    color: rgba(245, 245, 241, 0.78);
    font-size: 0.78rem;
    font-weight: 680;
    white-space: nowrap;
  }

  .rail-track i,
  .card-live i,
  .feed-track i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #69d254;
    box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.46);
    animation: pulse-dot 4.6s ease-out infinite;
  }

  .shipping-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.95rem, 1.4vw, 1.15rem);
  }

  .shipping-card {
    position: relative;
    overflow: hidden;
    min-height: 21.4rem;
    padding: clamp(1rem, 1.35vw, 1.18rem);
    border: 1px solid rgba(245, 245, 241, 0.32);
    border-radius: 1.6rem;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(237, 244, 234, 0.82) 52%, rgba(105, 210, 84, 0.13)),
      #f5f5f1;
    color: #0f1213;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.72);
    outline: none;
    transform: translateY(0);
    transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }

  .shipping-card:hover,
  .shipping-card:focus,
  .shipping-card.active {
    border-color: rgba(105, 210, 84, 0.68);
    box-shadow: 0 28px 78px rgba(0, 0, 0, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.76);
    transform: none;
  }

  .shipping-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 0%, rgba(105, 210, 84, 0.22), transparent 9rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.42), transparent 38%);
    pointer-events: none;
  }

  .shipping-card::after {
    content: "";
    position: absolute;
    inset: auto 1rem 0.9rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(15, 18, 19, 0.15), transparent);
  }

  .card-topline,
  .card-core,
  .sparkline,
  .activity-feed,
  .chip-row,
  .card-status {
    position: relative;
    z-index: 1;
  }

  .card-topline {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .lane-mark {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
  }

  .icon-bubble {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 2.55rem;
    height: 2.55rem;
    border-radius: 0.95rem;
    background: #0f1213;
    color: #69d254;
    box-shadow: 0 12px 26px rgba(15, 18, 19, 0.18), inset 0 0 0 1px rgba(105, 210, 84, 0.24);
  }

  .icon-bubble svg {
    width: 1.28rem;
    height: 1.28rem;
  }

  .card-eyebrow {
    color: rgba(15, 18, 19, 0.48);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .lane-mark strong {
    display: block;
    margin-top: 0.15rem;
    color: #0f1213;
    font-size: clamp(0.92rem, 1vw, 1.02rem);
    line-height: 1.1;
    letter-spacing: -0.018em;
  }

  .card-live {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    min-height: 1.85rem;
    padding: 0 0.58rem;
    border-radius: var(--radius-button);
    background: #0f1213;
    color: #f5f5f1;
    font-size: 0.66rem;
    font-weight: 800;
  }

  .card-core {
    position: relative;
    min-height: 5.2rem;
    margin: 0.5rem 0 0.9rem;
    overflow: hidden;
  }

  .metric-rotator {
    position: relative;
    min-height: 5.2rem;
  }

  .metric-moment {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: end;
    column-gap: 0.72rem;
    opacity: 0;
    transform: translateY(0.75rem);
    animation: metric-moment 20s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    animation-delay: calc(var(--moment-index) * 5s);
    will-change: opacity, transform;
  }

  .metric-moment strong {
    display: block;
    color: #0f1213;
    font-size: clamp(2.55rem, 3.85vw, 3.65rem);
    font-weight: 790;
    line-height: 1.08;
    letter-spacing: -0.055em;
    font-variant-numeric: tabular-nums;
  }

  .metric-moment span {
    display: block;
    max-width: 11rem;
    padding-bottom: 0.45rem;
    color: rgba(15, 18, 19, 0.64);
    font-size: clamp(0.78rem, 0.82vw, 0.88rem);
    font-weight: 820;
    line-height: 1.16;
    text-wrap: balance;
  }

  .sparkline {
    display: flex;
    align-items: end;
    gap: 0.26rem;
    height: 2.65rem;
    margin-bottom: 0.85rem;
    padding: 0.58rem 0.64rem;
    border-radius: 1.05rem;
    background: rgba(255, 255, 255, 0.62);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .sparkline span {
    flex: 1;
    height: var(--bar);
    border-radius: 999px 999px 0 0;
    background: linear-gradient(180deg, rgba(105, 210, 84, 0.92), rgba(105, 210, 84, 0.18));
    transform-origin: bottom;
    animation: bar-breathe 9.5s ease-in-out infinite;
    animation-delay: var(--bar-delay);
  }

  .activity-feed {
    height: 4.25rem;
    overflow: hidden;
    border: 1px solid rgba(15, 18, 19, 0.075);
    border-radius: 1.05rem;
    background: rgba(255, 255, 255, 0.68);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78);
  }

  .feed-track {
    display: grid;
    animation: feed-move 26s ease-in-out infinite;
  }

  .feed-track span {
    display: flex;
    align-items: center;
    gap: 0.52rem;
    min-height: 2.12rem;
    padding: 0 0.82rem;
    color: rgba(15, 18, 19, 0.72);
    font-size: 0.78rem;
    font-weight: 760;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.82rem;
  }

  .chip-row span {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    padding: 0 0.62rem;
    border-radius: var(--radius-button);
    background: rgba(15, 18, 19, 0.06);
    color: rgba(15, 18, 19, 0.66);
    font-size: 0.68rem;
    font-weight: 780;
    animation: chip-shift 8.8s ease-in-out infinite;
    animation-delay: var(--chip-delay);
  }

  .card-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.92rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(15, 18, 19, 0.08);
    color: rgba(15, 18, 19, 0.78);
    font-size: 0.76rem;
    font-weight: 820;
    line-height: 1.25;
  }

  .card-status i {
    width: 2.3rem;
    height: 0.5rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(105, 210, 84, 0.2), #69d254);
    animation: status-scan 6.2s ease-in-out infinite;
  }

  @keyframes rail-move {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @keyframes metric-moment {
    0% { opacity: 0; transform: translateY(0.75rem); }
    6%, 22% { opacity: 1; transform: translateY(0); }
    28%, 100% { opacity: 0; transform: translateY(-0.55rem); }
  }

  @keyframes feed-move {
    0%, 24% { transform: translateY(0); }
    34%, 52% { transform: translateY(-2.12rem); }
    62%, 80% { transform: translateY(-4.24rem); }
    90%, 100% { transform: translateY(-6.36rem); }
  }

  @keyframes bar-breathe {
    0%, 100% { transform: scaleY(0.72); opacity: 0.68; }
    46% { transform: scaleY(1); opacity: 1; }
  }

  @keyframes pulse-dot {
    0% { box-shadow: 0 0 0 0 rgba(105, 210, 84, 0.46); }
    72%, 100% { box-shadow: 0 0 0 0.55rem rgba(105, 210, 84, 0); }
  }

  @keyframes pulse-soft {
    0%, 100% { opacity: 0.28; transform: translateY(0); }
    48% { opacity: 1; transform: translateY(-0.1rem); }
  }

  @keyframes chip-shift {
    0%, 100% { transform: translateY(0); }
    45% { transform: translateY(-0.12rem); }
  }

  @keyframes status-scan {
    0%, 100% { transform: scaleX(0.68); opacity: 0.62; }
    45% { transform: scaleX(1); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail-track,
    .console-pulse i,
    .rail-track i,
    .card-live i,
    .feed-track i,
    .metric-moment,
    .sparkline span,
    .feed-track,
    .chip-row span,
    .card-status i {
      animation: none;
    }

    .metric-moment {
      position: static;
      display: none;
      opacity: 1;
      transform: none;
    }

    .metric-moment:first-child {
      display: grid;
    }
  }

  @media (max-width: 1060px) {
    .shipping-panel {
      grid-template-columns: 1fr;
      max-width: 34rem;
      margin: 0 auto;
    }

    .shipping-card {
      min-height: 20.8rem;
    }
  }

  @media (max-width: 767px) {
    .shipping-cards-section {
      padding: 4.7rem 0 5.6rem;
    }

    .shipping-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .production-console {
      padding: 0.72rem;
      border-radius: 1.5rem;
    }

    .console-topbar {
      padding-inline: 0.15rem;
    }

    .shipping-card {
      padding: 0.9rem;
      border-radius: 1.2rem;
    }

    .card-core,
    .metric-rotator {
      min-height: 5.6rem;
    }

    .metric-moment {
      grid-template-columns: 1fr;
      align-items: start;
      row-gap: 0.1rem;
    }

    .metric-moment span {
      max-width: 100%;
      padding-bottom: 0;
    }
  }
</style>
