---
const lanes = [
  {
    kicker: "WEBSITE",
    title: "From loose request to review-ready page.",
    body: "A website note becomes page structure, copy, visual direction, SEO notes, and approval context in one lane.",
    proof: "No scattered docs. No lost edits.",
    tags: ["Landing pages", "Copy", "SEO", "Review"],
  },
  {
    kicker: "CAMPAIGNS",
    title: "Build the campaign spine before the assets start.",
    body: "Audience, offer, angle, channel plan, creative asks, and approvals stay connected before work gets fragmented.",
    proof: "Every asset ships with a point of view.",
    tags: ["Offer", "Angle", "Social", "Email"],
  },
  {
    kicker: "LEADS",
    title: "Turn prospects into organized next steps.",
    body: "Lead lists, fit notes, outreach context, CRM movement, and reminders stay tied to the campaign that created demand.",
    proof: "Good-fit opportunities do not go cold.",
    tags: ["Prospects", "CRM", "Outreach", "Follow-up"],
  },
  {
    kicker: "APPROVALS",
    title: "Make every decision useful next time.",
    body: "Feedback, final versions, approved language, and rejected directions become system memory for the next round of work.",
    proof: "The next request starts sharper.",
    tags: ["Feedback", "Memory", "Versions", "Decisions"],
  },
];

const flow = ["Request", "Campaign", "Asset", "Approval", "Follow-up"];
---

<section class="move-section" id="strategy-system" aria-labelledby="move-section-title">
  <div class="container move-container">
    <div class="move-header animate-fade-up">
      <p class="subtitle">What Markethink can move</p>
      <div class="move-headline-row">
        <h2 id="move-section-title">The work stops scattering.</h2>
        <p>
          Markethink connects the request, campaign, asset, approval, and follow-up, so marketing moves from a chat message to review-ready work without restarting from zero.
        </p>
      </div>
    </div>

    <div class="move-flow" aria-label="Markethink operating flow">
      {flow.map((item, index) => (
        <div class="flow-step" style={`--step:${index}`}>
          <span>{index + 1}</span>
          <strong>{item}</strong>
        </div>
      ))}
    </div>

    <div class="move-grid">
      {lanes.map((lane, index) => (
        <article class="move-card" style={`--card:${index}`}>
          <div class="move-card-top">
            <span>{lane.kicker}</span>
            <i aria-hidden="true"></i>
          </div>
          <h3>{lane.title}</h3>
          <p>{lane.body}</p>
          <div class="move-proof">
            <em aria-hidden="true">✦</em>
            <strong>{lane.proof}</strong>
          </div>
          <div class="move-tags" aria-label={`${lane.kicker} work included`}>
            {lane.tags.map((tag) => <small>{tag}</small>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .move-section {
    position: relative;
    overflow: hidden;
    padding: clamp(5.2rem, 8vw, 8.4rem) 0 clamp(5rem, 7vw, 7.6rem);
    background:
      radial-gradient(circle at 8% 4%, rgba(105, 210, 84, 0.18), transparent 26rem),
      radial-gradient(circle at 92% 18%, rgba(105, 210, 84, 0.1), transparent 24rem),
      linear-gradient(180deg, #edf4ea 0%, #f5f5f1 100%);
    color: #0f1213;
  }

  .move-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15, 18, 19, 0.045) 1px, transparent 1px),
      linear-gradient(180deg, rgba(15, 18, 19, 0.035) 1px, transparent 1px);
    background-size: 5.2rem 5.2rem;
    mask-image: linear-gradient(180deg, black 0%, transparent 78%);
    pointer-events: none;
  }

  .move-container { position: relative; z-index: 1; }

  .move-header { margin-bottom: clamp(2rem, 4vw, 3.4rem); }

  .move-header .subtitle {
    margin-bottom: 1rem;
    color: rgba(15, 18, 19, 0.54);
  }

  .move-headline-row {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(22rem, 0.52fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
  }

  .move-headline-row h2 {
    max-width: 56rem;
    font-size: clamp(3.2rem, 6.7vw, 7.35rem);
    line-height: 0.88;
    letter-spacing: -0.066em;
  }

  .move-headline-row p {
    max-width: 35rem;
    color: rgba(15, 18, 19, 0.68);
    font-size: clamp(1rem, 1.18vw, 1.13rem);
    line-height: 1.68;
  }

  .move-flow {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.65rem;
    margin-bottom: 1rem;
    padding: 0.7rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: 1.65rem;
    background: rgba(255, 255, 255, 0.54);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
  }

  .move-flow::before {
    content: "";
    position: absolute;
    left: 2rem;
    right: 2rem;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(105, 210, 84, 0.55), transparent);
    pointer-events: none;
  }

  .flow-step {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3.2rem;
    border-radius: 1.05rem;
    background: rgba(245, 245, 241, 0.86);
    color: rgba(15, 18, 19, 0.74);
    font-size: 0.78rem;
    font-weight: 780;
    box-shadow: 0 10px 28px rgba(15, 18, 19, 0.06);
  }

  .flow-step span {
    display: grid;
    place-items: center;
    width: 1.55rem;
    height: 1.55rem;
    border-radius: 999px;
    background: #0f1213;
    color: #69d254;
    font-size: 0.68rem;
  }

  .move-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.85rem, 1.4vw, 1.15rem);
  }

  .move-card {
    position: relative;
    overflow: hidden;
    min-height: 25.5rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1.15rem, 1.6vw, 1.45rem);
    border: 1px solid rgba(15, 18, 19, 0.1);
    border-radius: 1.55rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(245, 245, 241, 0.82) 50%, rgba(237, 244, 234, 0.78)),
      #f5f5f1;
    box-shadow: 0 24px 70px rgba(15, 18, 19, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.74);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .move-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 86% 10%, rgba(105, 210, 84, 0.22), transparent 8.5rem),
      linear-gradient(90deg, transparent 0 1.15rem, rgba(15, 18, 19, 0.055) 1.15rem 1.21rem, transparent 1.21rem);
    pointer-events: none;
  }

  .move-card:hover {
    border-color: rgba(105, 210, 84, 0.42);
    box-shadow: 0 30px 84px rgba(15, 18, 19, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.78);
    transform: translateY(-0.18rem);
  }

  .move-card > * { position: relative; z-index: 1; }

  .move-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }

  .move-card-top span {
    color: rgba(15, 18, 19, 0.48);
    font-size: 0.72rem;
    font-weight: 860;
    letter-spacing: 0.14em;
  }

  .move-card-top i {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #69d254, rgba(105, 210, 84, 0.16)), #edf4ea;
    box-shadow: 0 0 0 0.42rem rgba(105, 210, 84, 0.1);
  }

  .move-card h3 {
    max-width: 18rem;
    font-family: var(--font-body);
    font-size: clamp(1.42rem, 1.8vw, 1.8rem);
    font-weight: 560;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1rem;
  }

  .move-card p {
    color: rgba(15, 18, 19, 0.66);
    font-size: 0.92rem;
    line-height: 1.56;
  }

  .move-proof {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: auto;
    padding-top: 1.4rem;
    color: #0f1213;
    font-size: 0.86rem;
    line-height: 1.35;
  }

  .move-proof em {
    color: #69d254;
    font-style: normal;
    line-height: 1;
    margin-top: 0.12rem;
  }

  .move-proof strong { font-weight: 760; }

  .move-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin-top: 1.1rem;
  }

  .move-tags small {
    display: inline-flex;
    align-items: center;
    min-height: 1.82rem;
    padding: 0 0.62rem;
    border-radius: 999px;
    background: rgba(15, 18, 19, 0.06);
    color: rgba(15, 18, 19, 0.64);
    font-size: 0.68rem;
    font-weight: 780;
  }

  @media (max-width: 1080px) {
    .move-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 900px) {
    .move-headline-row { grid-template-columns: 1fr; }
    .move-flow { grid-template-columns: 1fr; }
    .move-flow::before { display: none; }
  }

  @media (max-width: 640px) {
    .move-section { padding-top: 4.4rem; }
    .move-grid { grid-template-columns: 1fr; }
    .move-card { min-height: 0; }
  }
</style>
