---
const capabilities = [
  {
    kicker: "WEBSITE",
    title: "Turn a vague website request into a page ready for review",
    owner: "Markethink web lane",
    body: "Copy, section structure, visual direction, SEO notes, and approval context move together instead of living across separate files.",
    tags: ["Landing page", "Copy", "SEO", "Review"],
  },
  {
    kicker: "CAMPAIGNS",
    title: "Build the campaign spine before the assets start",
    owner: "Campaign studio",
    body: "Audience, offer, angle, channel plan, creative asks, and approval steps stay connected so the work ships with a point of view.",
    tags: ["Offer", "Angle", "Social", "Email"],
  },
  {
    kicker: "LEADS",
    title: "Move from scattered prospects to organized opportunities",
    owner: "Growth lane",
    body: "Lead lists, fit notes, outreach context, next steps, and follow-up reminders stay tied to the campaign that created demand.",
    tags: ["Prospects", "CRM", "Outreach", "Follow-up"],
  },
  {
    kicker: "APPROVALS",
    title: "Keep decisions from disappearing after the meeting",
    owner: "Approval memory",
    body: "Feedback, final versions, approved language, and rejected directions become part of the system so the next round starts smarter.",
    tags: ["Feedback", "Memory", "Versions", "Decisions"],
  },
  {
    kicker: "CONTENT",
    title: "Ship social and email without restarting every week",
    owner: "Content lane",
    body: "Ideas become briefs, briefs become assets, assets move to approval, and the approved patterns inform the next batch.",
    tags: ["Briefs", "Posts", "Email", "Reuse"],
  },
  {
    kicker: "REPORTING",
    title: "Bring learnings back into the next campaign",
    owner: "Learning loop",
    body: "What worked, what stalled, and what needs another angle becomes operational context, not a forgotten note in a report.",
    tags: ["Signals", "Learnings", "Next move", "Focus"],
  },
];
---

<section class="strategy-scroll-section" id="strategy-system" aria-labelledby="strategy-system-title">
  <div class="strategy-shell">
    <div class="container strategy-header animate-fade-up">
      <div>
        <p class="subtitle">What Markethink can move</p>
        <h2 id="strategy-system-title">A marketing system that turns requests into shipped work.</h2>
      </div>
      <div class="strategy-intro">
        <p>
          The old problem is scattered marketing. The better answer is a system that connects the request, the campaign, the asset, the approval, and the follow-up.
        </p>
        <div class="strategy-controls" aria-hidden="true">
          <button type="button" data-strategy-prev aria-label="Scroll strategy cards left">‹</button>
          <button type="button" data-strategy-next aria-label="Scroll strategy cards right">›</button>
        </div>
      </div>
    </div>

    <div class="strategy-rail-wrap" data-strategy-wrap>
      <div class="strategy-rail" data-strategy-rail>
        {capabilities.map((card, index) => (
          <article class="strategy-card" data-strategy-card tabindex="0" style={`--i:${index}`}>
            <div class="card-head">
              <span>{card.kicker}</span>
              <i aria-hidden="true"></i>
            </div>
            <h3>{card.title}</h3>
            <div class="owner-line">
              <span aria-hidden="true">✦</span>
              <strong>{card.owner}</strong>
            </div>
            <p>{card.body}</p>
            <div class="tag-row" aria-label={`${card.kicker} capabilities`}>
              {card.tags.map((tag) => <em>{tag}</em>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initStrategyScroll() {
    const rail = document.querySelector<HTMLElement>("[data-strategy-rail]");
    const wrap = document.querySelector<HTMLElement>("[data-strategy-wrap]");
    const next = document.querySelector<HTMLButtonElement>("[data-strategy-next]");
    const prev = document.querySelector<HTMLButtonElement>("[data-strategy-prev]");
    if (!rail || !wrap) return;

    const scrollByCard = (direction: number) => {
      const card = rail.querySelector<HTMLElement>("[data-strategy-card]");
      const amount = card ? card.offsetWidth + 24 : 380;
      wrap.scrollBy({ left: amount * direction, behavior: "smooth" });
    };

    next?.addEventListener("click", () => scrollByCard(1));
    prev?.addEventListener("click", () => scrollByCard(-1));

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    let timer = window.setInterval(() => {
      const max = wrap.scrollWidth - wrap.clientWidth - 8;
      if (wrap.scrollLeft >= max) {
        wrap.scrollTo({ left: 0, behavior: "smooth" });
      } else {
        scrollByCard(1);
      }
    }, 4200);

    wrap.addEventListener("mouseenter", () => window.clearInterval(timer));
    wrap.addEventListener("focusin", () => window.clearInterval(timer));
  }

  document.addEventListener("DOMContentLoaded", initStrategyScroll);
  if (document.readyState !== "loading") initStrategyScroll();
</script>

<style>
  .strategy-scroll-section {
    overflow: hidden;
    padding: clamp(5rem, 8vw, 8rem) 0 clamp(4.6rem, 7vw, 7.5rem);
    background:
      radial-gradient(circle at 10% 5%, rgba(105, 210, 84, 0.16), transparent 24rem),
      linear-gradient(180deg, #edf4ea 0%, #f5f5f1 100%);
    color: #0f1213;
  }

  .strategy-shell { position: relative; }

  .strategy-header {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(19rem, 0.52fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
    margin-bottom: 2rem;
  }

  .strategy-header .subtitle { margin-bottom: 0.95rem; color: rgba(15, 18, 19, 0.56); }

  .strategy-header h2 {
    max-width: 58rem;
    font-size: clamp(3rem, 6.4vw, 7.2rem);
    line-height: 0.88;
    letter-spacing: -0.066em;
  }

  .strategy-intro { display: grid; gap: 1.3rem; }

  .strategy-intro p {
    color: rgba(15, 18, 19, 0.68);
    font-size: clamp(1rem, 1.18vw, 1.12rem);
    line-height: 1.64;
  }

  .strategy-controls { display: flex; gap: 0.55rem; }

  .strategy-controls button {
    display: grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    border: 1px solid rgba(15, 18, 19, 0.1);
    border-radius: 999px;
    background: #0f1213;
    color: #f5f5f1;
    font-size: 1.7rem;
    line-height: 1;
    cursor: pointer;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .strategy-controls button:first-child { background: rgba(15, 18, 19, 0.06); color: #0f1213; }
  .strategy-controls button:hover { transform: translateY(-0.12rem); }

  .strategy-rail-wrap {
    overflow-x: auto;
    overflow-y: visible;
    margin-inline: max(1rem, calc((100vw - var(--container)) / 2));
    padding: 0.6rem 0 1.1rem;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    mask-image: linear-gradient(90deg, transparent 0, black 5%, black 95%, transparent 100%);
  }

  .strategy-rail-wrap::-webkit-scrollbar { display: none; }

  .strategy-rail { display: flex; gap: 1.1rem; width: max-content; }

  .strategy-card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: min(23rem, 82vw);
    min-height: 25.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(15, 18, 19, 0.1);
    border-radius: 1.55rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.88) 0%, rgba(255, 255, 255, 0.58) 54%, rgba(245, 245, 241, 0.94) 54%, rgba(245, 245, 241, 0.98) 100%),
      #f5f5f1;
    box-shadow: 0 24px 70px rgba(15, 18, 19, 0.1);
    scroll-snap-align: start;
    outline: none;
    transform: translateY(calc((var(--i) % 2) * 0.65rem));
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .strategy-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      linear-gradient(90deg, transparent 0 1.25rem, rgba(15, 18, 19, 0.055) 1.25rem 1.32rem, transparent 1.32rem),
      radial-gradient(circle at 86% 18%, rgba(105, 210, 84, 0.22), transparent 8rem);
    pointer-events: none;
  }

  .strategy-card:hover,
  .strategy-card:focus {
    border-color: rgba(105, 210, 84, 0.55);
    box-shadow: 0 30px 84px rgba(15, 18, 19, 0.16);
    transform: translateY(-0.25rem);
  }

  .card-head, .owner-line, .strategy-card h3, .strategy-card p, .tag-row { position: relative; z-index: 1; }

  .card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.55rem; }

  .card-head span { color: rgba(15, 18, 19, 0.48); font-size: 0.72rem; font-weight: 850; letter-spacing: 0.14em; }

  .card-head i {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #69d254, rgba(105, 210, 84, 0.18)), #edf4ea;
    box-shadow: 0 0 0 0.42rem rgba(105, 210, 84, 0.1);
  }

  .strategy-card h3 {
    max-width: 18rem;
    margin-bottom: auto;
    font-size: clamp(1.7rem, 2.7vw, 2.45rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .owner-line { display: flex; align-items: center; gap: 0.45rem; margin-top: 2.4rem; margin-bottom: 1rem; color: #0f1213; font-size: 0.8rem; }
  .owner-line span { color: #69d254; }

  .strategy-card p { color: rgba(15, 18, 19, 0.66); font-size: 0.92rem; line-height: 1.52; }

  .tag-row { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1.1rem; }

  .tag-row em {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0 0.58rem;
    border-radius: 999px;
    background: rgba(15, 18, 19, 0.06);
    color: rgba(15, 18, 19, 0.62);
    font-size: 0.68rem;
    font-style: normal;
    font-weight: 760;
  }

  @media (max-width: 900px) { .strategy-header { grid-template-columns: 1fr; } }

  @media (max-width: 640px) {
    .strategy-scroll-section { padding-top: 4rem; }
    .strategy-card { min-height: 24rem; padding: 1.25rem; }
    .strategy-controls { display: none; }
    .strategy-rail-wrap { margin-inline: 1rem; mask-image: none; }
  }
</style>
