---
const walkthroughHref = "/schedule-a-walkthrough/";
const dashboardHref = "https://dashboard.markethink.ai";
---

<nav class="navbar" aria-label="Primary navigation">
  <div class="navbar-shell">
    <a href="/#hero" class="nav-brand" aria-label="Markethink home">
      <img src="/images/logo-white.svg" alt="Markethink" class="nav-logo" />
    </a>
    <div class="nav-links" id="primary-navigation">
      <a href="/#how-it-works" class="nav-link">How it works</a>
      <a href="/#strategy-system" class="nav-link">What we move</a>
      <a href="/blog/" class="nav-link">Insights</a>
      <a href="/#markethink-system" class="nav-link">About</a>
    </div>
    <div class="nav-actions">
      <a href={dashboardHref} class="nav-login">Log in</a>
      <a href={walkthroughHref} class="button nav-button">Book a Walkthrough</a>
    </div>
    <button class="mobile-menu-btn" aria-label="Toggle menu" aria-controls="primary-navigation" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<script>
  const menuBtn = document.querySelector(".mobile-menu-btn");
  const navLinks = document.querySelector(".nav-links");
  const navActions = document.querySelector(".nav-actions");

  menuBtn?.addEventListener("click", () => {
    const isOpen = menuBtn.classList.toggle("open");
    menuBtn.setAttribute("aria-expanded", String(isOpen));
    navLinks?.classList.toggle("open", isOpen);
    navActions?.classList.toggle("open", isOpen);
  });
</script>

<style>
  .navbar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.35rem clamp(1rem, 2.2vw, 2rem) 0;
    pointer-events: none;
  }

  .navbar-shell {
    width: min(100%, 118rem);
    margin: 0 auto;
    min-height: 5.25rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    column-gap: clamp(1.5rem, 3vw, 3.4rem);
    padding: 0.9rem 1.35rem;
    border-radius: 1.35rem;
    background: linear-gradient(180deg, rgba(15, 18, 19, 0.78), rgba(15, 18, 19, 0.58));
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(20px) saturate(1.08);
    -webkit-backdrop-filter: blur(20px) saturate(1.08);
    pointer-events: auto;
  }

  .nav-brand {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-self: start;
  }

  .nav-logo {
    width: clamp(148px, 12vw, 210px);
    height: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-self: center;
    gap: clamp(1.4rem, 2.4vw, 3.1rem);
  }

  .nav-link,
  .nav-login {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: clamp(0.92rem, 0.95vw, 1.05rem);
    font-weight: 650;
    line-height: 1;
    color: rgba(255, 255, 255, 0.88);
    transition: color 0.25s ease, transform 0.25s ease;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-login:hover {
    color: #ffffff;
    transform: translateY(-1px);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: clamp(1rem, 1.8vw, 2rem);
  }

  .nav-button {
    min-height: 3.1rem;
    padding: 0.82rem 1.55rem;
    border-radius: 0.85rem;
    font-size: clamp(0.9rem, 0.9vw, 1rem);
    font-weight: 750;
    box-shadow: none;
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
    justify-self: end;
    padding: 0.5rem;
  }

  .mobile-menu-btn span {
    width: 24px;
    height: 2px;
    border-radius: 999px;
    background: white;
    transition: all 0.3s ease;
  }

  @media (max-width: 1040px) {
    .navbar-shell {
      grid-template-columns: auto auto;
      row-gap: 1.1rem;
      min-height: auto;
    }

    .nav-links,
    .nav-actions {
      display: none;
      grid-column: 1 / -1;
      flex-direction: column;
      align-items: flex-start;
      justify-self: stretch;
      width: 100%;
      gap: 1rem;
      padding-top: 0.5rem;
    }

    .nav-links.open,
    .nav-actions.open {
      display: flex;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }

  @media (max-width: 560px) {
    .navbar {
      padding: 0.75rem 0.75rem 0;
    }

    .navbar-shell {
      border-radius: 1rem;
      padding: 0.85rem 1rem;
    }

    .nav-logo {
      width: 145px;
    }

    .nav-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
