    </p>

    <figure class="section-visual">
      <img
        src={`${imageBase}/section-7-thirty-day-plan.svg`}
        width="1536"
        height="1024"
        loading="lazy"
        decoding="async"
        alt="A four-week marketing calendar moving from technical foundation to answer-ready content, trusted evidence, and measurement"
      />
      <figcaption>
        One complete operating loop is more useful than thirty disconnected
        optimization tasks.
      </figcaption>
    </figure>
  </section>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-ai-search-guide]");
    if (!root) return;
    root.classList.add("is-enhanced");

    const auditItems = [...root.querySelectorAll("[data-audit-item]")];
    const score = root.querySelector("[data-audit-score]");
    const progress = root.querySelector("[data-audit-progress]");
    const band = root.querySelector("[data-audit-band]");
    const advice = root.querySelector("[data-audit-advice]");
    const copyButton = root.querySelector("[data-copy-audit]");
    const copyStatus = root.querySelector("[data-copy-status]");

    const updateAudit = () => {
      const checked = auditItems.filter((item) => item.checked).length;
      const firstMissing = auditItems.find((item) => !item.checked);
      score.textContent = String(checked);
      progress.value = checked;
      if (checked <= 2) {
        band.textContent = "Build the foundation first";
      } else if (checked <= 5) {
        band.textContent = "Good signals, fragmented system";
      } else {
        band.textContent = "Ready to compound the work";
      }
      advice.textContent =
        firstMissing?.dataset.recommendation ||
        "Keep the facts current, strengthen evidence, and connect visibility to qualified business outcomes.";
      window.dataLayer?.push({
        event: "ai_search_audit_update",
        score: checked,
      });
    };
    auditItems.forEach((item) => item.addEventListener("change", updateAudit));

    copyButton?.addEventListener("click", async () => {
      const text = `AI-search readiness: ${score.textContent}/8. First action: ${advice.textContent}`;
      try {
        await navigator.clipboard.writeText(text);
        copyStatus.textContent = "Copied.";
      } catch {
        copyStatus.textContent = "Select the recommendation above to copy it.";
      }
      window.dataLayer?.push({ event: "ai_search_audit_copy" });
    });

    const answerButtons = [...root.querySelectorAll("[data-answer-view]")];
    const answerPanels = [...root.querySelectorAll("[data-answer-panel]")];
    answerButtons.forEach((button) =>
      button.addEventListener("click", () => {
        const view = button.dataset.answerView;
        answerButtons.forEach((item) =>
          item.setAttribute("aria-pressed", String(item === button)),
        );
        answerPanels.forEach((panel) =>
          panel.classList.toggle(
            "is-hidden",
            panel.dataset.answerPanel !== view,
          ),
        );
        window.dataLayer?.push({ event: "ai_search_answer_example", view });
      }),
    );

    root.querySelector("[data-print-plan]")?.addEventListener("click", () => {
      window.dataLayer?.push({ event: "ai_search_plan_print" });
      window.print();
    });
  })();
</script>

