---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";

---

<section class="section-hero" id="hero">
  <div class="hero-background" aria-hidden="true">
    <img src="/images/hero-office-background.svg" alt="" class="hero-background-image" />
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-heading animate-fade-up" aria-label="Your marketing should work as hard as you do.">
        <span class="hero-heading-line">Your marketing should work</span>
        <span class="hero-heading-line">as hard as you do.</span>
      </h1>
      <p class="hero-live-line animate-fade-up" aria-label="Right now, it is answering the 11:48pm lead.">
        <span class="hero-live-prefix">Right now, it’s</span>
        <span class="hero-heading-rotator" aria-hidden="true">
          <span class="hero-heading-accent">answering the 11:48pm lead.</span>
          <span class="hero-heading-accent">designing 3 posts in your brand.</span>
          <span class="hero-heading-accent">building Friday’s landing page.</span>
          <span class="hero-heading-accent">following up with quiet leads.</span>
          <span class="hero-heading-accent">drafting Monday’s email.</span>
        </span>
      </p>
      <div class="hero-description hero-heading-support animate-fade-up">
        <p>An AI marketing operator does the work around the clock. A real marketer dedicated to your business reviews what ships. You approve from your phone.</p>
        <p class="hero-price-line">From $500 a month. Cancel anytime.</p>
      </div>
      <div class="button-group animate-fade-up">
        <a href={walkthroughHref} class="button">Watch it work on your business →</a>
        <a href={trialHref} class="button is-secondary">Apply for a 30-Day Trial</a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(7.4rem, 14vh, 8.7rem) 0 clamp(6.8rem, 13vh, 8.6rem);
    background: #0f1213;
  }

  .section-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 50% 46%, rgba(4, 6, 6, 0.24) 0%, rgba(4, 6, 6, 0.6) 48%, rgba(4, 6, 6, 0.88) 100%),
      linear-gradient(180deg, rgba(15, 18, 19, 0.12) 0%, rgba(15, 18, 19, 0.44) 62%, #0f1213 100%);
    pointer-events: none;
  }

  .section-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(circle at 50% 50%, rgba(105, 210, 84, 0.13), transparent 35rem);
    pointer-events: none;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-background-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.96) contrast(1.04);
    transform: translateY(1.4rem) scale(1.015);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100svh - clamp(14.2rem, 27vh, 17.3rem));
    padding-top: clamp(0.35rem, 1.8vh, 1rem);
    padding-bottom: clamp(0.5rem, 2vh, 1.25rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.15rem, 2.2vh, 1.45rem);
    max-width: min(66rem, 92vw);
    margin: 0 auto;
    text-align: center;
  }

  .hero-heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: min(62rem, 94vw);
    font-size: clamp(4rem, 6.2vw, 7.1rem);
    line-height: 0.92;
    letter-spacing: -0.058em;
    text-wrap: balance;
  }

  .hero-heading-line {
    color: #fff;
  }

  .hero-live-line {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3em;
    width: min(100%, 58rem);
    color: rgba(255, 255, 255, 0.9);
    font-family: "Instrument Serif", Georgia, serif;
    font-size: clamp(1.85rem, 3vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.045em;
    text-wrap: balance;
  }

  .hero-live-prefix {
    flex: 0 0 auto;
  }

  .hero-heading-rotator {
    position: relative;
    display: inline-block;
    width: min(100%, 35rem);
    min-height: 1.22em;
    padding-bottom: 0.14em;
    margin-bottom: -0.08em;
    overflow: hidden;
    vertical-align: bottom;
  }

  .hero-heading-accent {
    position: absolute;
    inset: 0 0 auto 0;
    min-height: 1.14em;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    color: #69D254;
    line-height: 1;
    opacity: 0;
    transform: translateY(0.24em);
    animation: hero-rotate 20s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    white-space: nowrap;
    will-change: opacity, transform;
  }

  .hero-heading-accent:nth-child(2) {
    animation-delay: 4s;
  }

  .hero-heading-accent:nth-child(3) {
    animation-delay: 8s;
  }

  .hero-heading-accent:nth-child(4) {
    animation-delay: 12s;
  }

  .hero-heading-accent:nth-child(5) {
    animation-delay: 16s;
  }

  @keyframes hero-rotate {
    0% {
      opacity: 0;
      transform: translateY(0.24em);
    }

    5%, 17.5% {
      opacity: 1;
      transform: translateY(0);
    }

    20%, 100% {
      opacity: 0;
      transform: translateY(-0.22em);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-heading-accent {
      animation: none;
      opacity: 0;
      transform: none;
    }

    .hero-heading-accent:first-child {
      position: static;
      opacity: 1;
    }
  }

  .hero-description {
    color: rgba(255, 255, 255, 0.86);
    max-width: 54rem;
  }

  .hero-heading-support {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1em;
    font-family: var(--font-body);
    font-size: clamp(1.02rem, 1.28vw, 1.34rem);
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.018em;
    text-wrap: balance;
  }

  .hero-heading-support p {
    margin: 0;
  }

  .hero-price-line {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.86em;
  }

  .button-group {
    display: flex;
    justify-content: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    padding-top: clamp(0.35rem, 1vh, 0.75rem);
  }

  .button-group .button {
    min-height: 3.45rem;
    padding-inline: 1.55rem;
    border-radius: 999px;
    font-size: clamp(0.9rem, 0.95vw, 1rem);
    font-weight: 750;
  }

  .button-group .button.is-secondary {
    color: #ffffff;
    border-color: rgba(105, 210, 84, 0.82);
    background: rgba(15, 18, 19, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }


  @media (max-width: 1180px) {
    .hero-text {
      max-width: min(64rem, 94vw);
    }

    .hero-heading {
      max-width: min(62rem, 94vw);
      font-size: clamp(3.05rem, 6vw, 5.75rem);
    }

    .section-hero::before {
      background:
        radial-gradient(circle at 50% 42%, rgba(4, 6, 6, 0.34) 0%, rgba(4, 6, 6, 0.7) 52%, rgba(4, 6, 6, 0.9) 100%),
        linear-gradient(180deg, rgba(15, 18, 19, 0.14) 0%, rgba(15, 18, 19, 0.24) 58%, #0f1213 100%);
    }
  }

  @media (max-width: 767px) {
    .section-hero {
      min-height: 100svh;
      padding: 7.2rem 0 5.7rem;
    }

    .hero-content {
      min-height: calc(100svh - 12.9rem);
    }

    .hero-background-image {
      object-position: 62% top;
      transform: translateY(1rem) scale(1.02);
    }

    .section-hero::before {
      background:
        linear-gradient(180deg, rgba(4, 6, 6, 0.78) 0%, rgba(4, 6, 6, 0.7) 46%, #0f1213 100%),
        linear-gradient(90deg, rgba(4, 6, 6, 0.78) 0%, rgba(4, 6, 6, 0.3) 100%);
    }

    .hero-text {
      max-width: 100%;
      gap: 1.05rem;
    }

    .hero-heading {
      max-width: 100%;
      font-size: clamp(2.45rem, 10vw, 3.55rem);
    }

    .hero-live-line {
      flex-direction: column;
      gap: 0.08em;
      font-size: clamp(1.55rem, 6.4vw, 2.25rem);
    }

    .hero-heading-rotator {
      width: min(100%, 30rem);
    }

    .hero-description {
      max-width: 34rem;
    }

    .hero-heading-support {
      font-size: clamp(1rem, 4.2vw, 1.25rem);
    }
  }

  @media (max-width: 479px) {
    .section-hero {
      padding-bottom: 5rem;
    }

    .hero-content {
      min-height: calc(100svh - 12.2rem);
    }

    .hero-heading {
      font-size: clamp(2.08rem, 10.6vw, 2.9rem);
      letter-spacing: -0.055em;
    }

    .hero-live-line {
      font-size: clamp(1.35rem, 7vw, 1.85rem);
    }

    .hero-heading-rotator {
      min-height: 1.34em;
    }

    .hero-heading-support {
      font-size: clamp(0.98rem, 4.6vw, 1.16rem);
      letter-spacing: -0.018em;
    }

    .button-group,
    .button-group .button {
      width: 100%;
    }

    .button-group .button {
      justify-content: center;
    }
  }
</style>
