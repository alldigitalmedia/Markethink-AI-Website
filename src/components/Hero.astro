---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";

const capabilities = [
  "Campaigns",
  "Social",
  "Landing pages",
  "Lead lists",
  "CRM follow-up",
  "Approvals",
  "Brand memory",
  "Reporting",
];
---

<section class="section-hero" id="hero">
  <div class="hero-background" aria-hidden="true">
    <img src="/images/hero-office-background.svg" alt="" class="hero-background-image" />
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <p class="hero-kicker animate-fade-up">One connected marketing system</p>
      <h1 class="hero-heading animate-fade-up">
        Marketing that ships and keeps getting sharper.
      </h1>
      <p class="hero-description animate-fade-up">
        Markethink learns your business, organizes your campaigns, creates the work, and brings the right decisions back for approval. So your marketing stops restarting from zero every week.
      </p>
      <div class="button-group animate-fade-up">
        <a href={walkthroughHref} class="button">Book a Walkthrough</a>
        <a href={trialHref} class="button is-secondary">Apply for a 30-Day Trial</a>
      </div>
    </div>
    <div class="capability-strip animate-fade-up" aria-label="Markethink capabilities">
      <div class="capability-track">
        {[...capabilities, ...capabilities].map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 9.5rem 0 4.5rem;
    background: #0f1213;
  }

  .section-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(4, 6, 6, 0.94) 0%, rgba(4, 6, 6, 0.78) 24%, rgba(4, 6, 6, 0.34) 48%, rgba(4, 6, 6, 0.04) 78%),
      linear-gradient(180deg, rgba(15, 18, 19, 0.1) 0%, rgba(15, 18, 19, 0.14) 58%, #0f1213 100%);
    pointer-events: none;
  }

  .section-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(circle at 23% 50%, rgba(105, 210, 84, 0.12), transparent 32rem);
    pointer-events: none;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-background-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.96) contrast(1.04);
    transform: translateY(1.4rem) scale(1.015);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - 14rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.45rem;
    max-width: min(48rem, 52vw);
    text-align: left;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 2.3rem;
    padding: 0 0.9rem;
    border: 1px solid rgba(105, 210, 84, 0.35);
    border-radius: var(--radius-button);
    background: rgba(15, 18, 19, 0.38);
    color: #edf4ea;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero-heading {
    max-width: min(50rem, 55vw);
    color: #fff;
    font-size: clamp(4.15rem, 6.1vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.058em;
    text-wrap: balance;
  }

  .hero-heading::after {
    content: "";
    display: block;
    width: 7rem;
    height: 0.3rem;
    margin-top: 1.15rem;
    border-radius: 999px;
    background: #69d254;
  }

  .hero-description {
    font-size: clamp(1.03rem, 1.35vw, 1.35rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 43rem;
    line-height: 1.62;
  }

  .button-group {
    display: flex;
    justify-content: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .button-group .button {
    min-height: 3.9rem;
    padding-inline: 1.75rem;
    border-radius: 999px;
    font-size: clamp(0.98rem, 1.05vw, 1.15rem);
    font-weight: 750;
  }

  .button-group .button.is-secondary {
    color: #ffffff;
    border-color: rgba(105, 210, 84, 0.82);
    background: rgba(15, 18, 19, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .capability-strip {
    position: relative;
    width: min(100%, 64rem);
    margin-top: 3rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-button);
    background: rgba(15, 18, 19, 0.34);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    mask-image: linear-gradient(90deg, transparent 0, black 9%, black 91%, transparent 100%);
  }

  .capability-track {
    display: flex;
    width: max-content;
    gap: 0.65rem;
    padding: 0.72rem;
    animation: capability-scroll 32s linear infinite;
  }

  .capability-track span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0 1rem;
    border-radius: var(--radius-button);
    background: rgba(245, 245, 241, 0.08);
    color: rgba(245, 245, 241, 0.84);
    font-size: 0.82rem;
    font-weight: 650;
    white-space: nowrap;
  }

  @keyframes capability-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .capability-track {
      animation: none;
    }
  }

  @media (max-width: 1180px) {
    .hero-text {
      max-width: 54rem;
    }

    .hero-heading {
      max-width: min(56rem, 94vw);
      font-size: clamp(3.35rem, 7vw, 5.6rem);
    }

    .section-hero::before {
      background:
        linear-gradient(90deg, rgba(4, 6, 6, 0.92) 0%, rgba(4, 6, 6, 0.74) 38%, rgba(4, 6, 6, 0.22) 72%),
        linear-gradient(180deg, rgba(15, 18, 19, 0.1) 0%, rgba(15, 18, 19, 0.18) 58%, #0f1213 100%);
    }
  }

  @media (max-width: 767px) {
    .section-hero {
      min-height: auto;
      padding: 7.8rem 0 3.5rem;
    }

    .hero-content {
      min-height: 36rem;
    }

    .hero-background-image {
      object-position: 62% top;
      transform: translateY(1rem) scale(1.02);
    }

    .section-hero::before {
      background:
        linear-gradient(180deg, rgba(4, 6, 6, 0.78) 0%, rgba(4, 6, 6, 0.7) 46%, #0f1213 100%),
        linear-gradient(90deg, rgba(4, 6, 6, 0.78) 0%, rgba(4, 6, 6, 0.3) 100%);
    }

    .hero-text {
      max-width: 100%;
      gap: 1.25rem;
    }

    .hero-heading {
      max-width: 100%;
      font-size: clamp(2.72rem, 11vw, 4rem);
    }

    .hero-description {
      font-size: 1rem;
      max-width: 34rem;
    }

    .capability-strip {
      margin-top: 2.25rem;
    }
  }

  @media (max-width: 479px) {
    .section-hero {
      padding-bottom: 3rem;
    }

    .hero-content {
      min-height: 33rem;
    }

    .hero-heading {
      font-size: clamp(2.34rem, 11.4vw, 3.2rem);
      letter-spacing: -0.052em;
    }

    .button-group,
    .button-group .button {
      width: 100%;
    }

    .button-group .button {
      justify-content: center;
    }
  }
</style>
