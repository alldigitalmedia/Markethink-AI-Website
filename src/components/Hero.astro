---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";
---

<section class="section-hero" id="hero">
  <div class="hero-orb hero-orb-one" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-two" aria-hidden="true"></div>
  <div class="container hero-content">
    <div class="hero-copy">
      <p class="hero-kicker">AI marketing system · human reviewed</p>
      <h1 class="hero-heading" aria-label="Your marketing should work as hard as you do.">
        <span>Your marketing should work</span>
        <span>as hard as you do.</span>
      </h1>
      <p class="hero-description">
        An AI marketing operator keeps campaigns, posts, landing pages, and follow-up moving around the clock. A real marketer reviews what ships. You approve from your phone.
      </p>
      <div class="button-group">
        <a href={walkthroughHref} class="button">Watch it work on your business →</a>
        <a href={trialHref} class="button is-secondary">Apply for a 30-Day Trial</a>
      </div>
    </div>

    <div class="hero-visual" aria-label="Animated Markethink phone chat showing campaign, landing page, social, and lead follow-up work.">
      <div class="floating-card card-top-left">
        <span class="card-label">Campaign</span>
        <strong>Organized</strong>
      </div>
      <div class="floating-card card-top-right">
        <span class="card-label">Approval</span>
        <strong>Ready</strong>
      </div>
      <div class="floating-card card-bottom-left">
        <span class="card-label">Follow-up</span>
        <strong>Drafted</strong>
      </div>

      <div class="phone-shell">
        <div class="phone-glass">
          <div class="phone-notch" aria-hidden="true"></div>
          <div class="phone-topbar">
            <div>
              <span class="phone-eyebrow">Markethink</span>
              <strong>Live marketing desk</strong>
            </div>
            <span class="phone-live"><span></span>Live</span>
          </div>

          <div class="phone-screen" aria-hidden="true">
            <div class="chat-scene scene-campaign">
              <div class="chat-bubble user-bubble">
                <span>You</span>
                <p>Launch a campaign for the new service.</p>
              </div>
              <div class="chat-bubble ai-bubble">
                <span>AI operator</span>
                <p>Campaign map ready: landing page, posts, email, and lead follow-up.</p>
              </div>
              <div class="chat-bubble marketer-bubble">
                <span>Dedicated marketer</span>
                <p>Reviewed. Sending the first assets for approval.</p>
              </div>
            </div>

            <div class="chat-scene scene-landing">
              <div class="chat-bubble user-bubble">
                <span>You</span>
                <p>We need Friday’s landing page ready.</p>
              </div>
              <div class="chat-bubble ai-bubble">
                <span>AI operator</span>
                <p>Hero, CTA, form copy, and sections are drafted.</p>
              </div>
              <div class="chat-bubble marketer-bubble">
                <span>Dedicated marketer</span>
                <p>Polished. Ready for phone approval.</p>
              </div>
            </div>

            <div class="chat-scene scene-social">
              <div class="chat-bubble user-bubble">
                <span>You</span>
                <p>Turn this idea into social posts.</p>
              </div>
              <div class="chat-bubble ai-bubble">
                <span>AI operator</span>
                <p>3 branded posts and captions are ready.</p>
              </div>
              <div class="chat-bubble marketer-bubble">
                <span>Dedicated marketer</span>
                <p>Post one today. Queue the next two.</p>
              </div>
            </div>

            <div class="chat-scene scene-lead">
              <div class="chat-bubble user-bubble">
                <span>Customer lead</span>
                <p>Can someone send details tonight?</p>
              </div>
              <div class="chat-bubble ai-bubble">
                <span>AI operator</span>
                <p>Reply drafted with the right offer and next step.</p>
              </div>
              <div class="chat-bubble marketer-bubble">
                <span>Dedicated marketer</span>
                <p>Approved. Follow-up is scheduled.</p>
              </div>
            </div>
          </div>

          <div class="phone-dock">
            <span>Campaign</span>
            <span>Posts</span>
            <span>Leads</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(8.4rem, 15vh, 9.8rem) 0 clamp(4.8rem, 8vh, 6.2rem);
    background:
      radial-gradient(circle at 82% 24%, rgba(105, 210, 84, 0.18), transparent 24rem),
      radial-gradient(circle at 12% 86%, rgba(15, 18, 19, 0.08), transparent 24rem),
      linear-gradient(135deg, #f5f5f1 0%, #edf4ea 54%, #f8f8f3 100%);
    color: #0f1213;
  }

  .section-hero::before {
    content: "";
    position: absolute;
    inset: 1.25rem;
    z-index: -1;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: clamp(1.6rem, 3vw, 3rem);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.54), rgba(255, 255, 255, 0.18));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
    pointer-events: none;
  }

  .hero-orb {
    position: absolute;
    z-index: -1;
    border-radius: 999px;
    filter: blur(14px);
    pointer-events: none;
  }

  .hero-orb-one {
    width: 24rem;
    height: 24rem;
    right: 6vw;
    top: 18vh;
    background: rgba(105, 210, 84, 0.18);
  }

  .hero-orb-two {
    width: 16rem;
    height: 16rem;
    left: 8vw;
    bottom: 12vh;
    background: rgba(15, 18, 19, 0.08);
  }

  .hero-content {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(22rem, 0.88fr);
    align-items: center;
    gap: clamp(2.2rem, 5vw, 5rem);
    width: min(1120px, calc(100% - 2rem));
  }

  .hero-copy {
    max-width: 38rem;
    text-align: left;
  }

  .hero-kicker {
    margin: 0 0 1.05rem;
    color: rgba(15, 18, 19, 0.58);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .hero-heading {
    display: flex;
    flex-direction: column;
    gap: 0.02em;
    margin: 0;
    max-width: 44rem;
    font-size: clamp(3.4rem, 6.6vw, 7rem);
    line-height: 0.9;
    letter-spacing: -0.062em;
    color: #0f1213;
    text-wrap: balance;
  }

  .hero-description {
    max-width: 35rem;
    margin: clamp(1.3rem, 2.2vw, 1.8rem) 0 0;
    color: rgba(15, 18, 19, 0.72);
    font-size: clamp(1rem, 1.12vw, 1.18rem);
    font-weight: 500;
    line-height: 1.58;
    letter-spacing: -0.018em;
  }

  .button-group {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: clamp(1.45rem, 2.4vw, 2rem);
  }

  .button-group .button {
    min-height: 3.35rem;
    padding-inline: 1.45rem;
    border-radius: 999px;
    font-size: clamp(0.9rem, 0.95vw, 1rem);
    font-weight: 750;
  }

  .button-group .button.is-secondary {
    color: #0f1213;
    border-color: rgba(15, 18, 19, 0.2);
    background: rgba(255, 255, 255, 0.36);
    box-shadow: none;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .hero-visual {
    position: relative;
    display: grid;
    place-items: center;
    min-height: clamp(29rem, 62vh, 42rem);
  }

  .phone-shell {
    position: relative;
    width: min(100%, 22.5rem);
    transform: rotate(-3deg);
    filter: drop-shadow(0 34px 70px rgba(15, 18, 19, 0.24));
  }

  .phone-shell::before {
    content: "";
    position: absolute;
    inset: 8% -10% -4% 10%;
    z-index: -1;
    border-radius: 3.2rem;
    background: rgba(105, 210, 84, 0.2);
    filter: blur(28px);
  }

  .phone-glass {
    position: relative;
    overflow: hidden;
    min-height: 35rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.48);
    border-radius: 3rem;
    background:
      linear-gradient(145deg, rgba(15, 18, 19, 0.96), rgba(15, 18, 19, 0.78)),
      #0f1213;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.32),
      inset 0 -28px 70px rgba(105, 210, 84, 0.08),
      0 22px 52px rgba(15, 18, 19, 0.24);
    color: #f5f5f1;
  }

  .phone-glass::before {
    content: "";
    position: absolute;
    inset: -18% -30% auto auto;
    width: 15rem;
    height: 15rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(105, 210, 84, 0.34), transparent 64%);
    pointer-events: none;
  }

  .phone-notch {
    position: absolute;
    top: 0.72rem;
    left: 50%;
    z-index: 4;
    width: 5.4rem;
    height: 1.25rem;
    border-radius: 999px;
    background: #050606;
    transform: translateX(-50%);
  }

  .phone-topbar {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding: 2.1rem 0.55rem 0.8rem;
    text-align: left;
  }

  .phone-eyebrow {
    display: block;
    color: rgba(245, 245, 241, 0.52);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
  }

  .phone-topbar strong {
    display: block;
    margin-top: 0.18rem;
    color: #f5f5f1;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.1;
  }

  .phone-live {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    padding: 0.42rem 0.62rem;
    border: 1px solid rgba(105, 210, 84, 0.26);
    border-radius: 999px;
    background: rgba(105, 210, 84, 0.1);
    color: #69D254;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .phone-live span {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: #69D254;
    box-shadow: 0 0 0 0.22rem rgba(105, 210, 84, 0.16);
  }

  .phone-screen {
    position: relative;
    min-height: 24.6rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2.05rem;
    background:
      radial-gradient(circle at 86% 8%, rgba(105, 210, 84, 0.22), transparent 12rem),
      linear-gradient(180deg, rgba(245, 245, 241, 0.08), rgba(245, 245, 241, 0.03));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .chat-scene {
    position: absolute;
    inset: 1rem;
    display: grid;
    align-content: start;
    gap: 0.7rem;
    opacity: 0;
    transform: translateY(0.5rem) scale(0.992);
    animation: scene-cycle 40s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  .scene-landing { animation-delay: 10s; }
  .scene-social { animation-delay: 20s; }
  .scene-lead { animation-delay: 30s; }

  .chat-bubble {
    width: fit-content;
    max-width: 86%;
    padding: 0.76rem 0.88rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1.18rem;
    background: rgba(245, 245, 241, 0.1);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    color: rgba(245, 245, 241, 0.92);
    text-align: left;
    opacity: 0;
    transform: translateY(0.58rem) scale(0.985);
    animation: message-pop 40s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  .chat-bubble:nth-child(2) { animation-delay: 1.55s; }
  .chat-bubble:nth-child(3) { animation-delay: 3.1s; }
  .scene-landing .chat-bubble:nth-child(1) { animation-delay: 10s; }
  .scene-landing .chat-bubble:nth-child(2) { animation-delay: 11.55s; }
  .scene-landing .chat-bubble:nth-child(3) { animation-delay: 13.1s; }
  .scene-social .chat-bubble:nth-child(1) { animation-delay: 20s; }
  .scene-social .chat-bubble:nth-child(2) { animation-delay: 21.55s; }
  .scene-social .chat-bubble:nth-child(3) { animation-delay: 23.1s; }
  .scene-lead .chat-bubble:nth-child(1) { animation-delay: 30s; }
  .scene-lead .chat-bubble:nth-child(2) { animation-delay: 31.55s; }
  .scene-lead .chat-bubble:nth-child(3) { animation-delay: 33.1s; }

  .user-bubble,
  .marketer-bubble {
    justify-self: start;
    border-bottom-left-radius: 0.42rem;
  }

  .ai-bubble {
    justify-self: end;
    border-color: rgba(105, 210, 84, 0.34);
    border-bottom-right-radius: 0.42rem;
    background: linear-gradient(135deg, rgba(105, 210, 84, 0.24), rgba(105, 210, 84, 0.08));
  }

  .chat-bubble span {
    display: block;
    margin-bottom: 0.28rem;
    color: rgba(245, 245, 241, 0.52);
    font-size: 0.64rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .chat-bubble p {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 1vw, 0.95rem);
    font-weight: 650;
    line-height: 1.33;
    letter-spacing: -0.02em;
  }

  .phone-dock {
    display: flex;
    gap: 0.46rem;
    padding: 0.75rem 0.2rem 0;
  }

  .phone-dock span {
    flex: 1;
    padding: 0.56rem 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(245, 245, 241, 0.06);
    color: rgba(245, 245, 241, 0.66);
    font-size: 0.68rem;
    font-weight: 800;
    text-align: center;
  }

  .floating-card {
    position: absolute;
    z-index: 3;
    width: 9.6rem;
    padding: 0.86rem 0.92rem;
    border: 1px solid rgba(15, 18, 19, 0.1);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 18px 45px rgba(15, 18, 19, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px) saturate(1.12);
    -webkit-backdrop-filter: blur(16px) saturate(1.12);
    color: #0f1213;
    text-align: left;
    animation: float-card 8s ease-in-out infinite;
  }

  .card-label {
    display: block;
    margin-bottom: 0.25rem;
    color: rgba(15, 18, 19, 0.52);
    font-size: 0.66rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .floating-card strong {
    display: block;
    color: #0f1213;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.05;
  }

  .floating-card::after {
    content: "";
    position: absolute;
    top: 0.78rem;
    right: 0.78rem;
    width: 0.46rem;
    height: 0.46rem;
    border-radius: 999px;
    background: #69D254;
    box-shadow: 0 0 0 0.22rem rgba(105, 210, 84, 0.16);
  }

  .card-top-left {
    top: 10%;
    left: 0;
    transform: rotate(-4deg);
  }

  .card-top-right {
    top: 18%;
    right: -0.8rem;
    animation-delay: -2s;
    transform: rotate(4deg);
  }

  .card-bottom-left {
    bottom: 13%;
    left: -1rem;
    animation-delay: -4s;
    transform: rotate(3deg);
  }

  @keyframes float-card {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.75rem; }
  }

  @keyframes scene-cycle {
    0%, 4% {
      opacity: 0;
      transform: translateY(0.5rem) scale(0.992);
    }
    5%, 23% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    25%, 100% {
      opacity: 0;
      transform: translateY(-0.28rem) scale(0.996);
    }
  }

  @keyframes message-pop {
    0%, 2% {
      opacity: 0;
      transform: translateY(0.58rem) scale(0.985);
    }
    4%, 23% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    25%, 100% {
      opacity: 0;
      transform: translateY(-0.18rem) scale(0.995);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-scene,
    .chat-bubble,
    .floating-card {
      animation: none;
      transform: none;
      translate: none;
    }

    .chat-scene {
      opacity: 0;
    }

    .chat-scene:first-child,
    .chat-scene:first-child .chat-bubble {
      opacity: 1;
    }
  }

  @media (max-width: 980px) {
    .section-hero {
      padding-top: 8.25rem;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 2.6rem;
    }

    .hero-copy {
      max-width: 44rem;
      margin: 0 auto;
      text-align: center;
    }

    .hero-description {
      margin-inline: auto;
    }

    .button-group {
      justify-content: center;
    }

    .hero-visual {
      min-height: 34rem;
    }
  }

  @media (max-width: 640px) {
    .section-hero {
      padding: 7.6rem 0 4.2rem;
    }

    .section-hero::before {
      inset: 0.65rem;
      border-radius: 1.5rem;
    }

    .hero-heading {
      font-size: clamp(2.45rem, 12vw, 4.1rem);
    }

    .hero-description {
      font-size: 0.98rem;
    }

    .button-group,
    .button-group .button {
      width: 100%;
    }

    .button-group .button {
      justify-content: center;
    }

    .hero-visual {
      min-height: 31rem;
    }

    .phone-shell {
      width: min(100%, 19rem);
      transform: rotate(-2deg);
    }

    .phone-glass {
      min-height: 31rem;
      border-radius: 2.4rem;
      padding: 0.78rem;
    }

    .phone-screen {
      min-height: 21.5rem;
      border-radius: 1.65rem;
    }

    .chat-bubble {
      max-width: 90%;
      padding: 0.66rem 0.72rem;
    }

    .chat-bubble p {
      font-size: 0.78rem;
    }

    .floating-card {
      width: 8.2rem;
      padding: 0.72rem 0.78rem;
    }

    .card-top-left {
      left: -0.25rem;
      top: 6%;
    }

    .card-top-right {
      right: -0.45rem;
      top: 14%;
    }

    .card-bottom-left {
      left: 0;
      bottom: 6%;
    }
  }
</style>
