---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";
---

<section class="section-hero" id="hero">
  <div class="hero-background" aria-hidden="true">
    <img src="/images/hero-office-background.svg" alt="" class="hero-background-image" />
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-heading animate-fade-up" aria-label="The marketing system that ships the work.">
        <span class="hero-heading-line">The marketing system that</span>
        <span class="hero-heading-rotator" aria-hidden="true">
          <span class="hero-heading-accent">ships the work.</span>
          <span class="hero-heading-accent">learns your brand.</span>
          <span class="hero-heading-accent">keeps campaigns moving.</span>
          <span class="hero-heading-accent">remembers what worked.</span>
          <span class="hero-heading-accent">finds the next opportunity.</span>
        </span>
      </h1>
      <p class="hero-description animate-fade-up">
        Markethink helps brands plan campaigns, create content that connects, manage approvals with ease, and keep marketing moving — so nothing slows you down.
      </p>
      <div class="button-group animate-fade-up">
        <a href={walkthroughHref} class="button">Book a Walkthrough</a>
        <a href={trialHref} class="button is-secondary">Apply for a 30-Day Trial</a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 9.5rem 0 4.5rem;
    background: #0f1213;
  }

  .section-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(4, 6, 6, 0.94) 0%, rgba(4, 6, 6, 0.78) 24%, rgba(4, 6, 6, 0.34) 48%, rgba(4, 6, 6, 0.04) 78%),
      linear-gradient(180deg, rgba(15, 18, 19, 0.1) 0%, rgba(15, 18, 19, 0.14) 58%, #0f1213 100%);
    pointer-events: none;
  }

  .section-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(circle at 23% 50%, rgba(105, 210, 84, 0.1), transparent 32rem);
    pointer-events: none;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-background-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.96) contrast(1.04);
    transform: translateY(1.4rem) scale(1.015);
  }

  .hero-content {
    display: flex;
    align-items: center;
    min-height: calc(100vh - 14rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.65rem;
    max-width: min(43rem, 48vw);
    text-align: left;
  }

  .hero-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: min(46rem, 52vw);
    font-size: clamp(4.4rem, 6.35vw, 7.4rem);
    line-height: 0.88;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  .hero-heading-line {
    color: #fff;
  }

  .hero-heading-rotator {
    position: relative;
    display: block;
    width: 100%;
    min-height: 1.02em;
    overflow: hidden;
  }

  .hero-heading-accent {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    color: #69D254;
    opacity: 0;
    transform: translateY(0.24em);
    animation: hero-rotate 20s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    white-space: nowrap;
    will-change: opacity, transform;
  }

  .hero-heading-accent:nth-child(2) {
    animation-delay: 4s;
  }

  .hero-heading-accent:nth-child(3) {
    animation-delay: 8s;
  }

  .hero-heading-accent:nth-child(4) {
    animation-delay: 12s;
  }

  .hero-heading-accent:nth-child(5) {
    animation-delay: 16s;
  }

  @keyframes hero-rotate {
    0% {
      opacity: 0;
      transform: translateY(0.24em);
    }

    4%, 18% {
      opacity: 1;
      transform: translateY(0);
    }

    22%, 100% {
      opacity: 0;
      transform: translateY(-0.22em);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-heading-accent {
      animation: none;
      opacity: 0;
      transform: none;
    }

    .hero-heading-accent:first-child {
      position: static;
      opacity: 1;
    }
  }

  .hero-description {
    font-size: clamp(1.03rem, 1.35vw, 1.35rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 42rem;
    line-height: 1.62;
  }

  .button-group {
    display: flex;
    justify-content: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .button-group .button {
    min-height: 3.9rem;
    padding-inline: 1.75rem;
    border-radius: 999px;
    font-size: clamp(0.98rem, 1.05vw, 1.15rem);
    font-weight: 750;
  }

  .button-group .button.is-secondary {
    color: #ffffff;
    border-color: rgba(105, 210, 84, 0.82);
    background: rgba(15, 18, 19, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  @media (max-width: 1180px) {
    .hero-text {
      max-width: 54rem;
    }

    .hero-heading {
      max-width: 56rem;
      font-size: clamp(3.3rem, 7.8vw, 6rem);
    }

    .section-hero::before {
      background:
        linear-gradient(90deg, rgba(4, 6, 6, 0.92) 0%, rgba(4, 6, 6, 0.74) 38%, rgba(4, 6, 6, 0.22) 72%),
        linear-gradient(180deg, rgba(15, 18, 19, 0.1) 0%, rgba(15, 18, 19, 0.18) 58%, #0f1213 100%);
    }
  }

  @media (max-width: 767px) {
    .section-hero {
      min-height: auto;
      padding: 7.8rem 0 3.5rem;
    }

    .hero-content {
      min-height: 36rem;
    }

    .hero-background-image {
      object-position: 62% top;
      transform: translateY(1rem) scale(1.02);
    }

    .section-hero::before {
      background:
        linear-gradient(180deg, rgba(4, 6, 6, 0.72) 0%, rgba(4, 6, 6, 0.66) 46%, #0f1213 100%),
        linear-gradient(90deg, rgba(4, 6, 6, 0.78) 0%, rgba(4, 6, 6, 0.3) 100%);
    }

    .hero-text {
      max-width: 100%;
      gap: 1.25rem;
    }

    .hero-heading {
      max-width: 100%;
      font-size: clamp(2.6rem, 12vw, 4.2rem);
    }

    .hero-description {
      font-size: 1rem;
      max-width: 34rem;
    }
  }

  @media (max-width: 479px) {
    .section-hero {
      padding-bottom: 3rem;
    }

    .hero-content {
      min-height: 33rem;
    }

    .hero-heading {
      font-size: clamp(2.18rem, 11.2vw, 3rem);
      letter-spacing: -0.055em;
    }

    .hero-heading-accent {
      white-space: normal;
    }

    .button-group,
    .button-group .button {
      width: 100%;
    }

    .button-group .button {
      justify-content: center;
    }
  }
</style>
