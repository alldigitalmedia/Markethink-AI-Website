---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";
---

<section class="section-hero" id="hero">
  <div class="hero-backdrop" aria-hidden="true">
    <img src="/images/hero-image.png" alt="" class="hero-backdrop-image" />
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-heading animate-fade-up" aria-label="The marketing system that ships the work.">
        <span class="hero-heading-line">The marketing system that</span>
        <span class="hero-heading-rotator" aria-hidden="true">
          <span class="hero-heading-accent">ships the work.</span>
          <span class="hero-heading-accent">learns your brand.</span>
          <span class="hero-heading-accent">keeps campaigns moving.</span>
          <span class="hero-heading-accent">remembers what worked.</span>
          <span class="hero-heading-accent">finds the next opportunity.</span>
        </span>
      </h1>
      <p class="hero-description animate-fade-up">
        Markethink learns your brand, understands your ideal clients, plans campaigns, creates content and visuals, organizes approvals, finds opportunities, and keeps the next move clear — so the marketing you meant to do actually gets done.
      </p>
      <div class="button-group animate-fade-up">
        <a href={walkthroughHref} class="button">Book a Walkthrough</a>
        <a href={trialHref} class="button is-secondary">Apply for a 30-Day Trial</a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .section-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      radial-gradient(circle at 50% 18%, rgba(105, 210, 84, 0.16), transparent 30rem),
      linear-gradient(180deg, rgba(15, 18, 19, 0.2) 0%, #0f1213 86%);
  }

  .section-hero::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 2.75rem;
    z-index: -1;
    width: min(840px, 82vw);
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(90deg, transparent, rgba(105, 210, 84, 0.48), transparent);
    opacity: 0.7;
  }

  .hero-backdrop {
    position: absolute;
    inset: 6rem 0 auto;
    z-index: -2;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }

  .hero-backdrop-image {
    width: min(1040px, 90vw);
    max-height: 600px;
    object-fit: contain;
    opacity: 0.18;
    filter: saturate(0.78) contrast(1.08);
    transform: translate(18%, 1rem) scale(1.08);
    mask-image: radial-gradient(circle at 62% 42%, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.5) 34%, transparent 72%);
    -webkit-mask-image: radial-gradient(circle at 62% 42%, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.5) 34%, transparent 72%);
  }

  .hero-content {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 12rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 58rem;
    margin: 0 auto;
    text-align: center;
  }

  .hero-heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: min(72rem, 96vw);
    font-size: clamp(3rem, 6.25vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.065em;
  }

  .hero-heading-line {
    color: #fff;
    white-space: nowrap;
  }

  .hero-heading-rotator {
    position: relative;
    display: block;
    width: 100%;
    min-height: 1.08em;
    overflow: hidden;
  }

  .hero-heading-accent {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #69D254;
    opacity: 0;
    transform: translateY(0.24em);
    animation: hero-rotate 17.5s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    white-space: nowrap;
    will-change: opacity, transform;
  }

  .hero-heading-accent:nth-child(2) {
    animation-delay: 3.5s;
  }

  .hero-heading-accent:nth-child(3) {
    animation-delay: 7s;
  }

  .hero-heading-accent:nth-child(4) {
    animation-delay: 10.5s;
  }

  .hero-heading-accent:nth-child(5) {
    animation-delay: 14s;
  }

  @keyframes hero-rotate {
    0% {
      opacity: 0;
      transform: translateY(0.24em);
    }

    4%, 18% {
      opacity: 1;
      transform: translateY(0);
    }

    22%, 100% {
      opacity: 0;
      transform: translateY(-0.22em);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-heading-accent {
      animation: none;
      opacity: 0;
      transform: none;
    }

    .hero-heading-accent:first-child {
      position: static;
      opacity: 1;
    }
  }

  .hero-description {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: rgba(255, 255, 255, 0.76);
    max-width: 47rem;
    line-height: 1.7;
  }

  .button-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 991px) {
    .section-hero {
      padding-top: 7rem;
    }

    .hero-backdrop-image {
      width: 110vw;
      opacity: 0.14;
      transform: translate(10%, 2rem) scale(1.06);
    }
  }

  @media (max-width: 767px) {
    .section-hero {
      padding-top: 7rem;
      min-height: auto;
    }

    .hero-content {
      min-height: 34rem;
    }

    .hero-text {
      gap: 1.25rem;
    }

    .hero-heading {
      font-size: clamp(2.15rem, 9vw, 3.6rem);
      max-width: 96vw;
    }

    .hero-description {
      font-size: 1rem;
    }
  }

  @media (max-width: 479px) {
    .section-hero {
      padding-bottom: 3rem;
    }

    .hero-content {
      min-height: 31rem;
    }

    .hero-heading {
      font-size: clamp(1.55rem, 7.2vw, 2.05rem);
    }

    .hero-backdrop-image {
      width: 140vw;
      opacity: 0.12;
      transform: translate(8%, 4rem) scale(1.12);
    }
  }
</style>
