---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";
---

<section class="section-hero" id="hero">
  <div class="hero-plant-blur" aria-hidden="true"></div>
  <div class="container hero-content">
    <div class="hero-copy">
      <p class="hero-kicker"><span aria-hidden="true">✦</span> AI-powered marketing operations</p>
      <h1 class="hero-heading" aria-label="Your marketing should work as hard as you do.">
        Your marketing should<br />work <em>as hard</em> as you do.
      </h1>
      <p class="hero-description">
        An AI marketing operator does the work around the clock.<br />
        A real marketer dedicated to your business reviews what ships.<br />
        You approve from your phone.
      </p>
      <div class="button-group">
        <a href={walkthroughHref} class="button">Book a Walkthrough →</a>
        <a href={trialHref} class="button is-secondary"><span aria-hidden="true">▶</span> Watch it work on your business</a>
      </div>
    </div>

    <div class="hero-visual" aria-label="Markethink phone workflow preview">
      <div class="phone-video-card">
        <img
          src="https://dashboard.markethink.ai/generated/social/markethink/mt-home-hero-phone-video-20260703234443.webp"
          alt="A phone mockup showing Markethink coordinating a request between the business owner, AI operator, dedicated marketer, and approval step."
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(8.2rem, 14vh, 9.4rem) 0 clamp(4.2rem, 7vh, 5.5rem);
    background:
      radial-gradient(circle at 86% 28%, rgba(105, 210, 84, 0.16), transparent 24rem),
      linear-gradient(90deg, #ffffff 0%, #fbfbf6 52%, #edf4ea 100%);
    color: #0f1213;
  }

  .section-hero::after {
    content: "";
    position: absolute;
    inset: auto -8rem -12rem auto;
    z-index: -1;
    width: 38rem;
    height: 38rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(105, 210, 84, 0.15), transparent 68%);
    pointer-events: none;
  }

  .hero-plant-blur {
    position: absolute;
    right: -2rem;
    top: 0;
    z-index: -1;
    width: min(26vw, 22rem);
    height: 100%;
    opacity: 0.28;
    background:
      linear-gradient(110deg, transparent 0 36%, rgba(15, 18, 19, 0.12) 37% 39%, transparent 40% 100%),
      linear-gradient(80deg, transparent 0 54%, rgba(105, 210, 84, 0.18) 55% 58%, transparent 59% 100%),
      linear-gradient(130deg, transparent 0 62%, rgba(15, 18, 19, 0.11) 63% 65%, transparent 66% 100%);
    filter: blur(6px);
    pointer-events: none;
  }

  .hero-content {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(32rem, 0.98fr);
    align-items: center;
    gap: clamp(2.25rem, 5vw, 5rem);
    width: min(1180px, calc(100% - 2rem));
  }

  .hero-copy {
    max-width: 43rem;
    text-align: left;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    margin: 0 0 1.25rem;
    padding: 0.52rem 0.78rem;
    border: 1px solid rgba(105, 210, 84, 0.22);
    border-radius: 999px;
    background: rgba(105, 210, 84, 0.06);
    color: #3cae32;
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.11em;
    line-height: 1;
    text-transform: uppercase;
  }

  .hero-heading {
    margin: 0;
    max-width: 46rem;
    color: #0a0d0e;
    font-size: clamp(3.8rem, 6.45vw, 6.9rem);
    line-height: 0.94;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .hero-heading em {
    color: #43b83d;
    font-style: italic;
    letter-spacing: -0.055em;
  }

  .hero-description {
    margin: clamp(1.3rem, 2vw, 1.7rem) 0 0;
    color: rgba(15, 18, 19, 0.68);
    font-size: clamp(1.02rem, 1.16vw, 1.18rem);
    font-weight: 500;
    line-height: 1.55;
    letter-spacing: -0.016em;
  }

  .button-group {
    display: flex;
    align-items: center;
    gap: 0.95rem;
    flex-wrap: wrap;
    margin-top: clamp(1.65rem, 2.55vw, 2.15rem);
  }

  .button-group .button {
    min-height: 3.55rem;
    padding-inline: 1.65rem;
    border-radius: 0.95rem;
    font-size: 0.95rem;
    font-weight: 800;
  }

  .button-group .button.is-secondary {
    gap: 0.72rem;
    color: #0f1213;
    border-color: rgba(15, 18, 19, 0.12);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 12px 28px rgba(15, 18, 19, 0.06);
  }

  .button-group .button.is-secondary span {
    display: inline-grid;
    place-items: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    background: #0f1213;
    color: #f5f5f1;
    font-size: 0.58rem;
    line-height: 1;
  }

  .hero-visual {
    position: relative;
    display: grid;
    place-items: center;
    min-height: clamp(34rem, 66vh, 42rem);
  }

  .phone-video-card {
    position: relative;
    width: min(100%, 39rem);
    padding: 0.75rem;
    border: 1px solid rgba(15, 18, 19, 0.08);
    border-radius: 2.25rem;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 28px 70px rgba(15, 18, 19, 0.13), inset 0 1px 0 rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px) saturate(1.08);
    -webkit-backdrop-filter: blur(18px) saturate(1.08);
  }

  .phone-video-card::before {
    content: "";
    position: absolute;
    inset: 8% -8% -8% 22%;
    z-index: -1;
    border-radius: 999px;
    background: rgba(105, 210, 84, 0.18);
    filter: blur(34px);
    pointer-events: none;
  }

  .phone-video-card img {
    width: 100%;
    display: block;
    border-radius: 1.7rem;
    box-shadow: 0 18px 48px rgba(15, 18, 19, 0.12);
  }

  @media (max-width: 1100px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-copy {
      max-width: 50rem;
      margin: 0 auto;
      text-align: center;
    }

    .button-group {
      justify-content: center;
    }

  }

  @media (max-width: 760px) {
    .section-hero {
      padding: 7.4rem 0 4rem;
    }

    .hero-heading {
      font-size: clamp(2.7rem, 12vw, 4.4rem);
    }

    .hero-description br {
      display: none;
    }

    .button-group,
    .button-group .button {
      width: 100%;
    }

    .button-group .button {
      justify-content: center;
    }

    .hero-visual {
      min-height: auto;
    }

    .phone-video-card {
      width: min(100%, 34rem);
      border-radius: 1.8rem;
      padding: 0.52rem;
    }

    .phone-video-card img {
      border-radius: 1.35rem;
    }
  }

  @media (max-width: 480px) {
    .hero-kicker {
      font-size: 0.62rem;
    }

  }
</style>
