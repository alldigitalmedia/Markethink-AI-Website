---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";

const capabilities = [
  "Campaigns",
  "Social",
  "Landing pages",
  "Lead lists",
  "CRM follow-up",
  "Approvals",
  "Brand memory",
  "Reporting",
];
---

<section class="section-hero" id="hero">
  <div class="hero-background" aria-hidden="true">
    <img src="/images/hero-office-background.svg" alt="" class="hero-background-image" />
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-heading animate-fade-up" aria-label="The AI marketing system that ships the work.">
        <span class="hero-heading-line">The AI marketing system that</span>
        <span class="hero-heading-rotator" aria-hidden="true">
          <span class="hero-heading-accent">ships the work.</span>
          <span class="hero-heading-accent">learns your business.</span>
          <span class="hero-heading-accent">manages your website.</span>
          <span class="hero-heading-accent">keeps social up to date.</span>
          <span class="hero-heading-accent">keeps campaigns moving.</span>
          <span class="hero-heading-accent">follows up with leads.</span>
          <span class="hero-heading-accent">remembers what worked.</span>
          <span class="hero-heading-accent">finds the next opportunity.</span>
        </span>
      </h1>
      <p class="hero-description hero-heading-support animate-fade-up">
        <span>Run by your trained AI marketing agent.</span>
        <span>Managed by expert human marketers for you.</span>
      </p>
      <div class="button-group animate-fade-up">
        <a href={walkthroughHref} class="button">Book a Walkthrough</a>
        <a href={trialHref} class="button is-secondary">Apply for a 30-Day Trial</a>
      </div>
    </div>
    <div class="capability-strip animate-fade-up" aria-label="Markethink capabilities">
      <div class="capability-track">
        {[...capabilities, ...capabilities].map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 9.5rem 0 4.5rem;
    background: #0f1213;
  }

  .section-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 50% 43%, rgba(4, 6, 6, 0.3) 0%, rgba(4, 6, 6, 0.62) 44%, rgba(4, 6, 6, 0.88) 100%),
      linear-gradient(180deg, rgba(15, 18, 19, 0.2) 0%, rgba(15, 18, 19, 0.5) 58%, #0f1213 100%);
    pointer-events: none;
  }

  .section-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(circle at 50% 46%, rgba(105, 210, 84, 0.14), transparent 34rem);
    pointer-events: none;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-background-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.96) contrast(1.04);
    transform: translateY(1.4rem) scale(1.015);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - 14rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.45rem;
    max-width: min(72rem, 94vw);
    margin: 0 auto;
    text-align: center;
  }

  .hero-heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: min(72rem, 94vw);
    font-size: clamp(4.85rem, 8vw, 9.4rem);
    line-height: 0.88;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  .hero-heading-line {
    color: #fff;
  }

  .hero-heading-rotator {
    position: relative;
    display: block;
    width: min(100%, 58rem);
    min-height: 1.28em;
    padding-bottom: 0.22em;
    margin-bottom: -0.2em;
    overflow: hidden;
    font-size: 0.82em;
  }

  .hero-heading-accent {
    position: absolute;
    inset: 0 0 auto 0;
    min-height: 1.14em;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    color: #69D254;
    line-height: 1;
    opacity: 0;
    transform: translateY(0.24em);
    animation: hero-rotate 32s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    white-space: nowrap;
    will-change: opacity, transform;
  }

  .hero-heading-accent:nth-child(2) {
    animation-delay: 4s;
  }

  .hero-heading-accent:nth-child(3) {
    animation-delay: 8s;
  }

  .hero-heading-accent:nth-child(4) {
    animation-delay: 12s;
  }

  .hero-heading-accent:nth-child(5) {
    animation-delay: 16s;
  }

  .hero-heading-accent:nth-child(6) {
    animation-delay: 20s;
  }

  .hero-heading-accent:nth-child(7) {
    animation-delay: 24s;
  }

  .hero-heading-accent:nth-child(8) {
    animation-delay: 28s;
  }

  @keyframes hero-rotate {
    0% {
      opacity: 0;
      transform: translateY(0.24em);
    }

    3%, 10.5% {
      opacity: 1;
      transform: translateY(0);
    }

    12.5%, 100% {
      opacity: 0;
      transform: translateY(-0.22em);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-heading-accent {
      animation: none;
      opacity: 0;
      transform: none;
    }

    .hero-heading-accent:first-child {
      position: static;
      opacity: 1;
    }
  }

  .hero-description {
    color: rgba(255, 255, 255, 0.86);
    max-width: 64rem;
  }

  .hero-heading-support {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.08em;
    font-family: var(--font-display);
    font-size: clamp(2.05rem, 3.2vw, 4.1rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
    text-wrap: balance;
  }

  .hero-heading-support span {
    display: block;
  }

  .button-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .button-group .button {
    min-height: 3.9rem;
    padding-inline: 1.75rem;
    border-radius: 999px;
    font-size: clamp(0.98rem, 1.05vw, 1.15rem);
    font-weight: 750;
  }

  .button-group .button.is-secondary {
    color: #ffffff;
    border-color: rgba(105, 210, 84, 0.82);
    background: rgba(15, 18, 19, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .capability-strip {
    position: relative;
    width: min(100%, 64rem);
    margin: 3rem auto 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-button);
    background: rgba(15, 18, 19, 0.34);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    mask-image: linear-gradient(90deg, transparent 0, black 9%, black 91%, transparent 100%);
  }

  .capability-track {
    display: flex;
    width: max-content;
    gap: 0.65rem;
    padding: 0.72rem;
    animation: capability-scroll 32s linear infinite;
  }

  .capability-track span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0 1rem;
    border-radius: var(--radius-button);
    background: rgba(245, 245, 241, 0.08);
    color: rgba(245, 245, 241, 0.84);
    font-size: 0.82rem;
    font-weight: 650;
    white-space: nowrap;
  }

  @keyframes capability-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .capability-track {
      animation: none;
    }
  }

  @media (max-width: 1180px) {
    .hero-text {
      max-width: min(64rem, 94vw);
    }

    .hero-heading {
      max-width: min(64rem, 94vw);
      font-size: clamp(3.35rem, 7.2vw, 6.2rem);
    }

    .section-hero::before {
      background:
        radial-gradient(circle at 50% 42%, rgba(4, 6, 6, 0.34) 0%, rgba(4, 6, 6, 0.7) 52%, rgba(4, 6, 6, 0.9) 100%),
        linear-gradient(180deg, rgba(15, 18, 19, 0.14) 0%, rgba(15, 18, 19, 0.24) 58%, #0f1213 100%);
    }
  }

  @media (max-width: 767px) {
    .section-hero {
      min-height: auto;
      padding: 7.8rem 0 3.5rem;
    }

    .hero-content {
      min-height: 36rem;
    }

    .hero-background-image {
      object-position: 62% top;
      transform: translateY(1rem) scale(1.02);
    }

    .section-hero::before {
      background:
        linear-gradient(180deg, rgba(4, 6, 6, 0.78) 0%, rgba(4, 6, 6, 0.7) 46%, #0f1213 100%),
        linear-gradient(90deg, rgba(4, 6, 6, 0.78) 0%, rgba(4, 6, 6, 0.3) 100%);
    }

    .hero-text {
      max-width: 100%;
      gap: 1.25rem;
    }

    .hero-heading {
      max-width: 100%;
      font-size: clamp(2.45rem, 10.6vw, 3.85rem);
    }

    .hero-heading-rotator {
      font-size: 0.76em;
    }

    .hero-description {
      max-width: 34rem;
    }

    .hero-heading-support {
      font-size: clamp(1.55rem, 7.2vw, 2.45rem);
    }

    .capability-strip {
      margin-top: 2.25rem;
    }
  }

  @media (max-width: 479px) {
    .section-hero {
      padding-bottom: 3rem;
    }

    .hero-content {
      min-height: 33rem;
    }

    .hero-heading {
      font-size: clamp(2.18rem, 11.2vw, 3rem);
      letter-spacing: -0.055em;
    }

    .hero-heading-rotator {
      font-size: 0.68em;
      min-height: 1.42em;
    }

    .hero-heading-support {
      font-size: clamp(1.35rem, 7.8vw, 2rem);
      letter-spacing: -0.04em;
    }

    .button-group,
    .button-group .button {
      width: 100%;
    }

    .button-group .button {
      justify-content: center;
    }
  }
</style>
