---
const trialHref = "/trial/";
const walkthroughHref = "/schedule-a-walkthrough/";
---

<section class="section-hero" id="hero">
  <div class="hero-backdrop" aria-hidden="true">
    <img src="/images/hero-image.png" alt="" class="hero-backdrop-image" />
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-heading animate-fade-up">
        <span>Stop managing marketing chaos.</span>
        <span class="hero-heading-accent">Start shipping.</span>
      </h1>
      <p class="hero-description animate-fade-up">
        Markethink learns your brand, understands your ideal clients, plans campaigns, creates content and visuals, organizes approvals, finds opportunities, and keeps the next move clear — so the marketing you meant to do actually gets done.
      </p>
      <div class="button-group animate-fade-up">
        <a href={walkthroughHref} class="button">Book a Walkthrough</a>
        <a href={trialHref} class="button is-secondary">Apply for a 30-Day Trial</a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-hero {
    padding-top: 8rem;
    padding-bottom: 4rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .section-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      radial-gradient(circle at 50% 18%, rgba(105, 210, 84, 0.16), transparent 30rem),
      linear-gradient(180deg, rgba(15, 18, 19, 0.2) 0%, #0f1213 86%);
  }

  .section-hero::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 2.75rem;
    z-index: -1;
    width: min(840px, 82vw);
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(90deg, transparent, rgba(105, 210, 84, 0.48), transparent);
    opacity: 0.7;
  }

  .hero-backdrop {
    position: absolute;
    inset: 6rem 0 auto;
    z-index: -2;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }

  .hero-backdrop-image {
    width: min(1040px, 90vw);
    max-height: 600px;
    object-fit: contain;
    opacity: 0.18;
    filter: saturate(0.78) contrast(1.08);
    transform: translate(18%, 1rem) scale(1.08);
    mask-image: radial-gradient(circle at 62% 42%, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.5) 34%, transparent 72%);
    -webkit-mask-image: radial-gradient(circle at 62% 42%, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.5) 34%, transparent 72%);
  }

  .hero-content {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 12rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 58rem;
    margin: 0 auto;
    text-align: center;
  }

  .hero-heading {
    display: flex;
    flex-direction: column;
    max-width: 55rem;
    font-size: clamp(3.2rem, 8vw, 7.8rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .hero-heading-accent {
    color: #69D254;
  }

  .hero-description {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: rgba(255, 255, 255, 0.76);
    max-width: 47rem;
    line-height: 1.7;
  }

  .button-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 991px) {
    .section-hero {
      padding-top: 7rem;
    }

    .hero-backdrop-image {
      width: 110vw;
      opacity: 0.14;
      transform: translate(10%, 2rem) scale(1.06);
    }
  }

  @media (max-width: 767px) {
    .section-hero {
      padding-top: 7rem;
      min-height: auto;
    }

    .hero-content {
      min-height: 34rem;
    }

    .hero-text {
      gap: 1.25rem;
    }

    .hero-heading {
      font-size: clamp(3rem, 16vw, 4.6rem);
    }

    .hero-description {
      font-size: 1rem;
    }
  }

  @media (max-width: 479px) {
    .section-hero {
      padding-bottom: 3rem;
    }

    .hero-content {
      min-height: 31rem;
    }

    .hero-backdrop-image {
      width: 140vw;
      opacity: 0.12;
      transform: translate(8%, 4rem) scale(1.12);
    }
  }
</style>
