---

<Layout
  title="Markethink for InList + The 0.07%"
  description="A private presentation on how Markethink can support growth, website management, content, and custom user experiences for InList and The 0.07%."
  image={`${assetBase}/quiet-luxury-access.png`}
  canonical="https://markethink.ai/presentation-inlist-007/"
  noindex={true}
>
  <main class="presentation-page" aria-label="Markethink private presentation for InList and The 0.07%">
    <header class="presentation-topbar">
      <a href="/" class="logo-lockup" aria-label="Markethink">
        <img src="/images/logo.svg" alt="Markethink" class="markethink-logo" />
      </a>
      <div class="prospect-lockup" aria-label="Presentation brands">
        <img src={`${assetBase}/inlist-logo.svg`} alt="InList" class="inlist-wordmark" />
        <span class="lockup-divider"></span>
        <span class="zero-wordmark">The 0.07%</span>
      </div>
      <span class="deck-label">Private presentation</span>
    </header>

    <aside class="slide-rail" aria-label="Presentation sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} class={`rail-item ${slide.n === '01' ? 'active' : ''}`} data-slide-link={slide.id} aria-current={slide.n === '01' ? 'step' : undefined}>
          <span>{slide.n}</span><strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide, index) => (
      <section id={slide.id} data-slide-id={slide.id} data-slide-index={index} class={`presentation-slide layout-${slide.layout} ${slide.backgroundOnly ? 'background-led' : ''} ${slide.n === '01' ? 'is-active' : ''}`} aria-label={`Slide ${slide.n}: ${slide.nav}`}>
        <div class="slide-background" aria-hidden="true">
          {slide.backgroundOnly && (
            <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
          )}
        </div>
        <div class="slide-overlay" aria-hidden="true"></div>
        <div class="motion-field" aria-hidden="true"><span></span><span></span><span></span><span></span></div>

        <div class="slide-shell">
          <div class="story-content">
            <p class="eyebrow">{slide.kicker}</p>
            {slide.n === '01' && (
              <div class="brand-row" aria-label="Brand lockup">
                {brands.map((brand) => brand.type === 'image' ? (
                  <span class={`brand-pill ${brand.className}`}><img src={brand.src} alt={brand.name} /></span>
                ) : (
                  <span class={`brand-pill ${brand.className}`}>{brand.name}</span>
                ))}
              </div>
            )}
            <h1 set:html={slide.title}></h1>
            <p class="lead">{slide.lead}</p>
            {slide.chips?.length > 0 && (
              <div class="chip-row" aria-label="Key points">
                {slide.chips.map((chip) => <span>{chip}</span>)}
              </div>
            )}
            {slide.vendorLogos?.length > 0 && (
              <div class="vendor-row" aria-label="Leading AI systems referenced">
                {slide.vendorLogos.map((vendor) => <span>{vendor}</span>)}
              </div>
            )}
            {slide.details && (
              <ul class="detail-list" aria-label="Section details">
                {slide.details.map((item) => <li>{item}</li>)}
              </ul>
            )}
            <div class="hero-actions" aria-label="Presentation context">
              <span class="context-note">Markethink · {slide.note}</span>
            </div>
          </div>

          {!slide.backgroundOnly && (
            <div class="visual-stack">
              <div class="visual-card" aria-hidden="true">
                <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
              </div>
            </div>
          )}
        </div>

        <div class="slide-footer">
          <span>{slide.n} / {slide.nav}</span>
          <span>{slide.note}</span>
        </div>
      </section>
    ))}
  </main>
</Layout>

<script is:inline>
  (() => {
    const slides = Array.from(document.querySelectorAll('.presentation-slide[data-slide-id]'));
    const railItems = Array.from(document.querySelectorAll('.rail-item[data-slide-link]'));

    if (!slides.length || !railItems.length) return;

    const setActiveSlide = (id) => {
      railItems.forEach((item) => {
        const isActive = item.dataset.slideLink === id;
        item.classList.toggle('active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', 'step');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      slides.forEach((slide) => {
        slide.classList.toggle('is-active', slide.dataset.slideId === id);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.dataset?.slideId) {
          setActiveSlide(visible.target.dataset.slideId);
        }
      },
      {
        root: null,
        threshold: [0.28, 0.42, 0.58, 0.72],
        rootMargin: '-22% 0px -34% 0px',
      }
    );

    slides.forEach((slide) => observer.observe(slide));

    railItems.forEach((item) => {
      item.addEventListener('click', () => {
        if (item.dataset.slideLink) setActiveSlide(item.dataset.slideLink);
      });
    });
  })();
</script>

