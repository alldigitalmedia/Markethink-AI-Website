  {
    n: "02",
    id: "architecture",
    nav: "Architecture",
    kicker: "SLIDE 02 · CAMPAIGN ARCHITECTURE",
    title: "The campaign should not start as one healthcare software account.",
    lead: "The three brands serve different buyers and different search moments. Keeping them separate improves message match, lead qualification, landing-page relevance, and reporting quality.",
