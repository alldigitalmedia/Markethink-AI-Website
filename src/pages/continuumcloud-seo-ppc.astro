  .rail { position:fixed; z-index:18; right:clamp(.7rem,1.6vw,1.4rem); top:50%; transform:translateY(-50%); display:grid; gap:.28rem; max-height:78vh; overflow:auto; padding:.2rem; scrollbar-width:none; }
  .rail::-webkit-scrollbar { display:none; }
  .rail-item { display:grid; grid-template-columns:1.45rem 1fr; gap:.36rem; align-items:center; width:7.2rem; padding:.34rem; border:1px solid rgba(255,255,255,.12); border-radius:.78rem; background:rgba(7,31,51,.58); color:rgba(247,251,252,.75); text-decoration:none; backdrop-filter:blur(14px); transition:.22s ease; }
  .rail-item:hover { transform:translateX(-.12rem); border-color:rgba(0,178,177,.45); color:#fff; }
  .rail-item span { display:grid; place-items:center; width:1.45rem; height:1.45rem; border-radius:.52rem; background:rgba(0,178,177,.14); color:var(--teal); font-size:.58rem; font-weight:800; }
  .rail-item strong { font-size:.66rem; font-weight:650; line-height:1.05; }
