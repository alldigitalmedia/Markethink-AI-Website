---
import Layout from "../layouts/Layout.astro";

const continuumLogo = "https://continuumcloud.com/wp-content/uploads/2025/07/whitelogo.png";
const continuumMark = "https://continuumcloud.com/wp-content/uploads/2026/01/CC-Logo_02.png";
const heroImage = "https://continuumcloud.com/wp-content/uploads/2022/10/HP_Hero.png";
const welligentIcon = "https://continuumcloud.com/wp-content/uploads/2026/01/Welligent_App.png";
const datisIcon = "https://continuumcloud.com/wp-content/uploads/2026/01/HCM_icon.png";
const caredForIcon = "https://continuumcloud.com/wp-content/uploads/2026/01/PE_icon.png";

const sourceLinks = [
  { label: "ContinuumCloud", href: "https://continuumcloud.com/" },
  { label: "Software suite", href: "https://continuumcloud.com/behavioral-health-software/" },
  { label: "Welligent", href: "https://continuumcloud.com/behavioral-health-software/welligent/" },
  { label: "DATIS", href: "https://continuumcloud.com/behavioral-health-software/datis/" },
  { label: "CaredFor", href: "https://continuumcloud.com/behavioral-health-software/caredfor/" },
  { label: "CCBHCs", href: "https://continuumcloud.com/who-we-serve/ccbhcs/" },
  { label: "Substance use", href: "https://continuumcloud.com/who-we-serve/substance-use-treatment/" },
  { label: "Clinically AI", href: "https://continuumcloud.com/clinically-ai/" },
  { label: "Mental health", href: "https://continuumcloud.com/who-we-serve/mental-health-wellbeing/" },
  { label: "I/DD + autism", href: "https://continuumcloud.com/who-we-serve/idd-autism/" },
  { label: "Residential", href: "https://continuumcloud.com/who-we-serve/residential/" },
  { label: "Sitemap", href: "https://continuumcloud.com/sitemap.xml" },
];

const slides = [
  {
    n: "01",
    id: "opening",
    nav: "Opening",
    kicker: "PRIVATE STRATEGY PREVIEW · SEO + PPC",
    title: "How we would approach SEO and PPC for ContinuumCloud.",
    lead: "The opportunity is not simply more traffic. It is a segmented demand system that connects each searcher to the right product, page, conversion event, and sales follow-up path.",
    layout: "hero",
    image: heroImage,
    chips: ["SEO", "PPC", "Landing pages", "Tracking", "Sales follow-up"],
    note: "Intro for the marketing team",
    sources: [sourceLinks[0], sourceLinks[1]],
  },
  {
    n: "02",
    id: "business-architecture",
    nav: "Business",
    kicker: "SLIDE 02 · WHAT THE RESEARCH SHOWS",
    title: "ContinuumCloud is not one generic software search. It is several buyer journeys.",
    lead: "The public site points to a connected behavioral health and human services stack: EHR, HCM, patient engagement, documentation, billing, reporting, compliance, and workforce operations.",
    layout: "products",
    chips: ["Clinical", "Workforce", "Engagement", "Documentation"],
    note: "Four product entry points",
    products: [
      { name: "Welligent", label: "Behavioral health EHR, billing, documentation, reporting", icon: welligentIcon, href: sourceLinks[2].href },
      { name: "DATIS", label: "HCM, payroll, position control, workforce", icon: datisIcon, href: sourceLinks[3].href },
      { name: "CaredFor", label: "Patient, family, alumni, aftercare engagement", icon: caredForIcon, href: sourceLinks[4].href },
      { name: "Clinically AI", label: "Documentation support and compliance workflow", icon: continuumMark, href: sourceLinks[7].href },
    ],
    sources: [sourceLinks[2], sourceLinks[3], sourceLinks[4], sourceLinks[7]],
  },
  {
    n: "03",
    id: "buyer-map",
    nav: "Buyers",
    kicker: "SLIDE 03 · BUYER AND INTENT MAP",
    title: "Different buyers are trying to solve different problems. Search needs to respect that.",
    lead: "A clinical director, HR leader, CCBHC executive, substance use operator, and patient experience owner should not all be routed into the same story.",
    layout: "map",
    chips: ["Intent", "Product", "Buyer route"],
    note: "Message match before spend",
    rows: [
      ["Behavioral health EHR", "Welligent", "Clinical + operations"],
      ["CCBHC software", "Suite story", "Executive + compliance"],
      ["HCM / position control", "DATIS", "HR + finance"],
      ["SUD / residential", "Welligent + CaredFor", "Operations + engagement"],
      ["AI documentation", "Clinically AI", "Clinical leadership"],
    ],
    sources: [sourceLinks[5], sourceLinks[6], sourceLinks[10]],
  },
  {
    n: "04",
    id: "seo-research",
    nav: "SEO",
    kicker: "SLIDE 04 · SEO RESEARCH READOUT",
    title: "The site already has content depth. The bigger SEO opportunity is commercial routing.",
    lead: "Resources, webinars, podcasts, product pages, and vertical pages already exist. The next layer is making the highest-value commercial paths easier for search engines and buyers to understand.",
    layout: "cards",
    chips: ["Resources", "Money pages", "Internal links", "Index coverage"],
    note: "Do not start with content volume alone",
    cards: [
      { title: "Content footprint", body: "Public resources give ContinuumCloud material to work with: blogs, webinars, press, podcasts, and vertical education." },
      { title: "Commercial hierarchy", body: "Welligent, DATIS, CaredFor, Clinically AI, CCBHC, SUD, and mental health pages should carry clearer search roles." },
      { title: "Content-to-product routing", body: "Educational content should point buyers into the correct product or vertical page instead of only educating them." },
      { title: "Indexation review", body: "Sitemap and Search Console review should confirm whether the most important commercial pages are clearly represented." },
    ],
    sources: [sourceLinks[1], sourceLinks[5], sourceLinks[8], sourceLinks[11]],
  },
  {
    n: "05",
    id: "hard-findings",
    nav: "Findings",
    kicker: "SLIDE 05 · PUBLIC WEBSITE FINDINGS",
    title: "There are clear technical and page-structure improvements we can discuss without overreaching.",
    lead: "These are public-site observations, not private analytics claims. They are useful because they give the marketing manager a concrete starting point before we ask for account data.",
    layout: "cards",
    chips: ["Duplicate H1s", "Sitemap coverage", "Page hierarchy", "Search Console"],
    note: "Observed from public pages",
    cards: [
      {
        title: "Duplicate H1s on money pages",
        body: "Example: these pages render the same primary H1 twice in the page HTML.",
        examples: [
          { label: "Behavioral health software", href: "https://continuumcloud.com/behavioral-health-software/", detail: "H1 repeated: Cloud-Based Behavioral Health Software" },
          { label: "Welligent", href: "https://continuumcloud.com/behavioral-health-software/welligent/", detail: "H1 repeated: Welligent: The #1 Cloud-Based Behavioral Health EHR" },
          { label: "DATIS", href: "https://continuumcloud.com/behavioral-health-software/datis/", detail: "H1 repeated: Human Capital Management" },
        ],
      },
      {
        title: "CCBHC page has competing H1s",
        body: "Example: the CCBHC page renders several H1s, including section labels like Staffing, Accessibility, Care coordination, and Quality and reporting.",
        examples: [
          { label: "CCBHC page", href: "https://continuumcloud.com/who-we-serve/ccbhcs/", detail: "Multiple H1s compete with the main page topic" },
        ],
      },
      {
        title: "Sitemap coverage needs validation",
        body: "The XML sitemap set inspected did not clearly surface several core commercial pages. We would validate this inside Search Console before making a stronger claim.",
        examples: [
          { label: "Sitemap", href: "https://continuumcloud.com/sitemap.xml", detail: "Public XML sitemap set reviewed" },
        ],
      },
      { title: "Commercial pages need cleaner hierarchy", body: "A practical first cleanup: page hierarchy, indexation validation, schema review, internal links, and source-to-CRM tracking clarity." },
    ],
    sources: [sourceLinks[1], sourceLinks[2], sourceLinks[3], sourceLinks[5], sourceLinks[11]],
  },
  {
    n: "06",
    id: "ppc-architecture",
    nav: "PPC plan",
    kicker: "SLIDE 06 · PPC ACCOUNT ARCHITECTURE",
    title: "Paid search should be built around product and intent, not one broad healthcare software campaign.",
    lead: "The first wave should focus where buyer intent and product clarity are strongest. Start focused, measure lead quality, then expand into noisier or more experimental categories.",
    layout: "budget",
    chips: ["Welligent", "CCBHC", "DATIS", "SUD", "CaredFor", "AI test"],
    note: "Prioritize quality before scale",
    budget: [
      { label: "Welligent / Behavioral Health EHR", value: "01", detail: "Highest-intent category. Natural demo path around EHR, billing, documentation, reporting." },
      { label: "CCBHC software", value: "02", detail: "Strategic vertical with requirement, funding, reporting, and operational-readiness searches." },
      { label: "DATIS / HCM workforce", value: "03", detail: "Sharper wedge than generic HR. Focus on behavioral health and human services workforce needs." },
      { label: "SUD / residential", value: "04", detail: "Promising but noisy. Use exact/phrase match and strong qualification filters." },
      { label: "CaredFor / patient engagement", value: "05", detail: "Smaller volume, differentiated aftercare and alumni-engagement story." },
      { label: "Clinically AI", value: "06", detail: "Controlled test only. High interest, but requires careful claims and lead-quality review." },
    ],
    sources: [sourceLinks[2], sourceLinks[3], sourceLinks[4], sourceLinks[5]],
  },
  {
    n: "07",
    id: "landing-pages",
    nav: "Pages",
    kicker: "SLIDE 07 · LANDING PAGE PLAN",
    title: "Product pages explain the suite. Paid pages should capture one buyer problem at a time.",
    lead: "Each search path should get its own headline, proof set, demo path, CRM label, and follow-up route. That is how PPC becomes a demand system instead of a click-buying exercise.",
    layout: "pages",
    chips: ["Message match", "Demo path", "Proof", "CRM source"],
    note: "Dedicated pages reduce wasted clicks",
    pages: [
      "Behavioral Health EHR Software",
      "CCBHC Software Platform",
      "HCM Software for Behavioral Health and Human Services",
      "Substance Use Treatment EHR + Engagement",
      "Patient Engagement Software for Behavioral Health",
      "AI Documentation for Behavioral Health",
    ],
    sources: [sourceLinks[2], sourceLinks[3], sourceLinks[4], sourceLinks[7]],
  },
  {
    n: "08",
    id: "filters",
    nav: "Filters",
    kicker: "SLIDE 08 · NEGATIVE KEYWORD AND QUALIFICATION STRATEGY",
    title: "Their PPC success will depend heavily on filtering wrong-fit intent.",
    lead: "Behavioral health, substance use, human services, HCM, and AI terms can attract students, job seekers, patients, small practices, support queries, and generic research. The account has to protect sales quality from day one.",
    layout: "cards",
    chips: ["Negatives", "Fit filters", "Lead quality", "CRM feedback"],
    note: "Cleaner intent beats more clicks",
    cards: [
      { title: "Exclude support and login traffic", body: "Block login, portal, support, customer service, records request, training, certification, and similar non-buyer searches." },
      { title: "Separate patient intent", body: "Avoid patient-near-me, rehab-near-me, therapist-near-me, treatment-near-me, and consumer care searches unless a campaign intentionally targets them." },
      { title: "Protect enterprise fit", body: "Filter out free, template, open source, solo practice, small private practice, and low-fit software research when the goal is larger organizations." },
      { title: "Use sales feedback weekly", body: "Negative keywords should not be static. Review search terms and CRM quality together so the account learns what a qualified opportunity looks like." },
    ],
    sources: [sourceLinks[6], sourceLinks[8]],
  },
  {
    n: "09",
    id: "measurement",
    nav: "Tracking",
    kicker: "SLIDE 09 · MEASUREMENT AND SALES FOLLOW-UP",
    title: "The scorecard should not stop at form fills. It should show which searches become qualified conversations.",
    lead: "We would connect UTMs, landing pages, conversion labels, product interest, CRM source, and sales feedback so SEO and PPC can optimize toward pipeline quality, not just raw lead volume.",
    layout: "flow",
    chips: ["UTMs", "Demo request", "MQL", "SQL", "Pipeline"],
    note: "Optimize to qualified movement",
    steps: ["Search intent", "Landing page", "Demo or download", "CRM source", "Qualified opportunity", "Sales feedback loop"],
    sources: [sourceLinks[0]],
  },
  {
    n: "10",
    id: "recommended-move",
    nav: "First sprint",
    kicker: "SLIDE 10 · HOW WE WOULD START",
    title: "Start with a focused audit, then build the first demand paths with the data in front of us.",
    lead: "The goal for the intro is to show we understand the business, ask for the right data, and recommend one focused first sprint instead of pitching generic channel management.",
    layout: "close",
    image: heroImage,
    chips: ["Audit", "Demand map", "Landing pages", "Tracking", "First test"],
    note: "A practical first sprint",
    checklist: [
      "Confirm the priority product lines and buyer segments",
      "Review Search Console, ad account, CRM, and conversion tracking data",
      "Clean visible SEO issues and validate index coverage",
      "Map Welligent, CCBHC, and DATIS as first-wave demand paths",
      "Build or improve the first paid-search landing page and tracking flow",
      "Review lead quality weekly with marketing and sales feedback",
    ],
    sources: sourceLinks,
  },
];

---

<Layout
  title="ContinuumCloud SEO + PPC Strategy Preview"
  description="A private ContinuumCloud strategy preview: SEO and PPC demand architecture, landing page opportunities, and recommended first moves."
  image={heroImage}
  canonical="https://markethink.ai/continuumcloud-seo-ppc/"
  noindex={true}
  siteName="ContinuumCloud"
  favicon={continuumMark}
>
  <main class="deck" aria-label="ContinuumCloud SEO and PPC strategy presentation">
    <header class="topbar">
      <div class="brand-lockup" aria-label="ContinuumCloud">
        <img src={continuumLogo} alt="ContinuumCloud" class="cc-logo" />
      </div>
      <span class="private-label">Private SEO + PPC preview</span>
    </header>

    <aside class="rail" aria-label="Presentation navigation">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} class="rail-item">
          <span>{slide.n}</span><strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} class={`slide layout-${slide.layout}`} aria-label={`Slide ${slide.n}: ${slide.nav}`}>
        <div class="bg" aria-hidden="true">
          {slide.image ? <img src={slide.image} alt="" loading={slide.n === "01" ? "eager" : "lazy"} decoding="async" /> : <img src={heroImage} alt="" loading="lazy" decoding="async" />}
        </div>
        <div class="wash" aria-hidden="true"></div>
        <div class="grid" aria-hidden="true"></div>

        <div class="shell">
          <div class="copy">
            <p class="kicker">{slide.kicker}</p>
            <h1>{slide.title}</h1>
            <p class="lead">{slide.lead}</p>
            <div class="chips">
              {slide.chips.map((chip) => <span>{chip}</span>)}
            </div>
          </div>

          <div class="visual">
            {slide.layout === "hero" && (
              <div class="hero-panel">
                <img src={continuumMark} alt="" />
                <strong>One suite. Multiple demand paths.</strong>
                <p>SEO and PPC should route each buyer to the product, proof, and next step that matches their intent.</p>
              </div>
            )}

            {slide.products && (
              <div class="product-grid">
                {slide.products.map((product) => (
                  <a href={product.href} class="product-card" target="_blank" rel="noreferrer">
                    <img src={product.icon} alt="" />
                    <strong>{product.name}</strong>
                    <span>{product.label}</span>
                  </a>
                ))}
              </div>
            )}

            {slide.rows && (
              <div class="intent-table">
                {slide.rows.map((row) => (
                  <div class="intent-row">
                    <strong>{row[0]}</strong>
                    <span>{row[1]}</span>
                    <em>{row[2]}</em>
                  </div>
                ))}
              </div>
            )}

            {slide.cards && (
              <div class="card-grid">
                {slide.cards.map((card) => (
                  <article>
                    <strong>{card.title}</strong>
                    <p>{card.body}</p>
                    {card.examples && (
                      <div class="card-examples">
                        {card.examples.map((example) => (
                          <a href={example.href} target="_blank" rel="noreferrer">
                            <span>{example.label}</span>
                            <em>{example.detail}</em>
                          </a>
                        ))}
                      </div>
                    )}
                  </article>
                ))}
              </div>
            )}

            {slide.budget && (
              <div class="budget-list">
                {slide.budget.map((item) => (
                  <div class="budget-row">
                    <span>{item.value}</span>
                    <div><strong>{item.label}</strong><em>{item.detail}</em></div>
                  </div>
                ))}
              </div>
            )}

            {slide.pages && (
              <div class="page-stack">
                {slide.pages.map((page, index) => (
                  <div><span>{String(index + 1).padStart(2, "0")}</span><strong>{page}</strong></div>
                ))}
              </div>
            )}

            {slide.steps && (
              <div class="flow-line">
                {slide.steps.map((step, index) => (
                  <div><span>{index + 1}</span><strong>{step}</strong></div>
                ))}
              </div>
            )}

            {slide.checklist && (
              <div class="next-card">
                <strong>Recommended first sprint</strong>
                <ul>
                  {slide.checklist.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            )}
          </div>
        </div>

        <footer class="slide-footer">
          <span>{slide.n} / {slide.nav} · {slide.note}</span>
          <div>
            {slide.sources?.slice(0, 4).map((source) => (
              <a href={source.href} target="_blank" rel="noreferrer">{source.label}</a>
            ))}
          </div>
        </footer>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(html) { background: #071f33; scroll-behavior: smooth; }
  .deck { --navy:#003070; --teal:#00b2b1; --orange:#f39a31; --cream:#f7fbfc; --ink:#071f33; min-height:100vh; color:var(--cream); background:var(--ink); font-family:var(--font-body); overflow-x:hidden; }
  .topbar { position:fixed; z-index:20; top:clamp(1rem,2vw,1.8rem); left:clamp(1rem,3.5vw,3.5rem); right:clamp(1rem,3.5vw,3.5rem); display:flex; justify-content:space-between; align-items:center; pointer-events:none; }
  .brand-lockup { pointer-events:none; display:inline-flex; align-items:center; min-height:3rem; padding:.78rem 1.1rem; border:1px solid rgba(255,255,255,.14); border-radius:999px; background:rgba(7,31,51,.72); backdrop-filter:blur(18px); box-shadow:0 18px 70px rgba(0,0,0,.25); }
  .cc-logo { width:13.5rem; height:auto; object-fit:contain; }
  .private-label { pointer-events:none; padding:.72rem 1rem; border:1px solid rgba(255,255,255,.12); border-radius:999px; background:rgba(7,31,51,.52); color:rgba(247,251,252,.74); font-size:.72rem; letter-spacing:.14em; text-transform:uppercase; backdrop-filter:blur(14px); }
  .rail { position:fixed; z-index:18; right:clamp(.9rem,2vw,1.8rem); top:50%; transform:translateY(-50%); display:grid; gap:.42rem; }
  .rail-item { display:grid; grid-template-columns:1.75rem 1fr; gap:.45rem; align-items:center; width:8.25rem; padding:.45rem; border:1px solid rgba(255,255,255,.12); border-radius:.95rem; background:rgba(7,31,51,.58); color:rgba(247,251,252,.75); text-decoration:none; backdrop-filter:blur(14px); transition:.22s ease; }
  .rail-item:hover { transform:translateX(-.16rem); border-color:rgba(0,178,177,.45); color:#fff; }
  .rail-item span { display:grid; place-items:center; width:1.75rem; height:1.75rem; border-radius:.65rem; background:rgba(0,178,177,.14); color:var(--teal); font-size:.65rem; font-weight:800; }
  .rail-item strong { font-size:.72rem; font-weight:650; }
  .slide { position:relative; min-height:100svh; overflow:hidden; isolation:isolate; display:grid; align-items:center; padding:clamp(7rem,10vh,8.5rem) clamp(1.3rem,5vw,5rem) clamp(4.8rem,7vh,6rem); }
  .bg, .wash, .grid { position:absolute; inset:0; }
  .bg { z-index:-4; background:linear-gradient(135deg,#003070,#071f33); }
  .bg img { width:100%; height:100%; object-fit:cover; object-position:center; opacity:.18; filter:saturate(.95) contrast(1.08); transform:scale(1.03); }
  .wash { z-index:-3; background: radial-gradient(circle at 78% 30%, rgba(0,178,177,.33), transparent 28%), radial-gradient(circle at 88% 80%, rgba(243,154,49,.18), transparent 24%), linear-gradient(90deg, rgba(7,31,51,.98) 0%, rgba(7,31,51,.86) 47%, rgba(7,31,51,.50) 100%), linear-gradient(180deg, rgba(0,48,112,.18), rgba(7,31,51,.90)); }
  .grid { z-index:-2; opacity:.42; background-image:linear-gradient(rgba(255,255,255,.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.06) 1px, transparent 1px); background-size:72px 72px; mask-image:radial-gradient(circle at 66% 45%, black, transparent 76%); }
  .shell { width:min(1240px,100%); margin-inline:auto; display:grid; grid-template-columns:minmax(0,.88fr) minmax(420px,1fr); align-items:center; gap:clamp(2rem,5vw,5rem); }
  .copy { position:relative; z-index:2; max-width:770px; }
  .kicker { display:inline-flex; gap:.65rem; align-items:center; margin:0 0 1.05rem; color:rgba(247,251,252,.72); font-size:.74rem; letter-spacing:.16em; text-transform:uppercase; }
  .kicker::before { content:""; width:.55rem; height:.55rem; border-radius:999px; background:var(--teal); box-shadow:0 0 0 .32rem rgba(0,178,177,.14); }
  h1 { max-width:14.8ch; margin:0; font-family:"Instrument Serif", Georgia, serif; font-size:clamp(2.65rem,5.2vw,5.75rem); line-height:.98; font-weight:400; letter-spacing:-.04em; text-wrap:balance; }
  .lead { max-width:47rem; margin:1.15rem 0 0; color:rgba(247,251,252,.82); font-size:clamp(1rem,1.15vw,1.16rem); line-height:1.52; text-wrap:balance; }
  .chips { display:flex; flex-wrap:wrap; gap:.55rem; margin-top:1.2rem; }
  .chips span { padding:.64rem .82rem; border:1px solid rgba(255,255,255,.13); border-radius:999px; background:rgba(255,255,255,.06); color:rgba(247,251,252,.80); font-size:.8rem; backdrop-filter:blur(12px); }
  .visual { position:relative; z-index:3; }
  .hero-panel, .next-card { padding:clamp(1.4rem,2.4vw,2rem); border:1px solid rgba(255,255,255,.14); border-radius:2rem; background:linear-gradient(135deg, rgba(255,255,255,.12), rgba(255,255,255,.055)); backdrop-filter:blur(20px); box-shadow:0 40px 130px rgba(0,0,0,.32); }
  .hero-panel img { width:7rem; margin-bottom:1.5rem; filter:drop-shadow(0 18px 40px rgba(0,0,0,.32)); }
  .hero-panel strong, .next-card strong { display:block; font-size:clamp(1.5rem,2.6vw,2.45rem); line-height:1.05; font-family:"Instrument Serif", Georgia, serif; font-weight:400; }
  .hero-panel p { color:rgba(247,251,252,.76); line-height:1.5; margin:.85rem 0 0; }
  .product-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.85rem; }
  .product-card { min-height:11rem; display:flex; flex-direction:column; justify-content:flex-end; gap:.45rem; padding:1.15rem; border:1px solid rgba(255,255,255,.13); border-radius:1.35rem; background:linear-gradient(135deg, rgba(255,255,255,.12), rgba(255,255,255,.055)); color:#fff; text-decoration:none; backdrop-filter:blur(18px); box-shadow:0 24px 80px rgba(0,0,0,.22); }
  .product-card img { width:3rem; height:3rem; object-fit:contain; margin-bottom:auto; }
  .product-card strong { font-size:1.15rem; }
  .product-card span { color:rgba(247,251,252,.68); font-size:.9rem; }
  .intent-table, .budget-list, .page-stack { display:grid; gap:.62rem; }
  .intent-row, .budget-row, .page-stack div { display:grid; grid-template-columns:1.35fr .9fr 1.1fr; gap:.8rem; align-items:center; padding:.88rem 1rem; border:1px solid rgba(255,255,255,.12); border-radius:1rem; background:rgba(255,255,255,.07); backdrop-filter:blur(16px); }
  .intent-row strong { color:#fff; } .intent-row span { color:var(--teal); font-weight:750; } .intent-row em { color:rgba(247,251,252,.70); font-style:normal; }
  .card-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.75rem; }
  .card-grid article { min-height:10.5rem; padding:1.05rem; border:1px solid rgba(255,255,255,.12); border-radius:1.2rem; background:rgba(255,255,255,.075); backdrop-filter:blur(16px); }
