---

<Layout
  title="Villazzo Miami Property Management · Private Owner Presentation"
  description="A private Villazzo presentation for a Miami luxury homeowner considering property management."
  image={images.villa}
  canonical={deckUrl}
  noindex={true}
>
  <main class="villazzo-deck" aria-label="Villazzo private Miami homeowner presentation">
    <header class="deck-topbar">
      <a href="#opening" class="brand-lockup" aria-label="Villazzo presentation home">
        <img class="brand-logo-img" src={villazzoLogo} alt="Villazzo" loading="eager" decoding="async" />
      </a>
      <span class="deck-label">Private owner presentation · Miami</span>
    </header>

    <aside class="slide-rail" aria-label="Presentation sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} class={`rail-item ${slide.n === '01' ? 'active' : ''}`} data-slide-link={slide.id} aria-current={slide.n === '01' ? 'step' : undefined}>
          <span>{slide.n}</span><strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide, index) => (
      <section id={slide.id} data-slide-id={slide.id} data-slide-index={index} class={`presentation-slide tone-${slide.tone} ${slide.n === '01' ? 'is-active' : ''}`} style={`--slide-image: url('${slide.image}')`} aria-label={`Slide ${slide.n}: ${slide.nav}`}>
        <div class="image-field" aria-hidden="true"><img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" /></div>
        <div class="paper-grain" aria-hidden="true"></div>
        <div class="slide-shell">
          <div class="story-content">
            {slide.n === '01' && (
              <div class="hero-logo" aria-label="Villazzo">
                <img class="hero-logo-img" src={villazzoLogo} alt="Villazzo" loading="eager" decoding="async" />
              </div>
            )}
            <p class="eyebrow"><span>{slide.n}</span>{slide.kicker}</p>
            <h1>{slide.title}</h1>
            <p class="lead">{slide.lead}</p>
            {slide.details && (
              <ul class="detail-list" aria-label="Section details">
                {slide.details.map((item) => <li>{item}</li>)}
              </ul>
            )}
            <div class="chip-row" aria-label="Key points">
              {slide.chips.map((chip) => <span>{chip}</span>)}
            </div>
          </div>
        </div>
        <div class="slide-footer">
          <span>Villazzo · {slide.note}</span>
          <span>{slide.n} / 10</span>
        </div>
      </section>
    ))}
  </main>
</Layout>

<script is:inline>
  (() => {
    const slides = Array.from(document.querySelectorAll('.presentation-slide[data-slide-id]'));
    const railItems = Array.from(document.querySelectorAll('.rail-item[data-slide-link]'));
    if (!slides.length || !railItems.length) return;
    const setActiveSlide = (id) => {
      railItems.forEach((item) => {
        const isActive = item.dataset.slideLink === id;
        item.classList.toggle('active', isActive);
        if (isActive) item.setAttribute('aria-current', 'step');
        else item.removeAttribute('aria-current');
      });
      slides.forEach((slide) => slide.classList.toggle('is-active', slide.dataset.slideId === id));
    };
    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible?.target?.dataset?.slideId) setActiveSlide(visible.target.dataset.slideId);
    }, { threshold: [0.32, 0.48, 0.64], rootMargin: '-18% 0px -36% 0px' });
    slides.forEach((slide) => observer.observe(slide));
  })();
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap');

  :global(html) { background: #f9f7f0; scroll-behavior: smooth; }
  .villazzo-deck { min-height: 100vh; overflow-x: hidden; background: #f9f7f0; color: #191713; font-family: Inter, var(--font-body), system-ui, sans-serif; }
  .presentation-slide { position: relative; min-height: 100svh; isolation: isolate; display: grid; align-items: center; padding: clamp(7.2rem, 10vh, 8.6rem) clamp(1.35rem, 5vw, 5.2rem) clamp(5rem, 7vh, 6.8rem); overflow: hidden; background: radial-gradient(circle at 16% 12%, rgba(255,255,255,.96), rgba(255,255,255,0) 38%), linear-gradient(120deg, #fbfaf6 0%, #f6f0e5 52%, #ede2cf 100%); scroll-margin-top: 0; }
  .presentation-slide::before { content: ""; position: absolute; inset: clamp(1.05rem, 2vw, 2rem); z-index: -1; border: 1px solid rgba(173, 139, 76, .24); pointer-events: none; }
  .presentation-slide::after { content: ""; position: absolute; inset: 0; z-index: -4; background: linear-gradient(90deg, rgba(255,255,255,.90) 0%, rgba(255,255,255,.72) 34%, rgba(255,255,255,.24) 67%, rgba(255,255,255,.60) 100%); pointer-events: none; }
  .image-field { position: absolute; inset: 0; z-index: -5; pointer-events: none; overflow: hidden; }
  .image-field img { position: absolute; right: -3vw; top: 50%; width: min(72vw, 1180px); height: 100%; min-height: 720px; object-fit: cover; object-position: center; opacity: .42; filter: saturate(.78) contrast(1.04) brightness(1.08); transform: translateY(-50%) scale(1.04); -webkit-mask-image: radial-gradient(ellipse at 68% 49%, #000 0%, rgba(0,0,0,.95) 34%, rgba(0,0,0,.58) 56%, transparent 78%); mask-image: radial-gradient(ellipse at 68% 49%, #000 0%, rgba(0,0,0,.95) 34%, rgba(0,0,0,.58) 56%, transparent 78%); }
  .tone-reverse .image-field img, .tone-light.reverse .image-field img, .tone-warm.reverse .image-field img { right: auto; left: -3vw; -webkit-mask-image: radial-gradient(ellipse at 30% 49%, #000 0%, rgba(0,0,0,.92) 34%, rgba(0,0,0,.52) 56%, transparent 78%); mask-image: radial-gradient(ellipse at 30% 49%, #000 0%, rgba(0,0,0,.92) 34%, rgba(0,0,0,.52) 56%, transparent 78%); }
  .tone-hero .image-field img, .tone-cinema .image-field img, .tone-closing .image-field img { inset: 0; width: 100%; height: 100%; min-height: 0; transform: scale(1.03); opacity: .54; -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,.30) 20%, #000 54%, rgba(0,0,0,.72) 100%); mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,.30) 20%, #000 54%, rgba(0,0,0,.72) 100%); }
  .tone-hero::after, .tone-cinema::after, .tone-closing::after { background: linear-gradient(90deg, rgba(252,249,241,.96) 0%, rgba(252,249,241,.82) 38%, rgba(252,249,241,.38) 70%, rgba(252,249,241,.68) 100%), radial-gradient(circle at 72% 32%, rgba(176,139,72,.20), transparent 34%); }
  .tone-cinema { background: #f8f3e9; }
  .tone-warm { background: linear-gradient(120deg, #fbfaf6 0%, #f4eadb 48%, #eaddc7 100%); }
  .paper-grain { position: absolute; inset: 0; z-index: -2; opacity: .32; pointer-events: none; background-image: radial-gradient(rgba(84,63,34,.10) .7px, transparent .7px); background-size: 4px 4px; mix-blend-mode: multiply; }
  .deck-topbar { position: fixed; top: clamp(1rem, 2vw, 2rem); left: clamp(1.25rem, 4vw, 4rem); right: clamp(1.25rem, 4vw, 4rem); z-index: 8; display: flex; align-items: center; justify-content: space-between; gap: 1rem; pointer-events: none; }
  .brand-lockup { pointer-events: auto; display: inline-flex; align-items: center; gap: .8rem; min-height: 3.4rem; padding: .74rem 1.08rem; border: 1px solid rgba(173,139,76,.26); border-radius: 999px; background: rgba(255,255,255,.76); color: #16130e; text-decoration: none; backdrop-filter: blur(18px); box-shadow: 0 22px 70px rgba(62,48,26,.12); }
  .brand-logo-img { display: block; width: clamp(132px, 11vw, 178px); height: auto; object-fit: contain; }
  .hero-logo-img { display: block; width: clamp(190px, 20vw, 320px); height: auto; object-fit: contain; }
  .hero-logo { min-height: clamp(3.2rem, 5vw, 5.4rem); }
  .deck-label { pointer-events: none; padding: .82rem 1rem; border: 1px solid rgba(173,139,76,.18); border-radius: 999px; color: rgba(41,35,25,.64); background: rgba(255,255,255,.58); backdrop-filter: blur(14px); font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; }
  .slide-shell { width: min(1160px, 100%); margin-inline: auto; display: grid; grid-template-columns: minmax(0, 1fr); align-items: center; }
  .story-content { position: relative; z-index: 2; max-width: min(760px, 62vw); opacity: .74; transform: translateY(18px); transition: opacity .72s ease, transform .72s ease; }
  .tone-reverse .story-content, .tone-light.reverse .story-content, .tone-warm.reverse .story-content { margin-left: auto; }
  .presentation-slide.is-active .story-content { opacity: 1; transform: translateY(0); }
  .hero-logo { display: inline-flex; align-items: center; gap: .95rem; margin: 0 0 clamp(1.1rem, 2vw, 1.8rem); color: #15120d; font-size: clamp(1.25rem, 2vw, 2rem); }
  .eyebrow { display: inline-flex; align-items: center; gap: .75rem; margin: 0 0 clamp(.95rem,1.6vw,1.22rem); color: #a27631; font-size: .72rem; line-height: 1; letter-spacing: .20em; text-transform: uppercase; font-weight: 600; }
  .eyebrow span { display: inline-grid; place-items: center; width: 2.15rem; height: 2.15rem; border-radius: 999px; border: 1px solid rgba(173,139,76,.34); color: #8c642b; background: rgba(255,255,255,.52); letter-spacing: .04em; }
  h1 { max-width: 15.6ch; margin: 0; font-family: Cinzel, Georgia, serif; font-size: clamp(2.25rem, 4.28vw, 5.15rem); font-weight: 400; line-height: .98; letter-spacing: -.045em; color: #17130d; text-wrap: balance; }
  .lead { max-width: 49rem; margin: clamp(1rem,1.8vw,1.35rem) 0 0; color: rgba(34,28,20,.78); font-family: Cormorant Garamond, Georgia, serif; font-size: clamp(1.23rem,1.55vw,1.55rem); line-height: 1.36; text-wrap: balance; }
  .chip-row { display: flex; flex-wrap: wrap; gap: .56rem; margin-top: 1.3rem; }
  .chip-row span { padding: .66rem .88rem; border: 1px solid rgba(173,139,76,.22); border-radius: 999px; background: rgba(255,255,255,.50); color: rgba(42,35,24,.70); backdrop-filter: blur(12px); font-size: .76rem; letter-spacing: .02em; }
  .detail-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .62rem; margin: 1.16rem 0 0; padding: 0; list-style: none; }
  .detail-list li { position: relative; padding: .82rem .9rem .82rem 1.66rem; border: 1px solid rgba(173,139,76,.18); border-radius: 1.1rem; background: rgba(255,255,255,.48); color: rgba(35,29,21,.72); font-size: .9rem; line-height: 1.38; backdrop-filter: blur(12px); box-shadow: 0 18px 60px rgba(79,61,33,.06); }
  .detail-list li::before { content: ""; position: absolute; left: .82rem; top: 1.14rem; width: .38rem; height: .38rem; border-radius: 999px; background: #b48b45; }
  .slide-footer { position: absolute; left: clamp(1.25rem,4vw,4rem); right: clamp(1.25rem,4vw,4rem); bottom: clamp(1rem,2vw,2rem); z-index: 3; display: flex; justify-content: space-between; gap: 1rem; color: rgba(50,42,30,.50); font-size: .68rem; letter-spacing: .12em; text-transform: uppercase; pointer-events: none; }
  .slide-rail { position: fixed; top: 50%; right: clamp(1rem,2vw,2rem); z-index: 7; display: grid; gap: .42rem; transform: translateY(-50%); }
  .rail-item { width: 8.7rem; display: grid; grid-template-columns: 1.8rem 1fr; align-items: center; gap: .48rem; padding: .46rem; border: 1px solid rgba(173,139,76,.16); border-radius: 999px; background: rgba(255,255,255,.54); backdrop-filter: blur(16px); color: rgba(45,37,25,.62); text-decoration: none; transition: transform .28s ease, border-color .28s ease, background .28s ease, color .28s ease; box-shadow: 0 18px 52px rgba(69,53,28,.08); }
  .rail-item span { width: 1.8rem; height: 1.8rem; display: inline-grid; place-items: center; border-radius: 999px; background: rgba(180,139,69,.08); color: rgba(120,88,38,.78); font-size: .62rem; font-weight: 700; }
  .rail-item strong { font-size: .68rem; font-weight: 600; }
  .rail-item.active { transform: translateX(-.18rem); color: #18140f; border-color: rgba(180,139,69,.55); background: rgba(255,255,255,.86); }
  .rail-item.active span { background: rgba(180,139,69,.16); color: #8f6429; }
  @media (prefers-reduced-motion: reduce) { :global(html) { scroll-behavior: auto; } .story-content, .rail-item { transition: none; } }
  @media (min-width:1081px) { .presentation-slide { padding-right: clamp(10.5rem,13vw,14rem); } .slide-footer { right: clamp(10.5rem,13vw,14rem); } }
  @media (max-width:1080px) { .slide-rail { display: none; } .deck-label { display:none; } .presentation-slide { align-items: start; padding-top: 8rem; min-height: auto; } .presentation-slide::before { inset: .8rem; } .story-content, .tone-reverse .story-content, .tone-light.reverse .story-content, .tone-warm.reverse .story-content { max-width: 100%; margin-left: 0; padding: 0; } .image-field img, .tone-reverse .image-field img, .tone-light.reverse .image-field img, .tone-warm.reverse .image-field img { width: 100%; min-height: 0; right: 0; left: 0; opacity: .24; -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,.72), transparent 76%); mask-image: linear-gradient(180deg, rgba(0,0,0,.72), transparent 76%); } .slide-footer { position: relative; left: auto; right: auto; bottom: auto; margin-top: 2rem; } }
  @media (max-width:680px) { .presentation-slide { padding: 7.15rem 1.25rem 1.6rem; } .deck-topbar { position: absolute; } .brand-name { font-size: 1rem; } .hero-logo-img { width: clamp(168px, 46vw, 245px); } h1 { font-size: clamp(2.25rem,10.2vw,4rem); max-width: 12.8ch; } .lead { font-size: 1.16rem; } .detail-list { grid-template-columns: 1fr; } .slide-footer { display:none; } }
</style>
