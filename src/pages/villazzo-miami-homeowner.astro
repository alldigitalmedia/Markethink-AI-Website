  {
    n: "04",
    id: "villazzo-standard",
    nav: "Standard",
    kicker: "THE VILLAZZO STANDARD",
    title: "The privacy of a villa. The service rhythm of a five-star hotel.",
    lead: "A premium guest is not simply renting a house. They expect arrival, comfort, service, privacy, and detail to feel effortless from the first moment.",
    image: images.arrival,
    tone: "cinema",
    note: "Five-star villa experience",
    chips: ["Private arrival", "Concierge readiness", "Discreet service", "Luxury detail"],
  },
  {
    n: "05",
