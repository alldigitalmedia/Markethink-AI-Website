---
import Layout from "../layouts/Layout.astro";

const deckUrl = "https://markethink.ai/villazzo-miami-homeowner/";
const images = {
  villa: "https://dashboard.markethink.ai/generated/landing/markethink/villazzo-miami-homeowner/01-miami-villa.png",
  staff: "https://dashboard.markethink.ai/generated/landing/markethink/villazzo-miami-homeowner/02-staff-prep.png",
  advisory: "https://dashboard.markethink.ai/generated/landing/markethink/villazzo-miami-homeowner/03-owner-advisory.png",
  arrival: "https://dashboard.markethink.ai/generated/landing/markethink/villazzo-miami-homeowner/04-evening-arrival.png",
};

const slides = [
  {
    n: "01",
    id: "opening",
    nav: "Opening",
    kicker: "PRIVATE OWNER PRESENTATION · MIAMI",
    title: "Your Miami property, managed as a private five-star residence.",
    lead: "Villazzo brings the discipline of luxury hospitality to private villa ownership: care, readiness, presentation, and premium rental performance handled with discretion.",
    image: images.villa,
    layout: "hero",
    backgroundOnly: true,
    note: "Private villa management",
    chips: ["Miami", "Luxury villa care", "Five-star service", "Owner peace of mind"],
  },
  {
    n: "02",
    id: "opportunity",
    nav: "Opportunity",
    kicker: "SLIDE 02 · THE OWNER OPPORTUNITY",
    title: "A luxury home should perform without becoming a burden.",
    lead: "The right management partner protects the residence, elevates its market position, and unlocks qualified rental demand while the owner stays removed from the day-to-day operational pressure.",
    image: images.advisory,
    layout: "split",
    backgroundOnly: false,
    note: "Performance without friction",
    chips: ["Protect the asset", "Reduce oversight", "Elevate positioning", "Create demand"],
    details: [
      "Keep the property ready for owner use and premium guests",
      "Coordinate care, presentation, and service standards",
      "Position the home for the right rental audience",
      "Give the owner a clearer, calmer management relationship",
    ],
  },
  {
    n: "03",
    id: "beyond-maintenance",
    nav: "Beyond maintenance",
    kicker: "SLIDE 03 · WHY ORDINARY MANAGEMENT IS NOT ENOUGH",
    title: "Luxury homes need more than maintenance. They need hospitality discipline.",
    lead: "Basic property management keeps the lights on. Villazzo prepares the residence as a private five-star environment: the home, the team, the guest experience, the revenue strategy, and the owner relationship working together.",
    image: images.staff,
    layout: "library",
    backgroundOnly: false,
    note: "Care plus experience",
    chips: ["Readiness", "Staffing", "Guest preparation", "Service standards"],
    details: [
      "Pre-arrival preparation with luxury hospitality expectations",
      "Housekeeping, culinary, concierge, and service coordination",
      "Consistent presentation before each guest or owner stay",
      "Operational detail handled quietly in the background",
    ],
  },
  {
    n: "04",
    id: "villazzo-standard",
    nav: "Standard",
    kicker: "SLIDE 04 · THE VILLAZZO STANDARD",
    title: "The privacy of a villa. The service rhythm of a five-star hotel.",
    lead: "Villazzo understands that a premium guest is not simply renting a house. They expect arrival, comfort, service, privacy, and detail to feel effortless from the first moment.",
    image: images.arrival,
    layout: "cinema",
    backgroundOnly: true,
    note: "Five-star villa experience",
    chips: ["Private arrival", "Concierge readiness", "Discreet service", "Luxury detail"],
  },
  {
    n: "05",
    id: "revenue",
    nav: "Revenue",
    kicker: "SLIDE 05 · PREMIUM REVENUE GENERATION",
    title: "Positioned for discerning luxury renters, not generic traffic.",
    lead: "Villazzo’s strength is understanding how to present, price, and position luxury villas for qualified guests who value service, privacy, destination, and a property prepared to the highest standard.",
    image: images.villa,
    layout: "split reverse",
    backgroundOnly: false,
    note: "Qualified demand",
    chips: ["Premium positioning", "Luxury renters", "Occupancy strategy", "Market knowledge"],
    details: [
      "Shape the property story around the home’s strongest features",
      "Attract guests who understand the value of private-villa service",
      "Use high-end presentation to support premium rental expectations",
      "Balance revenue ambition with long-term asset care",
    ],
  },
  {
    n: "06",
    id: "protection",
    nav: "Protection",
    kicker: "SLIDE 06 · PROPERTY CARE AND UPKEEP",
    title: "A pristine residence, ready year-round.",
    lead: "A Miami luxury home needs continuous attention: climate, waterfront exposure, staffing, cleaning, vendor coordination, owner readiness, and guest turnover. Villazzo manages the details before they become owner problems.",
    image: images.staff,
    layout: "library reverse",
    backgroundOnly: false,
    note: "Preserve the asset",
    chips: ["Year-round care", "Vendor coordination", "Turnover readiness", "Owner standards"],
    details: [
      "Coordinate upkeep around the property’s specific needs",
      "Maintain presentation standards across every room and exterior area",
      "Prepare the residence for private use or premium rental stays",
      "Protect the long-term value of the home through consistent attention",
    ],
  },
  {
    n: "07",
    id: "miami",
    nav: "Miami",
    kicker: "SLIDE 07 · MIAMI MARKET CONTEXT",
    title: "Local execution for a global luxury audience.",
    lead: "Miami attracts guests who expect waterfront living, privacy, access, service, and speed. Villazzo combines local operational knowledge with a global luxury-villa perspective.",
    image: images.villa,
    layout: "cinema soft",
    backgroundOnly: true,
    note: "Miami, managed precisely",
    chips: ["Waterfront living", "Global demand", "Local operations", "Private service"],
  },
  {
    n: "08",
    id: "personalized",
    nav: "Personalized",
    kicker: "SLIDE 08 · BESPOKE OWNER RELATIONSHIP",
    title: "Managed around your property, your standards, and your goals.",
    lead: "Every home has its own rhythm. Villazzo builds the management plan around the property’s architecture, owner preferences, rental goals, staffing needs, guest expectations, and level of desired involvement.",
    image: images.advisory,
    layout: "split",
    backgroundOnly: false,
    note: "Bespoke management",
    chips: ["Owner preferences", "Property character", "Rental goals", "Service profile"],
    details: [
      "Define what should happen before, during, and after each stay",
      "Align service standards with the owner’s expectations",
      "Protect the home’s privacy, presentation, and long-term quality",
      "Create one clear relationship for operational decisions",
    ],
  },
  {
    n: "09",
    id: "experience",
    nav: "Experience",
    kicker: "SLIDE 09 · GUEST EXPERIENCE",
    title: "The stay should feel effortless before the guest ever walks in.",
    lead: "From arrival to daily service, the strongest luxury rentals feel prepared, personal, and calm. Villazzo turns the home into a complete private-villa experience rather than a transactional rental.",
    image: images.arrival,
    layout: "library",
    backgroundOnly: false,
    note: "Prepared, personal, calm",
    chips: ["Arrival", "Concierge", "House team", "Guest comfort"],
    details: [
      "Prepare the home so the first impression feels immediate and complete",
      "Coordinate services that match the guest profile and occasion",
      "Maintain privacy and discretion throughout the stay",
      "Make the property feel like a private five-star residence",
    ],
  },
  {
    n: "10",
    id: "closing",
    nav: "Next step",
    kicker: "SLIDE 10 · NEXT STEP",
    title: "Let Villazzo unlock the full potential of your Miami home.",
    lead: "With Villazzo, the owner gains a partner focused on protection, presentation, guest experience, and premium rental performance — with the day-to-day complexity handled quietly and professionally.",
    image: images.villa,
    layout: "closing",
    backgroundOnly: true,
    note: "Discuss the right management plan",
    chips: ["Protect", "Prepare", "Position", "Perform"],
  },
];
---

<Layout
  title="Villazzo Miami Property Management · Private Owner Presentation"
  description="A private Villazzo presentation for a Miami luxury homeowner considering property management."
  image={images.villa}
  canonical={deckUrl}
  noindex={true}
>
  <main class="villazzo-deck" aria-label="Villazzo private Miami homeowner presentation">
    <header class="deck-topbar">
      <a href="#opening" class="brand-lockup" aria-label="Villazzo presentation home">
        <span class="brand-mark">V</span>
        <span class="brand-name">Villazzo</span>
      </a>
      <span class="deck-label">Private owner presentation · Miami</span>
    </header>

    <aside class="slide-rail" aria-label="Presentation sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} class={`rail-item ${slide.n === '01' ? 'active' : ''}`} data-slide-link={slide.id} aria-current={slide.n === '01' ? 'step' : undefined}>
          <span>{slide.n}</span><strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide, index) => (
      <section id={slide.id} data-slide-id={slide.id} data-slide-index={index} class={`presentation-slide layout-${slide.layout} ${slide.backgroundOnly ? 'background-led' : ''} ${slide.n === '01' ? 'is-active' : ''}`} aria-label={`Slide ${slide.n}: ${slide.nav}`}>
        <div class="slide-background" aria-hidden="true">
          {slide.backgroundOnly && <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />}
        </div>
        <div class="slide-overlay" aria-hidden="true"></div>

        <div class="slide-shell">
          <div class="story-content">
            <p class="eyebrow">{slide.kicker}</p>
            {slide.n === '01' && (
              <div class="hero-wordmark" aria-label="Villazzo">
                <span class="hero-v">V</span>
                <span>Villazzo</span>
              </div>
            )}
            <h1>{slide.title}</h1>
            <p class="lead">{slide.lead}</p>
            <div class="chip-row" aria-label="Key points">
              {slide.chips.map((chip) => <span>{chip}</span>)}
            </div>
            {slide.details && (
              <ul class="detail-list" aria-label="Section details">
                {slide.details.map((item) => <li>{item}</li>)}
              </ul>
            )}
            <div class="context-note">Villazzo · {slide.note}</div>
          </div>

          {!slide.backgroundOnly && (
            <div class="visual-stack">
              <figure class="visual-card">
                <img src={slide.image} alt="" loading="lazy" decoding="async" />
                <figcaption><span class="mini-mark">V</span><strong>Villazzo</strong><em>{slide.note}</em></figcaption>
              </figure>
            </div>
          )}
        </div>

        <div class="slide-footer">
          <span>{slide.n} / {slide.nav}</span>
          <span>{slide.note}</span>
        </div>
      </section>
    ))}
  </main>
</Layout>

<script is:inline>
  (() => {
    const slides = Array.from(document.querySelectorAll('.presentation-slide[data-slide-id]'));
    const railItems = Array.from(document.querySelectorAll('.rail-item[data-slide-link]'));
    if (!slides.length || !railItems.length) return;
    const setActiveSlide = (id) => {
      railItems.forEach((item) => {
        const isActive = item.dataset.slideLink === id;
        item.classList.toggle('active', isActive);
        if (isActive) item.setAttribute('aria-current', 'step');
        else item.removeAttribute('aria-current');
      });
      slides.forEach((slide) => slide.classList.toggle('is-active', slide.dataset.slideId === id));
    };
    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible?.target?.dataset?.slideId) setActiveSlide(visible.target.dataset.slideId);
    }, { threshold: [0.32, 0.48, 0.64], rootMargin: '-18% 0px -36% 0px' });
    slides.forEach((slide) => observer.observe(slide));
  })();
</script>

<style>
  :global(html) { background: #080807; scroll-behavior: smooth; }
  .villazzo-deck { min-height: 100vh; overflow-x: hidden; background: #080807; color: #f8f4eb; font-family: var(--font-body); }
  .presentation-slide { position: relative; min-height: 100svh; isolation: isolate; display: grid; align-items: center; padding: clamp(6.8rem, 9vh, 8.2rem) clamp(1.35rem, 5vw, 5rem) clamp(5rem, 7vh, 6.4rem); overflow: hidden; background: #080807; scroll-margin-top: 0; }
  .slide-background, .slide-overlay { position: absolute; inset: 0; }
  .slide-background { z-index: -4; }
  .slide-background img { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: .78; filter: saturate(.86) contrast(1.08) brightness(.74); transform: scale(1.02); }
  .slide-overlay { z-index: -3; background: radial-gradient(circle at 72% 35%, rgba(190, 150, 82, .22), transparent 28%), linear-gradient(90deg, rgba(8,8,7,.98) 0%, rgba(8,8,7,.88) 34%, rgba(8,8,7,.52) 68%, rgba(8,8,7,.26) 100%), linear-gradient(180deg, rgba(8,8,7,.12), rgba(8,8,7,.82)); }
  .deck-topbar { position: fixed; top: clamp(1rem, 2vw, 2rem); left: clamp(1.25rem, 4vw, 4rem); right: clamp(1.25rem, 4vw, 4rem); z-index: 8; display: flex; align-items: center; justify-content: space-between; gap: 1rem; pointer-events: none; }
  .brand-lockup { pointer-events: auto; display: inline-flex; align-items: center; gap: .76rem; min-height: 3.15rem; padding: .78rem 1.08rem .78rem .78rem; border: 1px solid rgba(248,244,235,.18); border-radius: 999px; background: rgba(8,8,7,.68); color: #f8f4eb; text-decoration: none; backdrop-filter: blur(18px); box-shadow: 0 24px 80px rgba(0,0,0,.34); }
  .brand-mark, .hero-v, .mini-mark { display: inline-grid; place-items: center; width: 2rem; height: 2rem; border-radius: 999px; background: linear-gradient(145deg, #c8a35c, #f2dfaa); color: #080807; font-family: Georgia, serif; font-weight: 700; }
  .brand-name { font-family: Georgia, 'Times New Roman', serif; font-size: 1.25rem; letter-spacing: .08em; text-transform: uppercase; }
  .deck-label { pointer-events: none; padding: .78rem 1rem; border: 1px solid rgba(248,244,235,.13); border-radius: 999px; color: rgba(248,244,235,.66); background: rgba(8,8,7,.52); backdrop-filter: blur(14px); font-size: .72rem; letter-spacing: .16em; text-transform: uppercase; }
  .slide-shell { width: min(1240px, 100%); margin-inline: auto; display: grid; grid-template-columns: minmax(0, .92fr) minmax(380px, .88fr); gap: clamp(2rem, 5vw, 5.5rem); align-items: center; }
  .background-led .slide-shell { grid-template-columns: 1fr; }
  .story-content { position: relative; z-index: 2; max-width: 820px; opacity: .78; transform: translateY(18px); transition: opacity .72s ease, transform .72s ease; }
  .presentation-slide.is-active .story-content { opacity: 1; transform: translateY(0); }
  .background-led .story-content { max-width: min(940px, 74vw); padding: clamp(1.2rem, 2vw, 2rem); border-left: 1px solid rgba(200,163,92,.48); background: linear-gradient(90deg, rgba(8,8,7,.62), rgba(8,8,7,.18)); backdrop-filter: blur(2px); }
  .hero-wordmark { display: inline-flex; align-items: center; gap: .75rem; margin: 0 0 1.1rem; padding: .68rem .92rem .68rem .68rem; border: 1px solid rgba(248,244,235,.18); border-radius: 999px; background: rgba(248,244,235,.06); font-family: Georgia, serif; letter-spacing: .12em; text-transform: uppercase; color: #f8f4eb; }
  .eyebrow { display: inline-flex; align-items: center; gap: .7rem; margin: 0 0 1.12rem; color: rgba(239,219,178,.80); font-size: .75rem; line-height: 1; letter-spacing: .16em; text-transform: uppercase; }
  .eyebrow::before { content: ""; width: .52rem; height: .52rem; border-radius: 999px; background: #c8a35c; box-shadow: 0 0 0 .34rem rgba(200,163,92,.13); }
  h1 { max-width: 17ch; margin: 0; font-family: Georgia, 'Times New Roman', serif; font-size: clamp(2.25rem, 4.35vw, 4.85rem); font-weight: 400; line-height: 1.02; letter-spacing: -.045em; color: #f8f4eb; text-wrap: balance; }
  .lead { max-width: 50rem; margin: clamp(.9rem,1.7vw,1.3rem) 0 0; color: rgba(248,244,235,.84); font-size: clamp(1rem,1.14vw,1.14rem); line-height: 1.5; text-wrap: balance; }
  .chip-row { display: flex; flex-wrap: wrap; gap: .56rem; margin-top: 1.15rem; }
  .chip-row span { padding: .66rem .84rem; border: 1px solid rgba(248,244,235,.14); border-radius: 999px; background: rgba(8,8,7,.54); color: rgba(248,244,235,.76); backdrop-filter: blur(12px); font-size: .8rem; }
  .detail-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .54rem; margin: 1.08rem 0 0; padding: 0; list-style: none; }
  .detail-list li { position: relative; padding: .76rem .8rem .76rem 1.56rem; border: 1px solid rgba(248,244,235,.11); border-radius: 1rem; background: rgba(8,8,7,.44); color: rgba(248,244,235,.74); font-size: .92rem; line-height: 1.36; backdrop-filter: blur(12px); }
  .detail-list li::before { content: ""; position: absolute; left: .78rem; top: 1.08rem; width: .4rem; height: .4rem; border-radius: 999px; background: #c8a35c; }
  .context-note { margin-top: 1.25rem; color: rgba(248,244,235,.54); font-size: .86rem; }
  .visual-stack { display: grid; gap: 1rem; align-items: start; }
  .visual-card { position: relative; margin: 0; border: 1px solid rgba(248,244,235,.15); border-radius: clamp(1.4rem,3vw,2.4rem); overflow: hidden; background: #11100e; box-shadow: 0 44px 120px rgba(0,0,0,.48); transform: translateY(1rem); transition: transform .72s ease, opacity .72s ease, box-shadow .72s ease; opacity: .82; }
  .presentation-slide.is-active .visual-card { opacity: 1; transform: translateY(0); box-shadow: 0 52px 150px rgba(0,0,0,.56), 0 0 0 1px rgba(200,163,92,.14); }
  .visual-card img { width: 100%; height: auto; display: block; object-fit: contain; background: #080807; }
  .visual-card figcaption { position: absolute; left: 1rem; right: 1rem; bottom: 1rem; display: flex; align-items: center; gap: .65rem; padding: .65rem .78rem; border: 1px solid rgba(248,244,235,.18); border-radius: 999px; background: rgba(8,8,7,.66); backdrop-filter: blur(16px); color: #f8f4eb; }
  .visual-card figcaption strong { font-family: Georgia, serif; letter-spacing: .1em; text-transform: uppercase; font-size: .82rem; }
  .visual-card figcaption em { margin-left: auto; color: rgba(248,244,235,.62); font-style: normal; font-size: .78rem; }
  .mini-mark { width: 1.72rem; height: 1.72rem; font-size: .9rem; }
  .layout-reverse .story-content, .layout-library.reverse .story-content { order: 2; }
  .layout-reverse .visual-stack, .layout-library.reverse .visual-stack { order: 1; }
  .layout-cinema .story-content, .layout-cinema.soft .story-content, .layout-closing .story-content { max-width: min(980px, 78vw); }
  .slide-footer { position: absolute; left: clamp(1.25rem,4vw,4rem); right: clamp(1.25rem,4vw,4rem); bottom: clamp(1rem,2vw,2rem); z-index: 3; display: flex; justify-content: space-between; gap: 1rem; color: rgba(248,244,235,.48); font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; pointer-events: none; }
  .slide-rail { position: fixed; top: 50%; right: clamp(1rem,2vw,2rem); z-index: 7; display: grid; gap: .42rem; transform: translateY(-50%); }
  .rail-item { width: 8.8rem; display: grid; grid-template-columns: 1.8rem 1fr; align-items: center; gap: .48rem; padding: .46rem; border: 1px solid rgba(248,244,235,.11); border-radius: .9rem; background: rgba(8,8,7,.50); backdrop-filter: blur(16px); color: rgba(248,244,235,.70); text-decoration: none; transition: transform .28s ease, border-color .28s ease, background .28s ease, color .28s ease; }
  .rail-item span { width: 1.8rem; height: 1.8rem; display: inline-grid; place-items: center; border-radius: .66rem; background: rgba(248,244,235,.08); color: rgba(248,244,235,.62); font-size: .64rem; font-weight: 700; }
  .rail-item strong { font-size: .72rem; font-weight: 600; }
  .rail-item.active { transform: translateX(-.18rem); color: #f8f4eb; border-color: rgba(200,163,92,.62); background: linear-gradient(90deg, rgba(200,163,92,.18), rgba(8,8,7,.64)); }
  .rail-item.active span { background: rgba(200,163,92,.18); color: #efdbb2; }
  @media (prefers-reduced-motion: reduce) { :global(html) { scroll-behavior: auto; } .story-content, .visual-card, .rail-item { transition: none; } }
  @media (min-width:1081px) { .presentation-slide { padding-right: clamp(10.5rem,13vw,14rem); } .slide-footer { right: clamp(10.5rem,13vw,14rem); } }
  @media (max-width:1080px) { .slide-rail { display: none; } .deck-label { display:none; } .presentation-slide { align-items: start; padding-top: 8rem; } .slide-shell, .background-led .slide-shell { grid-template-columns: 1fr; gap: 1.8rem; } .background-led .story-content { max-width: 100%; } .visual-card { max-width: 760px; } .slide-footer { position: relative; left: auto; right: auto; bottom: auto; margin-top: 1rem; } }
  @media (max-width:680px) { .presentation-slide { min-height: auto; padding: 7.25rem 1.25rem 1.6rem; } .deck-topbar { position: absolute; } .brand-name { font-size: 1.05rem; } h1 { font-size: clamp(2.35rem,10.5vw,4.15rem); max-width: 12.4ch; } .lead { font-size: .98rem; } .detail-list { grid-template-columns: 1fr; } .visual-card figcaption em { display: none; } .slide-footer { display:none; } .background-led .slide-background img { opacity: .44; } }
</style>
