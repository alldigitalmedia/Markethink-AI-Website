---
import Layout from "../../layouts/Layout.astro";

const heroImage = "https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-hero.jpg";
---

<Layout
  title="Markethink + Mácula — Marketing with memory"
  description="A private presentation page for enterprise teams exploring a more controlled way to organize campaigns, reviews, assets, and marketing learning."
  image="/images/hero-image.png"
  canonical="https://markethink.ai/presentacion/markethink-macula/"
  noindex={true}
>
  <main class="presentation-page" aria-label="Markethink + Mácula presentation">
    <aside class="slide-rail" aria-label="Presentation sections">
      <a href="#opening" class="rail-item active">
        <span>01</span>
        <strong>Opening</strong>
      </a>
      <span class="rail-item muted"><span>02</span><strong>Problem</strong></span>
      <span class="rail-item muted"><span>03</span><strong>System</strong></span>
      <span class="rail-item muted"><span>04</span><strong>Pilot</strong></span>
    </aside>

    <section id="opening" class="presentation-slide hero-slide">
      <div class="hero-background" aria-hidden="true">
        <img src={heroImage} alt="Abstract marketing system on a strategy table" loading="eager" decoding="async" />
      </div>
      <div class="hero-overlay" aria-hidden="true"></div>

      <header class="presentation-topbar">
        <a href="/" class="brand-wordmark" aria-label="Markethink home">Markethink</a>
        <span class="partner-lockup">Markethink + Mácula</span>
      </header>

      <div class="slide-content">
        <p class="eyebrow">PRIVATE PRESENTATION · FIRST SLIDE</p>
        <h1>Marketing that does not restart every week.</h1>
        <p class="lead">
          Markethink and Mácula propose a more controlled way to organize campaigns,
          prepare assets, manage reviews, and carry approved learning from one cycle
          into the next.
        </p>

        <div class="hero-actions" aria-label="Presentation actions">
          <a href="#opening" class="primary-action">Start the conversation</a>
          <span class="context-note">Designed for enterprise teams that need continuity, governance, and human approval.</span>
        </div>
      </div>

      <div class="slide-footer">
        <span>01 / Opening</span>
        <span>System + strategic technology partner</span>
      </div>
    </section>
  </main>
</Layout>

<style>
  :global(html) {
    background: #0f1213;
  }

  .presentation-page {
    min-height: 100vh;
    background: #0f1213;
    color: #f5f5f1;
    overflow: hidden;
  }

  .presentation-slide {
    position: relative;
    min-height: 100vh;
    isolation: isolate;
    display: grid;
    align-items: center;
    padding: clamp(1.25rem, 2vw, 2rem) clamp(1.25rem, 4vw, 4rem);
  }

  .hero-background,
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .hero-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    z-index: -1;
    background:
      radial-gradient(circle at 66% 42%, rgba(105, 210, 84, 0.14), transparent 32%),
      radial-gradient(circle at 79% 73%, rgba(243, 216, 50, 0.08), transparent 22%),
      linear-gradient(90deg, rgba(15, 18, 19, 0.98) 0%, rgba(15, 18, 19, 0.9) 29%, rgba(15, 18, 19, 0.48) 57%, rgba(15, 18, 19, 0.2) 100%);
  }

  .presentation-topbar {
    position: fixed;
    top: clamp(1rem, 2vw, 2rem);
    left: clamp(1.25rem, 4vw, 4rem);
    right: clamp(1.25rem, 4vw, 4rem);
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    pointer-events: none;
  }

  .brand-wordmark,
  .partner-lockup {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    min-height: 2.4rem;
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(245, 245, 241, 0.12);
    border-radius: 999px;
    background: rgba(15, 18, 19, 0.54);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    color: rgba(245, 245, 241, 0.88);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .partner-lockup {
    color: #f5f5f1;
  }

  .partner-lockup::after {
    content: "";
    width: 0.48rem;
    height: 0.48rem;
    margin-left: 0.65rem;
    border-radius: 999px;
    background: #f3d832;
    box-shadow: 0 0 0 0.28rem rgba(243, 216, 50, 0.12);
  }

  .slide-content {
    width: min(690px, 100%);
    padding-top: 4rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.3rem;
    color: rgba(237, 244, 234, 0.72);
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: "";
    width: 0.52rem;
    height: 0.52rem;
    border-radius: 999px;
    background: #69d254;
    box-shadow: 0 0 0 0.32rem rgba(105, 210, 84, 0.12);
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: clamp(4rem, 9vw, 8.9rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.075em;
    color: #f5f5f1;
  }

  .lead {
    max-width: 44rem;
    margin-top: clamp(1.25rem, 2.5vw, 2rem);
    color: rgba(245, 245, 241, 0.78);
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .primary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.9rem 1.25rem;
    border-radius: 999px;
    background: #69d254;
    color: #0f1213;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .context-note {
    max-width: 26rem;
    color: rgba(245, 245, 241, 0.52);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .slide-footer {
    position: fixed;
    left: clamp(1.25rem, 4vw, 4rem);
    right: clamp(1.25rem, 4vw, 4rem);
    bottom: clamp(1rem, 2vw, 2rem);
    z-index: 3;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: rgba(245, 245, 241, 0.48);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .slide-rail {
    position: fixed;
    top: 50%;
    right: clamp(1rem, 2vw, 2rem);
    z-index: 5;
    display: grid;
    gap: 0.55rem;
    transform: translateY(-50%);
  }

  .rail-item {
    width: 9rem;
    display: grid;
    grid-template-columns: 2rem 1fr;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem;
    border: 1px solid rgba(245, 245, 241, 0.12);
    border-radius: 1rem;
    background: rgba(15, 18, 19, 0.52);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: rgba(245, 245, 241, 0.8);
  }

  .rail-item span {
    width: 2rem;
    height: 2rem;
    display: inline-grid;
    place-items: center;
    border-radius: 0.72rem;
    background: rgba(245, 245, 241, 0.08);
    color: rgba(245, 245, 241, 0.66);
    font-size: 0.68rem;
    font-weight: 700;
  }

  .rail-item strong {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .rail-item.active {
    border-color: rgba(105, 210, 84, 0.44);
    box-shadow: 0 0 0 1px rgba(105, 210, 84, 0.12), 0 24px 60px rgba(0, 0, 0, 0.24);
  }

  .rail-item.active span {
    background: rgba(105, 210, 84, 0.16);
    color: #69d254;
  }

  .rail-item.muted {
    opacity: 0.42;
  }

  @media (max-width: 980px) {
    .presentation-slide {
      padding-right: clamp(1.25rem, 4vw, 4rem);
    }

    .slide-rail {
      display: none;
    }

    h1 {
      max-width: 11ch;
      font-size: clamp(3.8rem, 16vw, 7rem);
    }
  }

  @media (max-width: 680px) {
    .hero-overlay {
      background:
        linear-gradient(180deg, rgba(15, 18, 19, 0.7) 0%, rgba(15, 18, 19, 0.96) 46%, rgba(15, 18, 19, 1) 100%);
    }

    .presentation-topbar {
      position: absolute;
      align-items: flex-start;
    }

    .brand-wordmark {
      display: none;
    }

    .slide-content {
      align-self: end;
      padding-top: 9rem;
      padding-bottom: 5rem;
    }

    .hero-actions {
      align-items: flex-start;
      flex-direction: column;
    }

    .slide-footer {
      position: absolute;
      flex-direction: column;
    }
  }
</style>
