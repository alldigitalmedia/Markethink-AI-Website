    "n": "04",
    "id": "system",
    "nav": "Markethink",
    "kicker": "SLIDE 04 · MEET MARKETHINK",
    "title": "Markethink organiza la operación de marketing en un solo sistema.",
    "lead": "Aprende el negocio, estructura campañas, genera activos, ordena aprobaciones, conecta seguimiento y conserva memoria de lo que funciona.",
