    "layout": "hero",
    "backgroundOnly": true,
    "next": "problem",
    "action": "Siguiente",
    "note": "La tensión ejecutiva",
    "chips": [
      "Escala",
      "Continuidad",
      "Menos fricción"
    ]
  },
  {
    "n": "02",
    "id": "problem",
    "nav": "Problema",
    "kicker": "SLIDE 02 · DOLOR OPERATIVO",
    "title": "El equipo no está haciendo marketing. Está persiguiendo piezas sueltas.",
    "lead": "Briefs en un lugar. Diseños en otro. Aprobaciones por chat. CRM desconectado. Campañas sin memoria. Antes de mover la campaña, el equipo ya está administrando desorden.",
    "image": "https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-slide-2.png",
    "layout": "split",
    "backgroundOnly": true,
    "next": "cost",
    "action": "Siguiente",
