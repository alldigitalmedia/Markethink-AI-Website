<Layout
  title="Markethink + Mácula — Marketing con memoria"
  description="Una página privada de presentación para equipos empresariales que exploran una forma más controlada de organizar campañas, revisiones, activos y aprendizaje de marketing."
  image="https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-hero.jpg"
  canonical="https://markethink.ai/presentacion/markethink-macula/"
  noindex={true}
>
  <main class="presentation-page" aria-label="Presentación Markethink + Mácula">
    <header class="presentation-topbar">
      <a href="/" class="logo-lockup" aria-label="Markethink y Mácula">
        <img src="/images/logo.svg" alt="Markethink" class="markethink-logo" />
        <span class="logo-plus" aria-hidden="true">+</span>
        <span class="macula-logo" aria-label="Mácula" set:html={maculaLogoSvg} />
      </a>
      <span class="deck-label">Presentación privada</span>
    </header>

    <aside class="slide-rail" aria-label="Secciones de la presentación">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} class={`rail-item ${slide.n === '01' ? 'active' : ''}`}>
          <span>{slide.n}</span><strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} class={`presentation-slide layout-${slide.layout}`} aria-label={`Slide ${slide.n}: ${slide.nav}`}>
        <div class="slide-background" aria-hidden="true">
          <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
        </div>
        <div class="slide-overlay" aria-hidden="true"></div>
        <div class="motion-field" aria-hidden="true"><span></span><span></span><span></span><span></span></div>

        <div class="slide-shell">
          <div class="story-content">
            <p class="eyebrow">{slide.kicker}</p>
            <h1>{slide.title}</h1>
            <p class="lead">{slide.lead}</p>
            <div class="chip-row" aria-label="Puntos clave">
              {slide.chips.map((chip) => <span>{chip}</span>)}
            </div>
            <div class="hero-actions" aria-label="Acciones de presentación">
              <a href={`#${slide.next}`} class="primary-action">{slide.action}</a>
              <span class="context-note">Markethink × Mácula · {slide.note}</span>
            </div>
          </div>

          <div class="visual-card" aria-hidden="true">
            <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
          </div>
        </div>

        <div class="slide-footer">
          <span>{slide.n} / {slide.nav}</span>
          <span>{slide.note}</span>
        </div>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(html) { background: #0f1213; scroll-behavior: smooth; }
  .presentation-page { background: #0f1213; color: #f5f5f1; overflow-x: hidden; }
  .presentation-slide { position: relative; min-height: 100vh; isolation: isolate; display: grid; align-items: center; padding: clamp(1.4rem, 2vw, 2rem) clamp(1.3rem, 5vw, 5rem); background: #0f1213; overflow: hidden; }
  .slide-background, .slide-overlay, .motion-field { position: absolute; inset: 0; }
  .slide-background { z-index: -4; }
  .slide-background img { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.23; filter: saturate(0.82) contrast(1.08); transform: scale(1.04); }
  .slide-overlay { z-index: -3; background: radial-gradient(circle at var(--hot-x, 72%) var(--hot-y, 48%), rgba(105,210,84,.18), transparent 28%), radial-gradient(circle at 88% 78%, rgba(243,216,50,.10), transparent 22%), linear-gradient(90deg, rgba(15,18,19,.98) 0%, rgba(15,18,19,.78) 46%, rgba(15,18,19,.42) 100%), linear-gradient(180deg, rgba(15,18,19,.14), rgba(15,18,19,.84)); }
  .motion-field { z-index: -2; opacity: .58; background-image: linear-gradient(rgba(245,245,241,.055) 1px, transparent 1px), linear-gradient(90deg, rgba(245,245,241,.055) 1px, transparent 1px); background-size: 72px 72px; mask-image: radial-gradient(circle at 62% 50%, black, transparent 76%); }
  .motion-field span { position: absolute; width: .55rem; height: .55rem; border-radius: 999px; background: #69d254; box-shadow: 0 0 0 .42rem rgba(105,210,84,.13); }
  .motion-field span:nth-child(1){ top: 22%; left: 20%; } .motion-field span:nth-child(2){ top: 30%; right: 28%; background:#f3d832; box-shadow:0 0 0 .42rem rgba(243,216,50,.11);} .motion-field span:nth-child(3){ bottom:24%; left:38%; } .motion-field span:nth-child(4){ bottom:18%; right:17%; background:#f3d832; box-shadow:0 0 0 .42rem rgba(243,216,50,.11); }
  .presentation-topbar { position: fixed; top: clamp(1rem, 2vw, 2rem); left: clamp(1.25rem, 4vw, 4rem); right: clamp(1.25rem, 4vw, 4rem); z-index: 8; display:flex; align-items:center; justify-content:space-between; pointer-events:none; }
  .logo-lockup { pointer-events:auto; display:inline-flex; align-items:center; gap:.85rem; min-height:3.1rem; padding:.7rem 1rem; border:1px solid rgba(245,245,241,.13); border-radius:999px; background:rgba(15,18,19,.66); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); box-shadow:0 18px 70px rgba(0,0,0,.28); }
  .markethink-logo{ height:1.15rem; width:auto; filter:brightness(0) invert(1); } .logo-plus{ display:inline-grid; place-items:center; width:1.25rem; height:1.25rem; border-radius:999px; background:rgba(105,210,84,.14); color:#69d254; font-size:.95rem; font-weight:600; line-height:1; } .macula-logo, .macula-logo :global(svg){ display:inline-flex; align-items:center; height:2.18rem; width:auto; }
  .deck-label { pointer-events:none; padding:.75rem 1rem; border:1px solid rgba(245,245,241,.11); border-radius:999px; color:rgba(245,245,241,.58); background:rgba(15,18,19,.44); backdrop-filter:blur(14px); font-size:.72rem; letter-spacing:.16em; text-transform:uppercase; }
  .slide-shell { width:min(1280px, 100%); margin-inline:auto; display:grid; grid-template-columns:minmax(0, .95fr) minmax(340px, .9fr); gap:clamp(2rem,5vw,5.5rem); align-items:center; padding-top:5.5rem; }
  .story-content{ max-width:760px; position:relative; z-index:2; }
  .eyebrow{ display:inline-flex; align-items:center; gap:.65rem; margin:0 0 1.15rem; color:rgba(237,244,234,.72); font-size:.75rem; line-height:1; letter-spacing:.16em; text-transform:uppercase; } .eyebrow::before{ content:""; width:.52rem; height:.52rem; border-radius:999px; background:#69d254; box-shadow:0 0 0 .32rem rgba(105,210,84,.12); }
  h1{ max-width:12ch; margin:0; font-family:"Instrument Serif", Georgia, serif; font-size:clamp(3.45rem,7.4vw,8rem); font-weight:400; line-height:.9; letter-spacing:-.075em; color:#f5f5f1; text-wrap:balance; }
  .lead{ max-width:48rem; margin-top:clamp(1.2rem,2.5vw,2rem); color:rgba(245,245,241,.78); font-size:clamp(1.05rem,1.42vw,1.28rem); line-height:1.58; }
  .chip-row{ display:flex; flex-wrap:wrap; gap:.65rem; margin-top:1.45rem; } .chip-row span{ padding:.68rem .86rem; border:1px solid rgba(245,245,241,.13); border-radius:999px; background:rgba(15,18,19,.55); color:rgba(245,245,241,.74); backdrop-filter:blur(12px); font-size:.8rem; }
  .hero-actions{ display:flex; align-items:center; gap:1.15rem; flex-wrap:wrap; margin-top:2rem; } .primary-action{ display:inline-flex; align-items:center; justify-content:center; min-height:3rem; padding:.9rem 1.25rem; border-radius:999px; background:#69d254; color:#0f1213; font-size:.9rem; font-weight:750; box-shadow:0 18px 45px rgba(105,210,84,.16); } .context-note{ max-width:27rem; color:rgba(245,245,241,.52); font-size:.86rem; line-height:1.45; }
  .visual-card{ position:relative; aspect-ratio:1.22; border:1px solid rgba(245,245,241,.13); border-radius:clamp(1.4rem,3vw,2.6rem); overflow:hidden; background:#141718; box-shadow:0 40px 110px rgba(0,0,0,.42); transform:translateY(1rem); }
  .visual-card::before{ content:""; position:absolute; inset:0; z-index:2; border-radius:inherit; box-shadow:inset 0 0 0 1px rgba(245,245,241,.06), inset 0 -90px 120px rgba(15,18,19,.20); pointer-events:none; }
  .visual-card::after{ content:""; position:absolute; width:32%; aspect-ratio:1; right:-10%; top:-12%; border-radius:999px; background:rgba(105,210,84,.16); filter:blur(24px); z-index:1; }
  .visual-card img{ width:100%; height:100%; object-fit:cover; display:block; transform:scale(1.012); }
  .layout-hero .slide-shell{ grid-template-columns:1fr; } .layout-hero .visual-card{ display:none; } .layout-hero .story-content{ max-width:880px; }
  .layout-split .visual-card{ aspect-ratio:1.34; transform:rotate(-1.2deg) translateY(0); }
  .layout-orbital{ --hot-x:70%; --hot-y:40%; } .layout-orbital .visual-card{ border-radius:999px 2.6rem 999px 2.6rem; transform:rotate(1.6deg); }
  .layout-product .slide-shell{ grid-template-columns:minmax(0,.82fr) minmax(460px,1.05fr); } .layout-product .visual-card{ aspect-ratio:1.48; transform:perspective(900px) rotateY(-4deg); }
  .layout-consulting .slide-shell{ grid-template-columns:minmax(430px,.98fr) minmax(0,.9fr); } .layout-consulting .story-content{ order:2; } .layout-consulting .visual-card{ order:1; aspect-ratio:1.02; transform:rotate(-2deg); }
  .layout-stacked .visual-card{ aspect-ratio:1.12; clip-path:polygon(6% 0,100% 0,94% 100%,0 100%); }
  .layout-library .slide-shell{ grid-template-columns:minmax(0,.88fr) minmax(470px,1fr); } .layout-library .visual-card{ aspect-ratio:1.08; transform:rotate(1deg) scale(1.02); }
  .layout-gates .story-content{ order:2; } .layout-gates .visual-card{ order:1; aspect-ratio:1.38; border-radius:2.8rem; }
