import Layout from "../../layouts/Layout.astro";

const slides = [{'n': '01', 'id': 'opening', 'nav': 'Apertura', 'kicker': 'PRESENTACIÓN PRIVADA · SLIDE 01', 'title': 'Marketing que no se reinicia cada semana.', 'lead': 'Markethink y Mácula proponen una forma más controlada de organizar campañas, preparar activos, gestionar revisiones y llevar el aprendizaje aprobado de un ciclo al siguiente.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-hero.jpg', 'layout': 'hero', 'next': 'problem', 'action': 'Ver el problema', 'note': 'Sistema + aliado tecnológico estratégico', 'chips': ['Continuidad', 'Criterio', 'Control humano']}, {'n': '02', 'id': 'problem', 'nav': 'Problema', 'kicker': 'SLIDE 02 · EL PROBLEMA', 'title': 'La operación se parte en demasiados lugares.', 'lead': 'En equipos grandes, el contexto vive repartido entre reuniones, documentos, agencias, áreas internas, comentarios y versiones. Antes de que el trabajo pueda volverse estratégico, la operación ya está cargando retrabajo.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-slide-2.png', 'layout': 'split', 'next': 'opportunity', 'action': 'Ver oportunidad', 'note': 'Fragmentación antes de estrategia', 'chips': ['Reuniones', 'Versiones', 'Comentarios', 'Aprobaciones']}, {'n': '03', 'id': 'opportunity', 'nav': 'Oportunidad', 'kicker': 'SLIDE 03 · LA OPORTUNIDAD', 'title': 'Convertir ejecución en memoria institucional.', 'lead': 'La oportunidad no es producir más por producir más. Es crear un sistema donde las decisiones, criterios y aprendizajes se acumulan, para que cada nuevo ciclo empiece con más contexto.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-3.png', 'layout': 'orbital', 'next': 'markethink-system', 'action': 'Ver Markethink', 'note': 'Aprendizaje que vuelve al sistema', 'chips': ['Decisiones', 'Criterios', 'Aprendizajes']}, {'n': '04', 'id': 'markethink-system', 'nav': 'Markethink', 'kicker': 'SLIDE 04 · QUÉ APORTA MARKETHINK', 'title': 'Un sistema para campañas, activos y revisión.', 'lead': 'Markethink aprende el contexto del negocio, organiza el trabajo por campañas, prepara activos para revisión y conserva el feedback aprobado para mejorar el siguiente ciclo.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-4.png', 'layout': 'product', 'next': 'macula-role', 'action': 'Ver Mácula', 'note': 'Campañas, activos, revisión y memoria', 'chips': ['Campañas', 'Activos', 'Revisión', 'Memoria']}, {'n': '05', 'id': 'macula-role', 'nav': 'Mácula', 'kicker': 'SLIDE 05 · QUÉ APORTA MÁCULA', 'title': 'Criterio tecnológico y acompañamiento consultivo.', 'lead': 'Mácula aporta la mirada estratégica y tecnológica para adaptar el sistema al contexto correcto: prioridades, stakeholders, casos de uso, narrativa y adopción.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-5.png', 'layout': 'consulting', 'next': 'alliance', 'action': 'Ver alianza', 'note': 'Criterio para implementar con contexto', 'chips': ['Prioridades', 'Stakeholders', 'Adopción']}, {'n': '06', 'id': 'alliance', 'nav': 'Alianza', 'kicker': 'SLIDE 06 · CÓMO FUNCIONA LA ALIANZA', 'title': 'Sistema + criterio + operación.', 'lead': 'Markethink estructura el flujo operativo. Mácula acompaña la lectura estratégica y la implementación del caso de uso. El equipo humano mantiene la aprobación y el criterio final.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-6.png', 'layout': 'stacked', 'next': 'use-cases', 'action': 'Ver casos de uso', 'note': 'Tres capas, una forma de trabajo', 'chips': ['Mácula · estrategia', 'Markethink · sistema', 'Equipo humano · decisión']}, {'n': '07', 'id': 'use-cases', 'nav': 'Casos de uso', 'kicker': 'SLIDE 07 · DÓNDE EMPEZAR', 'title': 'Un primer caso útil, no un despliegue gigante.', 'lead': 'La entrada correcta puede ser acotada: campañas no sensibles, piezas de comunicación, landing pages de iniciativa, kits de lanzamiento, organización de activos o memoria de aprobaciones.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-7.png', 'layout': 'library', 'next': 'governance', 'action': 'Ver gobernanza', 'note': 'Casos controlados antes de escalar', 'chips': ['Campañas', 'Landings', 'Kits', 'Revisión', 'Audiencias', 'Memoria']}, {'n': '08', 'id': 'governance', 'nav': 'Gobernanza', 'kicker': 'SLIDE 08 · GOBERNANZA', 'title': 'Control antes que velocidad.', 'lead': 'El sistema no reemplaza la revisión. La ordena. Cada pieza puede pasar por criterios definidos, aprobación humana y registro de aprendizaje antes de avanzar.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-8.png', 'layout': 'gates', 'next': 'pilot', 'action': 'Ver piloto', 'note': 'Aprobación humana y aprendizaje registrado', 'chips': ['Criterio', 'Revisión', 'Aprobación', 'Registro']}, {'n': '09', 'id': 'pilot', 'nav': 'Piloto', 'kicker': 'SLIDE 09 · PILOTO 30–45 DÍAS', 'title': 'Empezar pequeño, aprender rápido, escalar con criterio.', 'lead': 'Un piloto controlado puede definir contexto y criterios, organizar una campaña o iniciativa, crear activos revisables, registrar feedback y medir claridad, velocidad y aprendizaje.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-9.png', 'layout': 'roadmap', 'next': 'close', 'action': 'Ver cierre', 'note': 'Un primer flujo no sensible', 'chips': ['1 · Contexto', '2 · Campaña', '3 · Activos', '4 · Aprendizaje']}, {'n': '10', 'id': 'close', 'nav': 'Cierre', 'kicker': 'SLIDE 10 · CIERRE', 'title': 'Continuidad entre estrategia, ejecución, revisión y aprendizaje.', 'lead': 'No se trata de sumar otra herramienta. Se trata de crear una forma de trabajo que conserve criterio, acelere con control y haga que cada ciclo de marketing empiece más adelante que el anterior.', 'image': 'https://dashboard.markethink.ai/generated/landing/markethink/markethink-macula-dynamic-slide-10.png', 'layout': 'closing', 'next': 'opening', 'action': 'Definir primer caso de uso', 'note': 'Continuidad operativa con control humano', 'chips': ['Estrategia', 'Ejecución', 'Revisión', 'Aprendizaje']}];
