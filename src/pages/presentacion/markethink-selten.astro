const seltenLogoUrl = "https://cdn.prod.website-files.com/69b5adbcb4990ed13ab6d2cf/69b97ed5adb200b223489f34_Selten_Text_Header_Logo.svg";
const seltenMarkUrl = "https://cdn.prod.website-files.com/69b5adbcb4990ed13ab6d2cf/69b97ed5edefa7f6bcb4a5a4_logo.svg";
---

<Layout
  title="Markethink + Selten — Marketing con memoria"
  description="Una presentación privada sobre cómo Markethink y Selten ayudan a convertir campañas, activos, revisión y seguimiento en una operación de marketing continua."
  image="https://dashboard.markethink.ai/generated/landing/markethink/markethink-selten-hero.jpg"
  canonical="https://markethink.ai/presentacion/markethink-selten/"
  noindex={true}
>
  <main class="presentation-page" aria-label="Presentación Markethink + Selten">
    <header class="presentation-topbar">
      <a href="/" class="logo-lockup" aria-label="Markethink y Selten">
        <img src="/images/logo.svg" alt="Markethink" class="markethink-logo" />
        <span class="logo-plus logo-by" aria-hidden="true">&</span>
        <span class="selten-lockup" aria-label="Selten+">
          <img src={seltenMarkUrl} alt="" class="selten-mark" loading="eager" decoding="async" />
          <img src={seltenLogoUrl} alt="Selten" class="selten-logo" loading="eager" decoding="async" />
        </span>
      </a>
      <span class="deck-label">Presentación privada</span>
    </header>

    <aside class="slide-rail" aria-label="Secciones de la presentación">
      {slides.map((slide, index) => (
        <a href={`#${slide.id}`} class={`rail-item ${slide.n === '01' ? 'active' : ''}`} data-slide-link={slide.id} aria-current={slide.n === '01' ? 'step' : undefined}>
          <span>{slide.n}</span><strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide, index) => (
      <section id={slide.id} data-slide-id={slide.id} data-slide-index={index} class={`presentation-slide layout-${slide.layout} ${slide.backgroundOnly ? 'background-led' : ''} ${slide.n === '01' ? 'is-active' : ''}`} aria-label={`Slide ${slide.n}: ${slide.nav}`}>
        <div class="slide-background" aria-hidden="true">
          <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
        </div>
        <div class="slide-overlay" aria-hidden="true"></div>
        <div class="motion-field" aria-hidden="true"><span></span><span></span><span></span><span></span></div>

        <div class="slide-shell">
          <div class="story-content">
            <p class="eyebrow">{slide.kicker}</p>
            <h1 set:html={slide.title}></h1>
            <p class="lead">{slide.lead}</p>
            {slide.chips?.length > 0 && (
              <div class="chip-row" aria-label="Puntos clave">
                {slide.chips.map((chip) => <span>{chip}</span>)}
              </div>
            )}
            {slide.details && (
              <ul class="detail-list" aria-label="Detalles de la sección">
                {slide.details.map((item) => <li>{item}</li>)}
              </ul>
            )}
            <div class="hero-actions" aria-label="Acciones de presentación">
              <span class="context-note">Markethink by Selten · {slide.note}</span>
            </div>
          </div>

          {!slide.backgroundOnly && (
            <div class="visual-stack">
              {slide.videoPlayer ? (
                <div class="video-card">
                  <iframe src={slide.videoPlayer} title="Video de presentación Markethink by Selten" loading="lazy" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
                </div>
              ) : (
                <div class="visual-card" aria-hidden="true">
                  <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
                </div>
              )}
              {slide.aiCompanies && (
                <div class="ai-ecosystem" aria-label="Logos de compañías de IA evaluadas continuamente">
                  <div class="ai-logo-row">
                    {slide.aiCompanies.map((company) => (
                      <span class="ai-logo-card" aria-label={company.name}>
                        <img src={company.icon} alt="" loading="lazy" decoding="async" />
                        <strong>{company.name}</strong>
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}
        </div>

        <div class="slide-footer">
          <span>{slide.n} / {slide.nav}</span>
          <span>{slide.note}</span>
        </div>
      </section>
    ))}
  </main>
</Layout>

<script is:inline>
  (() => {
    const slides = Array.from(document.querySelectorAll('.presentation-slide[data-slide-id]'));
    const railItems = Array.from(document.querySelectorAll('.rail-item[data-slide-link]'));

    if (!slides.length || !railItems.length) return;

    const setActiveSlide = (id) => {
      railItems.forEach((item) => {
        const isActive = item.dataset.slideLink === id;
        item.classList.toggle('active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', 'step');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      slides.forEach((slide) => {
        slide.classList.toggle('is-active', slide.dataset.slideId === id);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.dataset?.slideId) {
          setActiveSlide(visible.target.dataset.slideId);
        }
      },
      {
        root: null,
        threshold: [0.28, 0.42, 0.58, 0.72],
        rootMargin: '-22% 0px -34% 0px',
      }
    );

    slides.forEach((slide) => observer.observe(slide));

    railItems.forEach((item) => {
      item.addEventListener('click', () => {
        if (item.dataset.slideLink) setActiveSlide(item.dataset.slideLink);
      });
    });
  })();
</script>

<style>
