  .logo-lockup { pointer-events:auto; display:inline-flex; align-items:center; gap:.85rem; min-height:3.1rem; padding:.7rem 1rem; border:1px solid rgba(245,245,241,.13); border-radius:999px; background:rgba(15,18,19,.66); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); box-shadow:0 18px 70px rgba(0,0,0,.28); }
  .markethink-logo{ height:1.42rem; width:auto; filter:brightness(0) invert(1); } .logo-plus{ display:inline-grid; place-items:center; width:1.35rem; height:1.35rem; border-radius:999px; background:rgba(105,210,84,.14); color:#69d254; font-size:1rem; font-weight:650; line-height:1; } .selten-lockup{ display:inline-flex; align-items:center; gap:.42rem; height:1.42rem; } .selten-mark{ width:1.42rem; height:1.42rem; object-fit:contain; flex:0 0 auto; } .selten-logo{ height:1.42rem; width:auto; object-fit:contain; display:block; }
  .deck-label { pointer-events:none; padding:.75rem 1rem; border:1px solid rgba(245,245,241,.11); border-radius:999px; color:rgba(245,245,241,.58); background:rgba(15,18,19,.44); backdrop-filter:blur(14px); font-size:.72rem; letter-spacing:.16em; text-transform:uppercase; }
  .slide-shell { width:min(1240px, 100%); margin-inline:auto; display:grid; grid-template-columns:minmax(0, .95fr) minmax(340px, .9fr); gap:clamp(2rem,5vw,5.5rem); align-items:center; padding-block:clamp(1.2rem,2.5vh,2rem); }
