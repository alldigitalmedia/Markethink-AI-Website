---
import Layout from "../layouts/Layout.astro";

const pageUrl = "https://markethink.ai/kriz-valentino-marketing-system/";
const assetBase = "https://dashboard.markethink.ai/generated/landing/markethink/kriz-valentino-marketing-system";

const images = {
  opening: `${assetBase}/01-opening.png`,
  opportunity: `${assetBase}/02-opportunity.png`,
  foundation: `${assetBase}/03-foundation.png`,
  menu: `${assetBase}/04-menu.png`,
  recommended: `${assetBase}/05-recommended.png`,
  next: `${assetBase}/06-next.png`,
};

const addOns = [
  { title: "Social Lite", price: "+$200/mo", items: ["Monthly content direction", "Hooks, captions, and post ideas", "Simple content calendar for Instagram"] },
  { title: "Leads Lite", price: "+$200/mo", items: ["Local partner and prospect ideas", "Outreach angles", "Simple follow-up tracking"] },
  { title: "SEO Lite", price: "+$200/mo", items: ["Keyword direction", "One page improvement", "Local search structure"] },
  { title: "Email / DM Lite", price: "+$200/mo", items: ["Inquiry follow-up", "Reactivation messages", "Simple nurture copy"] },
  { title: "Campaign Lite", price: "+$200/mo", items: ["One monthly offer angle", "Campaign assets mapped", "Review-ready campaign direction"] },
];

const growthExamples = [
  ["Foundation only", "$249/mo"],
  ["Foundation + 1 lane", "$449/mo"],
  ["Foundation + 2 lanes", "$649/mo"],
  ["Foundation + 3 lanes", "$849/mo"],
  ["Foundation + 4 lanes", "$1,049/mo"],
];

const slides = [
  {
    n: "01",
    id: "opening",
    nav: "Opening",
    kicker: "KRIZ VALENTINO × MARKETHINK",
    title: "Turn your coaching presence into a clear path for people to book you.",
    lead: "You already have a strong point of view: performance, kettlebell training, movement flows, and physical resilience for ambitious people. The next step is making it easy for someone who finds you to understand the offer, trust the method, and take action.",
    image: images.opening,
    tone: "hero",
    chips: ["Website foundation", "Booking path", "Monthly content", "Add-on lanes"],
  },
  {
    n: "02",
    id: "opportunity",
    nav: "Opportunity",
    kicker: "THE OPPORTUNITY",
    title: "When someone is interested, they should not have to figure out the next step on their own.",
    lead: "Right now, people can see the energy of your work. What they still need is a clean place to understand who the coaching is for, what working with you looks like, and how to reach out when they are ready.",
    image: images.opportunity,
    tone: "light",
    chips: ["Miami private coaching", "Kettlebell flows", "High-performers", "Clear booking path"],
    details: [
      "Make your private coaching offer clear from one page",
      "Give interested people a better destination than a generic link list",
      "Start building search and content around the way you train",
      "Keep updates, content ideas, approvals, and next steps organized in one place",
    ],
  },
  {
    n: "03",
    id: "foundation",
    nav: "Foundation",
    kicker: "START HERE",
    title: "Website + Marketing Foundation",
    lead: "A month-to-month base that gives you a professional booking page, one monthly content asset, and a simple workspace for keeping the business organized as it grows.",
    image: images.foundation,
    tone: "package light",
    package: {
      label: "Foundation",
      price: "$249/mo",
      note: "Month-to-month",
      scopeLabel: "Includes",
      intro: "Built as the base: your website, your offer structure, basic search setup, monthly content, and organized review.",
      groups: [
        { title: "Website", items: ["One-page coaching website or booking page", "Your private coaching offer structured clearly", "Booking/contact CTA", "Instagram link-in-bio path"] },
        { title: "Content", items: ["One monthly blog or content article included", "One monthly website update or content improvement"] },
        { title: "Search", items: ["Basic SEO title and metadata", "Page structure around your coaching offer"] },
        { title: "System", items: ["Markethink dashboard for review and approvals", "Your brand, offer, and content memory", "Monthly marketing recommendation"] },
      ],
    },
    chips: ["$249/month", "No long contract", "One monthly blog", "Dashboard included"],
    details: [
      "This is not a cheap DIY website. It is a managed marketing foundation that gives you the page, content, and review rhythm in one place.",
      "The first month stays simple: build the page, clarify the offer, publish the first content asset, and choose the next lane only when it makes sense.",
    ],
  },
  {
    n: "04",
    id: "menu",
    nav: "Add-ons",
    kicker: "ADD WHEN READY",
    title: "Start with the foundation. Add only what helps you grow next.",
    lead: "You do not need a complicated package menu. You need the right base first, then a simple way to add social, leads, search, follow-up, or campaigns when the business is ready for that next layer.",
    image: images.menu,
    tone: "system",
    addOnMenu: true,
    chips: ["Social", "Leads", "SEO", "Email / DM", "Campaigns"],
    details: [
      "Each add-on lane is priced at +$200/month",
      "You can add only the lane that matches your next priority",
      "Social helps you show up with more consistency",
      "Leads, SEO, Email / DM, and Campaigns can be added when you want more growth motion",
    ],
  },
  {
    n: "05",
    id: "recommended",
    nav: "Path",
    kicker: "RECOMMENDED FIRST BUILD",
    title: "The clean first move is simple: get your page, offer, and content base right.",
    lead: "Start with the foundation so people have a real place to understand your coaching and reach out. Once that is in place, the first add-on should be Social Lite if you want more consistency, or Leads Lite if you want more direct local opportunity work.",
    image: images.recommended,
    tone: "warm",
    growthPath: true,
    chips: ["Month 1: Foundation", "Next: Social or Leads", "Then: SEO / Email / Campaigns"],
    details: [
      "Foundation first keeps the first decision easy",
      "Social Lite turns your website offer into weekly Instagram direction",
      "Leads Lite is stronger if you want local partners and direct private-client opportunities",
      "The package grows only when the business has a reason to add more motion",
    ],
  },
  {
    n: "06",
    id: "next-step",
    nav: "Next",
    kicker: "NEXT STEP",
    title: "You should not have to rebuild your marketing from zero every month.",
    lead: "The page gets built, the content rhythm starts, decisions stay organized, and new lanes can be added only when they make sense. You keep your focus on coaching while the marketing system keeps the next step clear.",
    image: images.next,
    tone: "closing",
    chips: ["Build website", "Set booking path", "Publish first content", "Choose next lane"],
    details: [
      "Confirm the foundation structure",
      "Choose the first website sections and booking/contact path",
      "Prepare the first monthly content asset",
      "Decide whether the first add-on should be Social Lite or Leads Lite",
    ],
  },
];
---

<Layout
  title="Kriz Valentino × Markethink · Private Proposal"
  description="A private Markethink proposal presentation for Kriz Valentino."
  image={images.opening}
  canonical={pageUrl}
  noindex={true}
>
  <main class="proposal-deck" aria-label="Kriz Valentino and Markethink private proposal presentation">
    <header class="deck-topbar">
      <a href="#opening" class="brand-pair" aria-label="Kriz Valentino and Markethink presentation home">
        <span class="client-wordmark">KRIZ VALENTINO</span>
        <span class="pair-x" aria-hidden="true">×</span>
        <img class="brand-logo brand-logo-mt" src="/images/logo-white.svg" alt="Markethink" loading="eager" decoding="async" />
      </a>
      <span class="deck-label">Private proposal · website and marketing foundation</span>
    </header>

    <aside class="slide-rail" aria-label="Presentation sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} data-slide-link={slide.id}>
          <span>{slide.n}</span>
          <strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} data-slide-id={slide.id} class:list={["deck-slide", slide.tone]} style={`--slide-image: url('${slide.image}')`}>
        <div class="slide-bg" aria-hidden="true"></div>
        <div class="slide-vignette" aria-hidden="true"></div>
        <div class="slide-inner">
          {slide.kicker && <p class="slide-kicker">{slide.kicker}</p>}
          <h1>{slide.title}</h1>
          <p class="slide-lead">{slide.lead}</p>

          {slide.package && (
            <div class="package-offer" aria-label={`${slide.title} pricing and included value`}>
              <div class="price-panel">
                <span class="standard-label">Required base</span>
                <strong class="rate-value launch-price">{slide.package.price}</strong>
                <small>{slide.package.note}</small>
              </div>
              <div class="value-panel">
                <p class="package-intro">{slide.package.intro}</p>
                <span class="value-label">{slide.package.scopeLabel}</span>
                <div class="package-group-list">
                  {slide.package.groups.map((group) => (
                    <section class="package-group">
                      <strong>{group.title}</strong>
                      <ul>{group.items.map((item) => <li>{item}</li>)}</ul>
                    </section>
                  ))}
                </div>
              </div>
            </div>
          )}

          {slide.addOnMenu && (
            <div class="package-offer add-on-offer" aria-label="Add-on menu">
              <div class="price-panel">
                <span class="standard-label">Foundation</span>
                <strong class="rate-value launch-price">$249/mo</strong>
                <small>Add lanes only when ready</small>
              </div>
              <div class="value-panel">
                <p class="package-intro">Every lane is simple, monthly, and designed to expand your foundation without forcing you into a heavy retainer.</p>
                <span class="value-label">Add-on lanes · +$200/mo each</span>
                <div class="package-group-list addon-groups">
                  {addOns.map((item) => (
                    <section class="package-group addon-group">
                      <div class="addon-heading"><strong>{item.title}</strong><b>{item.price}</b></div>
                      <ul>{item.items.map((subitem) => <li>{subitem}</li>)}</ul>
                    </section>
                  ))}
                </div>
              </div>
            </div>
          )}

          {slide.growthPath && (
            <div class="package-offer growth-offer" aria-label="Example monthly builds">
              <div class="price-panel">
                <span class="standard-label">Recommended start</span>
                <strong class="rate-value launch-price">$249/mo</strong>
                <small>Foundation first, then choose the next lane.</small>
              </div>
              <div class="value-panel">
                <p class="package-intro">The menu gives you a clear path from a small start to a fuller marketing system as the coaching business grows.</p>
                <span class="value-label">Example monthly builds</span>
                <div class="path-table">
                  {growthExamples.map(([label, price]) => (
                    <div><span>{label}</span><strong>{price}</strong></div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {!slide.package && !slide.addOnMenu && !slide.growthPath && (
            <div class="chip-row">
              {slide.chips.map((chip) => <span>{chip}</span>)}
            </div>
          )}

          {slide.details && (
            <div class:list={["detail-grid", (slide.package || slide.addOnMenu || slide.growthPath) && "package-detail-grid"]}>
              {slide.details.map((detail) => <article>{detail}</article>)}
            </div>
          )}
        </div>
        <footer class="slide-footer">
          <span>{slide.n} / {slides.length.toString().padStart(2, "0")}</span>
          <span>Kriz Valentino × Markethink</span>
        </footer>
      </section>
    ))}
  </main>
</Layout>

<script>
  const links = Array.from(document.querySelectorAll("[data-slide-link]"));
  const slides = Array.from(document.querySelectorAll("[data-slide-id]"));
  const observer = new IntersectionObserver((entries) => {
    const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
    if (!visible) return;
    const id = visible.target.getAttribute("data-slide-id");
    links.forEach((link) => {
      const active = link.getAttribute("data-slide-link") === id;
      link.classList.toggle("is-active", active);
      if (active) link.setAttribute("aria-current", "step");
      else link.removeAttribute("aria-current");
    });
  }, { threshold: [0.42, 0.6, 0.78] });
  slides.forEach((slide) => observer.observe(slide));
</script>

<style>
  :global(html) { scroll-behavior: smooth; }
  :global(body) { background: #0f1213; }

  .proposal-deck {
    --charcoal: #0f1213;
    --ink: #231f1d;
    --cream: #f5f1e9;
    --warm: #edf4ea;
    --accent: #69d254;
    --accent-soft: rgba(105, 210, 84, 0.22);
    --accent-muted: #8bcf7e;
    --panel: rgba(245, 241, 233, 0.9);
    color: var(--cream);
    min-height: 100vh;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    overflow-x: hidden;
  }

  .deck-topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 34px;
    color: var(--cream);
    pointer-events: none;
  }

  .brand-pair {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    border: 1px solid rgba(245, 241, 233, 0.2);
    border-radius: 999px;
    background: rgba(15, 18, 19, 0.58);
    backdrop-filter: blur(18px);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.16);
  }

  .client-wordmark {
    color: var(--cream);
    font-size: 11px;
    line-height: 1;
    font-weight: 850;
    letter-spacing: 0.18em;
  }

  .brand-logo { display: block; object-fit: contain; height: auto; filter: none; }
  .brand-logo-mt { width: 138px; max-height: 18px; }
  .pair-x { color: rgba(245, 241, 233, 0.56); font-family: Georgia, serif; font-size: 14px; line-height: 1; transform: translateY(-1px); }

  .deck-label {
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(15, 18, 19, 0.45);
    border: 1px solid rgba(245, 241, 233, 0.18);
    color: rgba(245, 241, 233, 0.72);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    backdrop-filter: blur(18px);
  }

  .slide-rail {
    position: fixed;
    right: 26px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 42;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .slide-rail a {
    width: 118px;
    display: grid;
    grid-template-columns: 26px 1fr;
    align-items: center;
    gap: 9px;
    padding: 8px 10px;
    border-radius: 999px;
    color: rgba(245, 241, 233, 0.62);
    text-decoration: none;
    font-size: 10px;
    background: rgba(15, 18, 19, 0.34);
    border: 1px solid rgba(245, 241, 233, 0.14);
    backdrop-filter: blur(16px);
    transition: transform 0.2s ease, color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .slide-rail a:hover,
  .slide-rail a.is-active {
    color: var(--cream);
    border-color: rgba(105, 210, 84, 0.72);
    background: rgba(15, 18, 19, 0.7);
    transform: translateX(-5px);
  }

  .slide-rail span { color: var(--accent); font-weight: 750; }
  .slide-rail strong { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .deck-slide {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
    isolation: isolate;
    overflow: hidden;
    padding: 120px 160px 86px 88px;
  }

  .slide-bg,
  .slide-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .slide-bg {
    z-index: -3;
    background-image: var(--slide-image);
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
    filter: saturate(0.92) contrast(1.02);
  }

  .slide-vignette {
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(15, 18, 19, 0.92) 0%, rgba(15, 18, 19, 0.74) 39%, rgba(15, 18, 19, 0.28) 70%, rgba(15, 18, 19, 0.52) 100%),
      linear-gradient(180deg, rgba(15, 18, 19, 0.38), rgba(15, 18, 19, 0.54));
  }

  .light .slide-vignette,
  .package.light .slide-vignette {
    background:
      linear-gradient(90deg, rgba(245, 241, 233, 0.96) 0%, rgba(245, 241, 233, 0.84) 39%, rgba(237, 244, 234, 0.38) 70%, rgba(15, 18, 19, 0.28) 100%),
      linear-gradient(180deg, rgba(245, 241, 233, 0.18), rgba(15, 18, 19, 0.2));
  }

  .warm .slide-vignette {
    background:
      linear-gradient(90deg, rgba(22, 31, 24, 0.9) 0%, rgba(22, 31, 24, 0.66) 42%, rgba(22, 31, 24, 0.24) 72%, rgba(15, 18, 19, 0.45) 100%);
  }

  .closing .slide-vignette {
    background:
      linear-gradient(90deg, rgba(15, 18, 19, 0.94) 0%, rgba(15, 18, 19, 0.76) 42%, rgba(15, 18, 19, 0.3) 72%, rgba(15, 18, 19, 0.62) 100%);
  }

  .slide-inner { width: min(840px, 86vw); position: relative; z-index: 2; }
  .system .slide-inner,
  .package .slide-inner,
  .warm .slide-inner { width: min(1040px, 88vw); }

  .slide-kicker {
    margin: 0 0 18px;
    color: var(--accent);
    font-size: 12px;
    letter-spacing: 0.19em;
    text-transform: uppercase;
    font-weight: 800;
  }

  h1 {
    margin: 0;
    font-family: "Times New Roman", Georgia, serif;
    font-size: clamp(36px, 5.2vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    max-width: 940px;
    color: var(--cream);
    text-wrap: balance;
  }

  .light h1,
  .package.light h1 { color: var(--ink); }

  .slide-lead {
    margin: 26px 0 0;
    max-width: 760px;
    color: rgba(245, 241, 233, 0.82);
    font-size: clamp(18px, 2vw, 25px);
    line-height: 1.42;
    text-wrap: pretty;
  }

  .light .slide-lead,
  .package.light .slide-lead { color: rgba(35, 31, 29, 0.74); }

  .chip-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; max-width: 860px; }
  .chip-row span {
    padding: 10px 13px;
    border-radius: 999px;
    background: rgba(245, 241, 233, 0.12);
    border: 1px solid rgba(245, 241, 233, 0.2);
    color: rgba(245, 241, 233, 0.82);
    font-size: 12px;
    font-weight: 680;
  }

  .light .chip-row span,
  .package.light .chip-row span {
    background: rgba(15, 18, 19, 0.06);
    border-color: rgba(35, 31, 29, 0.12);
    color: rgba(35, 31, 29, 0.74);
  }

  .chip-row span:first-child {
    background: rgba(105, 210, 84, 0.22);
    border-color: rgba(105, 210, 84, 0.5);
    color: var(--cream);
  }

  .light .chip-row span:first-child,
  .package.light .chip-row span:first-child { color: #2d6a25; }

  .package-offer {
    --package-accent: #4e9f42;
    display: grid;
    grid-template-columns: minmax(230px, 0.42fr) minmax(620px, 1.58fr);
    gap: 0;
    align-items: stretch;
    max-width: 1160px;
    margin-top: 24px;
    border-radius: 20px;
    border: 1px solid rgba(245, 241, 233, 0.24);
    background: rgba(19, 18, 16, 0.58);
    box-shadow: 0 26px 80px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(18px);
    overflow: hidden;
  }

  .light .package-offer,
  .package.light .package-offer {
    background: rgba(250, 247, 240, 0.82);
    border-color: rgba(83, 70, 56, 0.14);
    box-shadow: 0 26px 80px rgba(83, 70, 56, 0.1);
  }

  .price-panel { display: flex; flex-direction: column; justify-content: center; padding: 28px; border-right: 1px solid rgba(245, 241, 233, 0.18); }
  .light .price-panel,
  .package.light .price-panel { border-right-color: rgba(83, 70, 56, 0.12); }
  .value-panel { padding: 24px 28px 22px; }

  .standard-label,
  .value-label {
    color: var(--package-accent);
    font-size: 10px;
    font-weight: 850;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .rate-value,
  .price-panel strong.rate-value {
    width: fit-content;
    margin-top: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: clamp(30px, 2.5vw, 42px);
    font-weight: 760;
    line-height: 1.02;
    letter-spacing: -0.045em;
    white-space: nowrap;
    color: var(--package-accent);
  }

  .price-panel small { max-width: 290px; margin-top: 12px; color: rgba(245, 241, 233, 0.68); font-size: 13px; line-height: 1.35; }
  .light .price-panel small,
  .package.light .price-panel small { color: rgba(35, 31, 29, 0.64); }

  .package-intro { max-width: 760px; margin: 0 0 16px; color: rgba(245, 241, 233, 0.8); font-size: 15px; line-height: 1.42; }
  .light .package-intro,
  .package.light .package-intro { color: rgba(35, 31, 29, 0.72); }

  .package-group-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px 13px; margin-top: 13px; }
  .package-group { padding: 12px 13px 13px; border-top: 1px solid rgba(245, 241, 233, 0.14); background: rgba(245, 241, 233, 0.045); border-radius: 16px; }
  .package-group strong { display: block; margin-bottom: 8px; color: var(--package-accent); font-size: 11px; font-weight: 850; letter-spacing: 0.13em; text-transform: uppercase; }
  .package-group ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 5px; }
  .package-group li { position: relative; padding-left: 13px; color: rgba(245, 241, 233, 0.82); font-size: 12.7px; line-height: 1.33; }
  .package-group li::before { content: ""; position: absolute; left: 0; top: 0.62em; width: 4px; height: 4px; border-radius: 999px; background: var(--package-accent); }
  .light .package-group,
  .package.light .package-group { background: rgba(255, 255, 255, 0.24); border-top-color: rgba(83, 70, 56, 0.12); }
  .light .package-group li,
  .package.light .package-group li { color: rgba(35, 31, 29, 0.74); }

  .addon-groups { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .addon-heading { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
  .addon-heading strong { margin-bottom: 0; }
  .addon-heading b { color: var(--cream); font-size: 12px; white-space: nowrap; }

  .path-table { display: grid; gap: 8px; margin-top: 13px; }
  .path-table div { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 12px 14px; border-radius: 14px; border-top: 1px solid rgba(245, 241, 233, 0.12); background: rgba(245, 241, 233, 0.055); }
  .path-table span { color: rgba(245, 241, 233, 0.76); font-size: 13px; }
