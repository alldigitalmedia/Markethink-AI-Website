---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const pageTitle = "AI Marketing for Law Firms and Lawyers | Markethink";
const pageDescription = "AI marketing for law firms and lawyers: a managed marketing system for law firm content, campaigns, local visibility, lead intake, approvals, and follow-up.";
const canonicalUrl = "https://markethink.ai/ai-marketing-for-law-firms/";
const walkthroughHref = "/schedule-a-walkthrough/";

const keywords = [
  "AI marketing for law firms",
  "AI marketing for lawyers",
  "law firm marketing system",
  "legal marketing automation",
  "law firm lead generation",
];

const painPoints = [
  ["Searchers choose the firm that looks clear first", "A potential client may compare three firms in one sitting. If your website, services, reviews, FAQs, and next step are hard to understand, another firm becomes the easier choice."],
  ["Good legal knowledge does not automatically become marketing", "Attorneys answer the same questions every week, but those answers rarely become useful pages, email follow-up, local content, or campaign assets."],
  ["Intake and follow-up lose context", "A form fill, phone call, or consultation request should connect to the page, practice area, campaign, and next message. Too often it becomes a disconnected note."],
];

const systemPieces = [
  ["Practice-area context", "Your services, locations, audience, tone, compliance preferences, review rules, and common client questions stay organized before new content is created."],
  ["Website and SEO direction", "Markethink helps plan and improve practice-area pages, local landing pages, FAQs, attorney bios, and conversion paths around real search intent."],
  ["Campaign workflow", "One marketing priority can become a page update, social posts, email copy, ad landing direction, intake notes, and follow-up language."],
  ["Approval memory", "Partner edits, disclaimer preferences, tone corrections, and wording rules are captured so future drafts start closer to approval."],
  ["Lead intake support", "Inquiry notes, source context, reply drafts, and next-step reminders stay connected to the campaign or page that created the conversation."],
  ["Weekly execution", "The firm gets a consistent marketing rhythm without treating every blog post, landing page, or follow-up sequence as a new one-off project."],
];

const useCases = [
  ["Law firm SEO content", "Plan useful pages around practice areas, locations, FAQs, service comparisons, attorney expertise, and client decision questions."],
  ["Website conversion improvements", "Clarify the first screen, calls to action, consultation paths, attorney bios, trust signals, and page order for search visitors."],
  ["Local marketing campaigns", "Connect city, neighborhood, practice-area, and referral campaigns to the pages and follow-up messages they need."],
  ["Social and email content", "Turn legal insights, case-type education, event updates, and common questions into review-ready posts and email drafts."],
  ["PPC landing support", "Create focused landing-page direction for high-intent search ads without making unsupported promises or generic claims."],
  ["Intake and follow-up", "Support faster, clearer replies after a form submission, consultation request, referral, or warm lead conversation."],
];

const comparisonRows = [
  ["AI writing tool", "Creates drafts when someone prompts it.", "Connects the draft to the firm's practice areas, approval rules, page goal, intake path, and follow-up."],
  ["SEO checklist", "Suggests keywords and technical tasks.", "Turns keyword intent into pages, sections, FAQs, internal links, and conversion paths."],
  ["Social scheduler", "Publishes posts after they are written.", "Plans the campaign, creates the assets, captures approvals, and keeps the message consistent."],
  ["CRM alone", "Stores contacts after they arrive.", "Keeps the marketing source, inquiry context, reply direction, and next step connected."],
];

const implementationSteps = [
  ["1", "Audit the firm marketing system", "Review the website, practice-area pages, local visibility, lead paths, content gaps, approvals, and intake follow-up."],
  ["2", "Choose one practice-area priority", "Start with one service line, location, or referral motion instead of trying to rebuild every channel at once."],
  ["3", "Build the page and campaign assets", "Create the landing direction, supporting content, social posts, email or PPC copy, FAQs, and follow-up notes together."],
  ["4", "Review with firm judgment", "Attorneys or firm leadership approve sensitive language, disclaimers, tone, and claims before anything becomes public."],
  ["5", "Repeat with memory", "Each correction improves the next page, campaign, intake message, and content brief instead of restarting the process."],
];

const faqs = [
  { question: "What is AI marketing for law firms?", answer: "AI marketing for law firms means using AI-supported planning, content, website, campaign, and follow-up workflows with the right firm context and human review. The strongest setup is not a generic tool. It is a managed marketing system that understands the firm's practice areas, audience, approval rules, and intake path." },
  { question: "Is Markethink an AI marketing tool for lawyers?", answer: "Markethink is more than an AI marketing tool for lawyers. It is an AI marketing system managed by expert marketers. It helps law firms organize campaigns, create review-ready marketing assets, improve website clarity, support lead intake, and remember approvals over time." },
  { question: "Can AI help with law firm SEO?", answer: "Yes, when it is guided by strategy and review. AI can help research topics, structure practice-area pages, draft FAQs, improve internal links, and identify content gaps. Attorneys or approved firm reviewers should still review public legal content before publication." },
  { question: "Can Markethink help with law firm lead generation?", answer: "Markethink can support the marketing system around lead generation: clearer pages, better calls to action, campaign assets, intake context, CRM-style follow-up, and reply drafts. We do not promise a specific number of cases, clients, leads, or revenue." },
  { question: "Does this replace a law firm marketing agency?", answer: "No. Markethink is positioned as a managed marketing operation: AI helps with speed and consistency, while expert marketers guide strategy and review quality. Some firms may use it instead of scattered tools. Others may use it alongside an internal team or agency." },
  { question: "What law firms are a good fit?", answer: "The best fit is a firm with real expertise, clear practice areas, and a desire to market more consistently. It is especially useful when the firm needs website updates, SEO content, campaigns, intake follow-up, and approval memory connected in one place." },
  { question: "What should a law firm review before publishing AI-assisted marketing?", answer: "A qualified firm reviewer should check accuracy, jurisdictional language, disclaimers, claims, examples, attorney advertising rules, confidentiality concerns, and whether the content creates any unintended expectation. Markethink keeps human review central." },
  { question: "How do we start?", answer: "Start with a marketing system audit. We look at your website, practice-area pages, content gaps, campaign rhythm, intake path, and follow-up process, then recommend the first workflow to improve." },
];

const structuredData = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "AI Marketing for Law Firms", description: pageDescription, url: canonicalUrl, inLanguage: "en", publisher: { "@type": "Organization", name: "Markethink", url: "https://markethink.ai/", logo: "https://markethink.ai/images/logo.svg" } },
  { "@context": "https://schema.org", "@type": "Service", name: "AI Marketing for Law Firms", serviceType: "Managed marketing system for law firm campaigns, website content, lead intake, approvals, and follow-up", areaServed: ["United States", "Latin America"], provider: { "@type": "Organization", name: "Markethink", url: "https://markethink.ai/" }, audience: { "@type": "Audience", audienceType: "Law firms, attorneys, and legal service practices" }, description: "Markethink helps law firms organize marketing campaigns, improve website and SEO workflows, create review-ready content, manage approvals, and support lead intake follow-up." },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((faq) => ({ "@type": "Question", name: faq.question, acceptedAnswer: { "@type": "Answer", text: faq.answer } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [{ "@type": "ListItem", position: 1, name: "Home", item: "https://markethink.ai/" }, { "@type": "ListItem", position: 2, name: "AI Marketing for Law Firms", item: canonicalUrl }] },
];
---

<Layout title={pageTitle} description={pageDescription} image="/images/ai-marketing-law-firms-hero-v3.svg" canonical={canonicalUrl} structuredData={structuredData}>
  <Navbar />
  <main class="law-page">
    <section class="law-hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="subtitle animate-fade-up">AI MARKETING FOR LAW FIRMS</p>
          <h1 class="animate-fade-up">AI marketing for law firms works when it becomes a system for trust, intake, and follow-up.</h1>
          <p class="hero-description animate-fade-up">
            Markethink helps law firms turn practice-area knowledge, website pages, campaigns, approvals, and lead follow-up into one managed marketing rhythm. Powered by AI, managed by expert marketers, and reviewed with firm judgment.
          </p>
          <div class="button-group animate-fade-up">
            <a href={walkthroughHref} class="button">Request a Law Firm Marketing Audit</a>
            <a href="#system" class="button is-secondary">See the system</a>
          </div>
          <div class="outcome-row animate-fade-up" aria-label="Connected marketing capabilities">
            <span>Website + SEO</span>
            <span>Intake + CRM</span>
            <span>Expert review</span>
          </div>
        </div>
        <div class="hero-visual animate-scale-in">
          <img src="/images/ai-marketing-law-firms-hero-v3.svg" alt="Law firm leaders and expert marketers working with an AI-powered system connecting search, campaigns, approvals, intake, CRM follow-up, and email" width="1536" height="1024" />
        </div>
      </div>
    </section>

    <section class="section light-green intent-section">
      <div class="container two-column">
        <div>
          <p class="subtitle">THE REAL SEARCH INTENT</p>
          <h2>Law firms search for AI marketing because consistent client acquisition is hard to maintain.</h2>
        </div>
        <div class="rich-copy">
          <p>A managing partner may search for <strong>AI marketing for lawyers</strong>, <strong>legal marketing automation</strong>, or <strong>law firm lead generation</strong>. The underlying problem is usually the same: the firm needs clearer pages, better content, faster review, stronger intake, and follow-up that does not disappear after the first inquiry.</p>
          <p>AI can help produce and organize the work faster. But a law firm still needs strategy, judgment, accuracy checks, attorney advertising awareness, and a system that connects marketing to real consultations.</p>
          <p>That is the Markethink role: learn the firm, organize the campaign, create review-ready assets, capture approvals, support intake, and improve with every correction and result.</p>
        </div>
      </div>
      <div class="container pain-grid animate-stagger">
        {painPoints.map(([title, copy]) => (
          <article>
            <h3>{title}</h3>
            <p>{copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section dark" id="system">
      <div class="container">
        <div class="section-header text-center">
          <p class="subtitle">LAW FIRM MARKETING SYSTEM</p>
          <h2>A connected system for SEO, content, campaigns, approvals, and intake.</h2>
          <p class="section-description dark-copy">Most law firm marketing breaks because the pieces are separated. The website says one thing, the ads say another, intake has no context, and every approval starts from scratch.</p>
        </div>
        <div class="system-stage">
          <img src="/images/ai-marketing-law-firms-system-v3.svg" alt="Expert marketers and law firm leaders reviewing an AI-connected workflow for search, content, approvals, intake, and follow-up" width="1536" height="1024" loading="lazy" />
          <div class="system-caption">
            <span>Powered by AI</span>
            <strong>Directed and reviewed by experts.</strong>
          </div>
        </div>
        <div class="system-grid">
          {systemPieces.map(([title, copy], index) => (
            <article class="system-card">
              <span class="card-number">0{index + 1}</span>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section visual-section">
      <div class="container visual-grid">
        <div class="workflow-visual">
          <img src="/images/ai-marketing-law-firms-search-v2.svg" alt="Attorney and marketing strategist using AI to organize law firm search pages, FAQs, local visibility, approvals, and campaigns" width="1536" height="1024" loading="lazy" />
        </div>
        <div class="workflow-copy">
          <p class="subtitle">WHAT AI CAN HELP WITH</p>
          <h2>Useful AI marketing for law firms starts with the work clients actually judge.</h2>
          <p>Search visitors judge clarity, relevance, trust, and next steps before they ever speak to the firm. A marketing system should improve those moments, not just generate more posts.</p>
          <ul>
            <li>Practice-area pages that answer real decision questions.</li>
            <li>Attorney bios, FAQs, and service pages that build trust without overclaiming.</li>
            <li>Campaign assets for SEO, PPC, email, social, and referrals.</li>
            <li>Follow-up messages that connect back to the inquiry source and next step.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section light-green use-case-section">
      <div class="container">
        <div class="section-header">
          <p class="subtitle">PRACTICAL USE CASES</p>
          <h2>How law firms can use AI marketing without creating compliance risk or generic content.</h2>
          <p class="section-description">The goal is not more volume. The goal is clearer marketing, faster review, better search coverage, and a stronger path from visitor to consultation request.</p>
        </div>
        <div class="use-case-grid">
          {useCases.map(([title, copy]) => (
            <article>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="pipeline-section">
      <div class="pipeline-image">
        <img src="/images/ai-marketing-law-firms-pipeline-v2.svg" alt="Law firm intake team using an AI-powered pipeline to organize consultation requests, context, assignments, replies, and follow-up" width="1536" height="1024" loading="lazy" />
      </div>
      <div class="container pipeline-copy">
        <p class="subtitle">FROM INQUIRY TO FOLLOW-UP</p>
        <h2>AI moves the context. Your team keeps the judgment.</h2>
        <p>A consultation request should arrive with its source, practice-area context, campaign history, reply direction, and next step already connected. Markethink helps organize that motion so fewer opportunities disappear between marketing and intake.</p>
        <div class="pipeline-steps" aria-label="Connected law firm lead workflow">
          <span>01 · Inquiry</span><span>02 · Context</span><span>03 · Review</span><span>04 · Follow-up</span>
        </div>
      </div>
    </section>

    <section class="section dark comparison-section">
      <div class="container">
        <div class="section-header">
          <p class="subtitle">TOOLS VS. SYSTEM</p>
          <h2>AI tools can draft. A law firm marketing system keeps the whole motion connected.</h2>
          <p class="section-description dark-copy">This is where Markethink separates from one-off AI marketing tools for lawyers, content generators, SEO checklists, and disconnected CRMs.</p>
        </div>
        <div class="comparison-table">
          <div class="table-head"><span>Category</span><span>What it does alone</span><span>What Markethink connects</span></div>
          {comparisonRows.map(([category, alone, connected]) => (
            <div class="table-row"><span>{category}</span><span>{alone}</span><span>{connected}</span></div>
          ))}
        </div>
      </div>
    </section>

    <section class="section light-green seo-section">
      <div class="container two-column">
        <div>
          <p class="subtitle">SEO FOR LAW FIRMS</p>
          <h2>Rank for the questions your best clients ask before they call.</h2>
        </div>
        <div class="rich-copy">
          <p>A strong <strong>law firm SEO</strong> program needs more than keyword lists. It needs pages that match search intent, explain the practice area plainly, make the attorney or firm credible, and guide the visitor toward the right next step.</p>
          <p>Markethink can support topic planning, page outlines, FAQ sections, internal links, local landing-page direction, attorney bio improvements, and campaign briefs. The firm keeps final review where legal accuracy and attorney advertising standards matter.</p>
          <div class="supporting-link">
            <p>Related Markethink pages and guides:</p>
            <ul>
              <li><a href="/ai-marketing-for-small-business/">AI marketing for small business</a></li>
              <li><a href="/blog/consistent-marketing-beats-chasing-ai-tools/">Why consistent marketing beats chasing every new AI tool</a></li>
              <li><a href="/blog/brand-memory-feedback-approved-campaigns/">How brand memory turns feedback into faster approved campaigns</a></li>
              <li><a href="/blog/scattered-ideas-to-client-opportunities/">From scattered ideas to campaigns that create real client opportunities</a></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section dark process-section">
      <div class="container">
        <div class="section-header text-center">
          <p class="subtitle">IMPLEMENTATION PLAN</p>
          <h2>How to start using AI marketing without turning the firm into a content factory.</h2>
          <p class="section-description dark-copy">Start with the business outcome and review process. Then use AI to make the work faster, more organized, and easier to approve.</p>
        </div>
        <div class="process-grid">
          {implementationSteps.map(([number, title, copy]) => (
            <article>
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section light-green fit-section">
      <div class="container fit-grid">
        <div class="fit-card">
          <p class="subtitle">GOOD FIT</p>
          <h2>Built for firms that want steady marketing execution with real review.</h2>
          <ul>
            <li>You have clear practice areas and want better website, content, and campaign consistency.</li>
            <li>You need marketing connected to intake, consultations, CRM notes, and follow-up.</li>
            <li>You want AI speed, but still need expert marketers and firm approval before public claims go live.</li>
          </ul>
        </div>
        <div class="fit-card muted">
          <p class="subtitle">NOT THE RIGHT FIT</p>
          <h2>Not for risky legal claims or cheap content volume.</h2>
          <ul>
            <li>You want to publish legal content without attorney or firm review.</li>
            <li>You need guaranteed rankings, cases, leads, revenue, or specific outcomes.</li>
            <li>You only want a self-serve AI caption generator with no strategy or approval rhythm.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section faq-section">
      <div class="container faq-grid">
        <div>
          <p class="subtitle">FAQ</p>
          <h2>Questions law firms ask before using AI in marketing.</h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => (
            <details>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="law-final-cta">
      <div class="container final-panel">
        <p class="subtitle">START WITH THE SYSTEM</p>
        <h2>Find the gaps in your law firm marketing before adding another AI tool.</h2>
        <p>Book a focused walkthrough. We will look at your website, practice-area pages, campaigns, intake path, follow-up, and approval flow, then map where Markethink should help first.</p>
        <a href={walkthroughHref} class="button">Request a Law Firm Marketing Audit</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .law-page { background: #f5f5f1; color: #0f1213; overflow: clip; }
  .law-page .section { padding: clamp(6rem, 9vw, 9rem) 0; }
  .law-hero { min-height: 960px; display: flex; align-items: center; position: relative; overflow: hidden; background: #0f1213; }
  .law-hero::after { content: ""; position: absolute; inset: 0; z-index: 1; background: linear-gradient(90deg, rgba(5,10,14,.98) 0%, rgba(5,10,14,.92) 28%, rgba(5,10,14,.48) 57%, rgba(5,10,14,.1) 100%), linear-gradient(0deg, rgba(5,10,14,.52), transparent 40%); pointer-events: none; }
  .hero-grid { width: 100%; position: relative; z-index: 2; }
  .hero-copy { position: relative; z-index: 3; display: flex; flex-direction: column; gap: 1.25rem; max-width: min(48rem, 53vw); margin-left: clamp(1.25rem, 4vw, 4rem); padding: 9rem 0 5rem; }
  .hero-copy h1 { color: #f5f5f1; font-size: clamp(3.25rem, 5.45vw, 5.7rem); line-height: .94; letter-spacing: -.055em; text-wrap: balance; }
  .hero-description { max-width: 41rem; color: rgba(245,245,241,.76); font-size: 1.08rem; line-height: 1.75; }
  .hero-visual { position: absolute; inset: 0; z-index: 0; }
  .hero-visual img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .button-group, .outcome-row { display: flex; flex-wrap: wrap; gap: .75rem; }
  .outcome-row { margin-top: .5rem; }
  .outcome-row span { border: 1px solid rgba(245,245,241,.2); border-radius: 999px; padding: .65rem .9rem; color: rgba(245,245,241,.82); background: rgba(7,14,23,.42); backdrop-filter: blur(12px); font-size: .78rem; letter-spacing: .04em; }
  .hero-copy .subtitle { color: #aee8a0; }

  .hero-grid, .two-column, .visual-grid, .fit-grid, .faq-grid { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: clamp(2.5rem, 6vw, 5rem); align-items: center; }
  .section-header { max-width: 960px; margin-bottom: 3.2rem; }
  .section-header h2, .workflow-copy h2, .fit-card h2, .faq-grid h2, .intent-section h2, .seo-section h2, .final-panel h2, .pipeline-copy h2 { font-size: clamp(2.7rem, 5.1vw, 5.35rem); line-height: .96; letter-spacing: -.052em; text-wrap: balance; }
  .text-center { text-align: center; margin-left: auto; margin-right: auto; }
  .section-description, .rich-copy, .workflow-copy { color: rgba(15,18,19,.7); line-height: 1.78; font-size: 1rem; }
  .rich-copy p + p, .workflow-copy p + ul { margin-top: 1rem; }

  .intent-section { background: #edf4ea; }
  .pain-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-top: 3.5rem; }
  .pain-grid article, .use-case-grid article { border: 1px solid rgba(15,18,19,.11); border-radius: 1.35rem; background: rgba(245,245,241,.86); padding: 1.5rem; }
  .pain-grid article { min-height: 13rem; display: flex; flex-direction: column; justify-content: space-between; }
  .pain-grid h3, .system-card h3, .use-case-grid h3, .process-grid h3 { font-family: var(--font-body); font-size: 1.08rem; margin-bottom: .7rem; }
  .pain-grid p, .use-case-grid p { color: rgba(15,18,19,.68); line-height: 1.68; }

  .section.dark { background: #0f1213; color: #f5f5f1; }
  .dark-copy, .section.dark .section-description { color: rgba(245,245,241,.66); }
  .system-stage { position: relative; border-radius: 2rem; overflow: hidden; border: 1px solid rgba(255,255,255,.12); box-shadow: 0 36px 100px rgba(0,0,0,.35); }
  .system-stage img { display: block; width: 100%; aspect-ratio: 3/2; object-fit: cover; }
  .system-stage::after { content: ""; position: absolute; inset: 0; background: linear-gradient(0deg, rgba(7,14,23,.86) 0%, transparent 48%); }
  .system-caption { position: absolute; z-index: 2; left: clamp(1.4rem,4vw,3rem); bottom: clamp(1.4rem,4vw,2.6rem); display: flex; flex-direction: column; gap: .35rem; }
  .system-caption span { color: #69d254; font-size: .76rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .system-caption strong { font-family: var(--font-display); font-size: clamp(2rem,4vw,3.6rem); font-weight: 400; }
  .system-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; position: relative; z-index: 3; margin-top: -1.5rem; padding: 0 1.5rem; }
  .system-card, .process-grid article { border: 1px solid rgba(255,255,255,.13); border-radius: 1.3rem; background: rgba(20,25,28,.94); padding: 1.45rem; backdrop-filter: blur(12px); }
  .system-card p, .process-grid p { color: rgba(245,245,241,.66); line-height: 1.65; font-size: .94rem; }
  .card-number { display: block; color: #69d254; font-size: .75rem; font-weight: 800; letter-spacing: .08em; margin-bottom: 1rem; }

  .visual-section { background: #f5f5f1; color: #0f1213; }
  .visual-section .subtitle { color: rgba(15,18,19,.48); }
  .visual-grid { gap: clamp(2.5rem,5vw,5rem); }
  .workflow-visual { position: relative; }
  .workflow-visual::before { content: "AI + EXPERT REVIEW"; position: absolute; z-index: 2; left: 1rem; top: 1rem; border-radius: 999px; padding: .55rem .8rem; background: rgba(15,18,19,.84); color: #f5f5f1; font-size: .68rem; font-weight: 800; letter-spacing: .1em; }
  .workflow-visual img { width: 100%; height: auto; border-radius: 2rem; box-shadow: 0 34px 100px rgba(15,18,19,.18); }
  .workflow-copy ul, .fit-card ul { list-style: none; display: flex; flex-direction: column; gap: .75rem; margin-top: 1.25rem; }
  .workflow-copy li, .fit-card li { position: relative; padding-left: 1.35rem; color: rgba(15,18,19,.72); line-height: 1.66; }
  .workflow-copy li::before, .fit-card li::before { content: ""; position: absolute; left: 0; top: .7em; width: .45rem; height: .45rem; border-radius: 999px; background: #69d254; }

  .use-case-section { background: #edf4ea; }
  .use-case-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
  .use-case-grid article { min-height: 12rem; transition: transform .25s ease, box-shadow .25s ease; }
  .use-case-grid article:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(15,18,19,.08); }

