    chips: ["Approved direction", "Rejected patterns", "Useful feedback", "Next-cycle learning"],
    details: [
      "Fewer repeated corrections",
      "More consistent voice and visual direction",
      "Cleaner handoff between campaigns",
      "Better decisions as the business context grows",
    ],
  },
  {
    n: "07",
    id: "growth",
    nav: "Growth",
    kicker: "SLIDE 07 · BUSINESS OUTCOME",
