---

<Layout
  title="Markethink Presentation — Marketing that ships"
  description="A private Markethink presentation for direct clients: how the marketing system learns your business, organizes campaigns, and helps marketing ship every week."
  image="https://markethink.ai/images/hero-image.png"
  canonical="https://markethink.ai/presentation/"
  noindex={true}
>
  <main class="presentation-page" aria-label="Markethink presentation">
    <header class="presentation-topbar">
      <a href="/" class="logo-lockup" aria-label="Markethink">
        <img src="/images/logo.svg" alt="Markethink" class="markethink-logo" />
      </a>
      <span class="deck-label">Private presentation</span>
    </header>

    <aside class="slide-rail" aria-label="Presentation sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} class={`rail-item ${slide.n === '01' ? 'active' : ''}`} data-slide-link={slide.id} aria-current={slide.n === '01' ? 'step' : undefined}>
          <span>{slide.n}</span><strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide, index) => (
      <section id={slide.id} data-slide-id={slide.id} data-slide-index={index} class={`presentation-slide layout-${slide.layout} ${slide.backgroundOnly ? 'background-led' : ''} ${slide.n === '01' ? 'is-active' : ''}`} aria-label={`Slide ${slide.n}: ${slide.nav}`}>
        <div class="slide-background" aria-hidden="true">
          <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
        </div>
        <div class="slide-overlay" aria-hidden="true"></div>
        <div class="motion-field" aria-hidden="true"><span></span><span></span><span></span><span></span></div>

        <div class="slide-shell">
          <div class="story-content">
            <p class="eyebrow">{slide.kicker}</p>
            <h1 set:html={slide.title}></h1>
            <p class="lead">{slide.lead}</p>
            {slide.chips?.length > 0 && (
              <div class="chip-row" aria-label="Key points">
                {slide.chips.map((chip) => <span>{chip}</span>)}
              </div>
            )}
            {slide.details && (
              <ul class="detail-list" aria-label="Section details">
                {slide.details.map((item) => <li>{item}</li>)}
              </ul>
            )}
            <div class="hero-actions" aria-label="Presentation context">
              <span class="context-note">Markethink · {slide.note}</span>
            </div>
          </div>

          {!slide.backgroundOnly && (
            <div class="visual-stack">
              <div class="visual-card" aria-hidden="true">
                <img src={slide.image} alt="" loading={slide.n === '01' ? 'eager' : 'lazy'} decoding="async" />
              </div>
            </div>
          )}
        </div>

        <div class="slide-footer">
          <span>{slide.n} / {slide.nav}</span>
          <span>{slide.note}</span>
        </div>
      </section>
    ))}
  </main>
</Layout>

<script is:inline>
  (() => {
    const slides = Array.from(document.querySelectorAll('.presentation-slide[data-slide-id]'));
    const railItems = Array.from(document.querySelectorAll('.rail-item[data-slide-link]'));

    if (!slides.length || !railItems.length) return;

    const setActiveSlide = (id) => {
      railItems.forEach((item) => {
        const isActive = item.dataset.slideLink === id;
        item.classList.toggle('active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', 'step');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      slides.forEach((slide) => {
        slide.classList.toggle('is-active', slide.dataset.slideId === id);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.dataset?.slideId) {
          setActiveSlide(visible.target.dataset.slideId);
        }
      },
      {
        root: null,
        threshold: [0.28, 0.42, 0.58, 0.72],
        rootMargin: '-22% 0px -34% 0px',
      }
    );

    slides.forEach((slide) => observer.observe(slide));

    railItems.forEach((item) => {
      item.addEventListener('click', () => {
        if (item.dataset.slideLink) setActiveSlide(item.dataset.slideLink);
      });
    });
  })();
</script>

<style>
  :global(html) { background: #0f1213; scroll-behavior: smooth; }
  .presentation-page { background: #0f1213; color: #f5f5f1; overflow-x: hidden; }
  .presentation-slide { position: relative; min-height: 100svh; isolation: isolate; display: grid; align-items: center; padding: clamp(6.5rem, 9vh, 8rem) clamp(1.3rem, 5vw, 5rem) clamp(4.8rem, 7vh, 6.4rem); background: #0f1213; overflow: hidden; scroll-margin-top: 0; }
  .presentation-slide .story-content { opacity: .72; transform: translateY(18px); transition: opacity .72s ease, transform .72s ease; }
  .presentation-slide .visual-card { opacity: .76; transition: opacity .72s ease, transform .72s ease, box-shadow .72s ease; }
  .presentation-slide .slide-background img { transition: opacity .9s ease, transform 1.15s ease, filter .9s ease; }
  .presentation-slide.is-active .story-content { opacity: 1; transform: translateY(0); }
  .presentation-slide.is-active .visual-card { opacity: 1; box-shadow: 0 44px 120px rgba(0,0,0,.46), 0 0 0 1px rgba(105,210,84,.06); }
  .presentation-slide.is-active .slide-background img { transform: scale(1.01); }
  .presentation-slide.is-active .motion-field span { animation: softPulse 3.8s ease-in-out infinite; }
  .slide-background, .slide-overlay, .motion-field { position: absolute; inset: 0; }
  .slide-background { z-index: -4; }
  .slide-background img { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.23; filter: saturate(0.82) contrast(1.08); transform: scale(1.04); }
  .slide-overlay { z-index: -3; background: radial-gradient(circle at var(--hot-x, 72%) var(--hot-y, 48%), rgba(105,210,84,.18), transparent 28%), linear-gradient(90deg, rgba(15,18,19,.98) 0%, rgba(15,18,19,.78) 46%, rgba(15,18,19,.42) 100%), linear-gradient(180deg, rgba(15,18,19,.14), rgba(15,18,19,.84)); }
  .motion-field { z-index: -2; opacity: .58; background-image: linear-gradient(rgba(245,245,241,.055) 1px, transparent 1px), linear-gradient(90deg, rgba(245,245,241,.055) 1px, transparent 1px); background-size: 72px 72px; mask-image: radial-gradient(circle at 62% 50%, black, transparent 76%); }
  .motion-field span { position: absolute; width: .55rem; height: .55rem; border-radius: 999px; background: #69d254; box-shadow: 0 0 0 .42rem rgba(105,210,84,.13); }
  .motion-field span:nth-child(1){ top: 22%; left: 20%; } .motion-field span:nth-child(2){ top: 30%; right: 28%; } .motion-field span:nth-child(3){ bottom:24%; left:38%; } .motion-field span:nth-child(4){ bottom:18%; right:17%; }
  .presentation-topbar { position: fixed; top: clamp(1rem, 2vw, 2rem); left: clamp(1.25rem, 4vw, 4rem); right: clamp(1.25rem, 4vw, 4rem); z-index: 8; display:flex; align-items:center; justify-content:space-between; pointer-events:none; }
  .logo-lockup { pointer-events:auto; display:inline-flex; align-items:center; min-height:3.1rem; padding:.85rem 1.1rem; border:1px solid rgba(245,245,241,.13); border-radius:999px; background:rgba(15,18,19,.66); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); box-shadow:0 18px 70px rgba(0,0,0,.28); }
  .markethink-logo{ height:1.15rem; width:auto; filter:brightness(0) invert(1); }
  .deck-label { pointer-events:none; padding:.75rem 1rem; border:1px solid rgba(245,245,241,.11); border-radius:999px; color:rgba(245,245,241,.58); background:rgba(15,18,19,.44); backdrop-filter:blur(14px); font-size:.72rem; letter-spacing:.16em; text-transform:uppercase; }
  .slide-shell { width:min(1240px, 100%); margin-inline:auto; display:grid; grid-template-columns:minmax(0, .95fr) minmax(340px, .9fr); gap:clamp(2rem,5vw,5.5rem); align-items:center; padding-block:clamp(1.2rem,2.5vh,2rem); }
  .story-content{ max-width:760px; position:relative; z-index:2; }
  .eyebrow{ display:inline-flex; align-items:center; gap:.65rem; margin:0 0 1.15rem; color:rgba(237,244,234,.72); font-size:.75rem; line-height:1; letter-spacing:.16em; text-transform:uppercase; } .eyebrow::before{ content:""; width:.52rem; height:.52rem; border-radius:999px; background:#69d254; box-shadow:0 0 0 .32rem rgba(105,210,84,.12); }
  h1{ max-width:20ch; margin:0; font-family:"Instrument Serif", Georgia, serif; font-size:clamp(2.25rem,4.2vw,4.72rem); font-weight:400; line-height:1.03; letter-spacing:-.032em; color:#f5f5f1; text-wrap:balance; }
  .lead{ max-width:46rem; margin-top:clamp(.85rem,1.7vw,1.25rem); color:rgba(245,245,241,.80); font-size:clamp(.98rem,1.12vw,1.12rem); line-height:1.48; text-wrap:balance; }
  .chip-row{ display:flex; flex-wrap:wrap; gap:.55rem; margin-top:1.15rem; } .chip-row span{ padding:.68rem .86rem; border:1px solid rgba(245,245,241,.13); border-radius:999px; background:rgba(15,18,19,.55); color:rgba(245,245,241,.74); backdrop-filter:blur(12px); font-size:.8rem; }
  .detail-list{ max-width:50rem; display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.52rem; margin:1.05rem 0 0; padding:0; list-style:none; }
  .detail-list li{ position:relative; padding:.72rem .78rem .72rem 1.55rem; border:1px solid rgba(245,245,241,.10); border-radius:1rem; background:rgba(15,18,19,.38); color:rgba(245,245,241,.72); font-size:clamp(.86rem,.98vw,.95rem); line-height:1.34; backdrop-filter:blur(10px); }
  .detail-list li::before{ content:""; position:absolute; left:.78rem; top:1.05rem; width:.42rem; height:.42rem; border-radius:999px; background:#69d254; box-shadow:0 0 0 .18rem rgba(105,210,84,.12); }
  .hero-actions{ display:flex; align-items:center; gap:1.15rem; flex-wrap:wrap; margin-top:1.35rem; } .context-note{ max-width:27rem; color:rgba(245,245,241,.52); font-size:.86rem; line-height:1.45; }
  .visual-stack{ display:grid; gap:clamp(.85rem,1.4vw,1.15rem); align-items:start; }
  .visual-card{ position:relative; width:100%; border:1px solid rgba(245,245,241,.13); border-radius:clamp(1.4rem,3vw,2.6rem); overflow:hidden; background:#141718; box-shadow:0 40px 110px rgba(0,0,0,.42); transform:translateY(1rem); }
  .visual-card::before{ content:""; position:absolute; inset:0; z-index:2; border-radius:inherit; box-shadow:inset 0 0 0 1px rgba(245,245,241,.06), inset 0 -90px 120px rgba(15,18,19,.20); pointer-events:none; }
  .visual-card::after{ content:""; position:absolute; width:32%; aspect-ratio:1; right:-10%; top:-12%; border-radius:999px; background:rgba(105,210,84,.16); filter:blur(24px); z-index:1; }
  .visual-card img{ width:100%; height:auto; object-fit:contain; display:block; transform:none; background:#0f1213; }
  .background-led .slide-background img { opacity: .78; filter: saturate(.98) contrast(1.08); transform: scale(1.02); }
  .background-led .slide-overlay { background: radial-gradient(circle at var(--hot-x, 70%) var(--hot-y, 48%), rgba(105,210,84,.12), transparent 30%), linear-gradient(90deg, rgba(15,18,19,.98) 0%, rgba(15,18,19,.88) 28%, rgba(15,18,19,.44) 62%, rgba(15,18,19,.20) 100%), linear-gradient(180deg, rgba(15,18,19,.10), rgba(15,18,19,.72)); }
  .background-led .slide-shell { grid-template-columns: 1fr; }
  .background-led .story-content { max-width: min(880px, 72vw); padding: clamp(1.4rem, 2vw, 2rem); border-left: 1px solid rgba(105,210,84,.28); background: linear-gradient(90deg, rgba(15,18,19,.50), rgba(15,18,19,.16)); backdrop-filter: blur(2px); }
  .background-led h1 { max-width: 14.4ch; }
  .layout-hero .story-content { background: transparent; border-left: 0; padding-left: 0; }
  .layout-hero .slide-shell{ grid-template-columns:1fr; } .layout-hero .visual-card{ display:none; } .layout-hero .story-content{ max-width:1020px; } .layout-hero h1{ max-width:16ch; } .layout-hero .lead{ max-width:54rem; font-size:clamp(1.05rem,1.36vw,1.35rem); }
  .layout-product .slide-shell{ grid-template-columns:minmax(0,.82fr) minmax(460px,1.05fr); } .layout-product .visual-card{ transform:perspective(900px) rotateY(-4deg); }
  .layout-consulting .slide-shell{ grid-template-columns:minmax(430px,.98fr) minmax(0,.9fr); } .layout-consulting .story-content{ order:2; } .layout-consulting .visual-card{ order:1; transform:rotate(-2deg); }
  .layout-library .slide-shell{ grid-template-columns:minmax(0,.88fr) minmax(470px,1fr); } .layout-library .visual-card{ transform:rotate(1deg) scale(1.02); }
  .layout-gates .story-content{ order:2; } .layout-gates .visual-card{ order:1; border-radius:2.8rem; }
  .layout-roadmap .visual-card{ transform:rotate(-.8deg); }
  .layout-closing .slide-shell{ grid-template-columns:1fr; } .layout-closing .story-content{ max-width:960px; } .layout-closing .visual-card{ position:absolute; right:4vw; bottom:10vh; width:min(42vw,620px); opacity:.50; z-index:0; transform:rotate(2deg); }
