  .rail-item.active span{ background:rgba(105,210,84,.20); color:#69d254; box-shadow:0 0 0 .26rem rgba(105,210,84,.08); }
  @keyframes softPulse { 0%, 100% { transform: scale(1); opacity:.72; } 50% { transform: scale(1.36); opacity:1; } }
  @media (prefers-reduced-motion: reduce){ :global(html){ scroll-behavior:auto; } .presentation-slide .story-content, .presentation-slide .visual-card, .presentation-slide .slide-background img, .rail-item, .rail-item span{ transition:none; } .presentation-slide.is-active .motion-field span{ animation:none; } }
