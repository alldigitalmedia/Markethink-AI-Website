---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Client Onboarding | Markethink";
const pageDescription =
  "Set up your Markethink workspace with a focused step-by-step onboarding flow for your business, brand, audience, offers, goals, assets, and approval rhythm.";

const setupSteps = [
  { label: "Business", title: "First, tell us who we’re building around.", helper: "This gives us the basic workspace identity: company, contact, and what the business does." },
  { label: "Audience", title: "Who are we trying to move?", helper: "Good marketing starts with the buyer, the problem, and the market context." },
  { label: "Offer", title: "What should Markethink help sell or move first?", helper: "We focus the first motion instead of trying to boil the ocean." },
  { label: "Marketing", title: "What is already happening today?", helper: "We look for what is working, what is stuck, and where momentum can start fastest." },
  { label: "Assets", title: "Share the useful brand and marketing references.", helper: "Links and files help us avoid restarting from zero." },
  { label: "Approvals", title: "Last step: how should reviews and guardrails work?", helper: "Approval style becomes memory for the work that follows." },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="https://markethink.ai/onboarding/"
  noindex={true}
>
  <main class="setup-page">
    <section class="setup-screen" aria-labelledby="setup-heading">
      <div class="screen-bg" aria-hidden="true">
        <div class="screen-grid"></div>
        <div class="soft-orb orb-a"></div>
        <div class="soft-orb orb-b"></div>
      </div>

      <header class="setup-header">
        <a href="/" class="setup-logo" aria-label="Markethink home">
          <img src="/images/logo-white.svg" alt="Markethink" />
        </a>
        <div class="setup-status">
          <span aria-hidden="true"></span>
          Guided client setup
        </div>
      </header>

      <div class="setup-layout">
        <aside class="setup-rail" aria-label="Onboarding progress">
          <p class="rail-kicker">MARKETHINK SETUP</p>
          <h1 id="setup-heading">Let’s build the marketing system around your business.</h1>
          <p class="rail-copy">
            One focused step at a time. No long intake wall. No guessing what to do next.
          </p>
          <ol class="rail-steps">
            {setupSteps.map((step, index) => (
              <li class={index === 0 ? "active" : ""} data-rail-step={index}>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong>{step.label}</strong>
              </li>
            ))}
          </ol>
        </aside>

        <form
          id="onboarding-form"
          name="markethink-client-onboarding"
          method="POST"
          action="/onboarding/thanks/"
          netlify
          data-netlify="true"
          netlify-honeypot="bot-field"
          enctype="multipart/form-data"
          class="setup-card"
        >
          <input type="hidden" name="form-name" value="markethink-client-onboarding" />
          <input type="hidden" name="source" value="onboarding-page-single-screen" />
          <p class="hidden-field">
            <label>Do not fill this out <input name="bot-field" /></label>
          </p>

          <div class="card-topline">
            <div>
              <span id="step-count">Step 1 of 6</span>
              <strong id="step-label">Business</strong>
            </div>
            <div class="progress-pill" aria-hidden="true"><span id="progress-bar"></span></div>
          </div>

          <div class="step-copy">
            <h2 id="step-title">First, tell us who we’re building around.</h2>
            <p id="step-helper">This gives us the basic workspace identity: company, contact, and what the business does.</p>
          </div>

          <div class="step-viewport">
            <fieldset class="form-step is-active" data-step="0">
              <legend>Business snapshot</legend>
              <div class="field-grid two">
                <label>
                  <span>Your name</span>
                  <input type="text" name="full_name" autocomplete="name" required data-summary="name" />
                </label>
                <label>
                  <span>Work email</span>
                  <input type="email" name="email" autocomplete="email" required />
                </label>
              </div>
              <div class="field-grid two">
                <label>
                  <span>Company</span>
                  <input type="text" name="company" autocomplete="organization" required data-summary="company" />
                </label>
                <label>
                  <span>Website</span>
                  <input type="text" name="website" autocomplete="url" inputmode="url" placeholder="yourcompany.com or @profile" data-summary="website" />
                </label>
              </div>
              <label>
                <span>What does the business do?</span>
                <textarea name="business_description" rows="3" required placeholder="Short version is fine. What do you sell, and who buys it?"></textarea>
              </label>
            </fieldset>

            <fieldset class="form-step" data-step="1">
              <legend>Audience and market</legend>
              <label>
                <span>Who is the ideal customer?</span>
                <textarea name="ideal_customer" rows="3" required placeholder="Describe the buyer, role, location, budget level, or customer type."></textarea>
              </label>
              <label>
                <span>What problem brings them to you?</span>
                <textarea name="customer_problem" rows="3" placeholder="What are they trying to solve, avoid, improve, or achieve?"></textarea>
              </label>
              <label>
                <span>Any competitors or references we should understand?</span>
                <textarea name="market_references" rows="2" placeholder="Links or names are useful. Include brands you like or want to avoid."></textarea>
              </label>
            </fieldset>

            <fieldset class="form-step" data-step="2">
              <legend>Offers and priorities</legend>
              <label>
                <span>Primary offer, product, or service to focus on first</span>
                <textarea name="primary_offer" rows="3" required data-summary="offer" placeholder="What should Markethink help move first?"></textarea>
              </label>
              <label>
                <span>What makes this offer different?</span>
                <textarea name="offer_difference" rows="3" placeholder="Use plain language. No need for polished copy."></textarea>
              </label>
              <label>
                <span>Main business goal for the next 30–60 days</span>
                <select name="primary_goal" required data-summary="goal">
                  <option value="">Select one</option>
                  <option>More qualified leads</option>
                  <option>More consistent campaigns</option>
                  <option>Better website conversion</option>
                  <option>More polished social presence</option>
                  <option>Better email or newsletter rhythm</option>
                  <option>Cleaner client approvals and follow-up</option>
                </select>
              </label>
            </fieldset>

            <fieldset class="form-step" data-step="3">
              <legend>Current marketing motion</legend>
              <label>
                <span>Where is your marketing active today?</span>
                <textarea name="active_channels" rows="3" placeholder="Instagram, LinkedIn, email, paid ads, website, referrals, events, outbound, etc."></textarea>
              </label>
              <label>
                <span>What is working right now?</span>
                <textarea name="whats_working" rows="3" placeholder="Best posts, strongest services, sales questions, referrals, campaigns, or anything with signal."></textarea>
              </label>
              <label>
                <span>What feels scattered, slow, or stuck?</span>
                <textarea name="whats_stuck" rows="3" required placeholder="This helps us find the first useful system fix."></textarea>
              </label>
            </fieldset>

            <fieldset class="form-step" data-step="4">
              <legend>Assets and links</legend>
              <label>
                <span>Brand or asset folder link</span>
                <input type="text" name="asset_folder" inputmode="url" placeholder="Drive folder, Dropbox link, website page, or any asset location" />
              </label>
              <label>
                <span>Upload a logo, brand guide, or useful reference file</span>
                <input type="file" name="brand_asset" accept=".pdf,.png,.jpg,.jpeg,.webp,.svg" />
              </label>
              <label>
                <span>Important links</span>
                <textarea name="important_links" rows="3" placeholder="Social profiles, landing pages, past campaigns, press, portfolio, products, booking links."></textarea>
              </label>
            </fieldset>

            <fieldset class="form-step" data-step="5">
              <legend>Approvals and guardrails</legend>
              <div class="field-grid two">
                <label>
                  <span>Who approves marketing work?</span>
                  <input type="text" name="approver" placeholder="Name / role" data-summary="approver" />
                </label>
                <label>
                  <span>Preferred approval style</span>
                  <select name="approval_speed" data-summary="approval">
                    <option value="">Select one</option>
                    <option>Fast and direct</option>
                    <option>Careful and polished</option>
                    <option>Collaborative with a few options</option>
                  </select>
                </label>
              </div>
              <label>
                <span>What should Markethink avoid?</span>
                <textarea name="avoid" rows="3" placeholder="Claims, words, offers, visual styles, audiences, compliance limits, or anything sensitive."></textarea>
              </label>
              <label class="confirm-row">
                <input type="checkbox" name="credential_confirmation" required />
                <span>I understand this form is for onboarding context, not passwords or private account credentials.</span>
              </label>
            </fieldset>
          </div>

          <div class="card-actions">
            <button type="button" class="step-button back-button" id="prev-step" disabled>Back</button>
            <button type="button" class="step-button next-button" id="next-step">Continue</button>
            <button type="submit" class="step-button next-button hidden" id="submit-step">Send onboarding context</button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script>
    const stepMeta = [
      {
        label: "Business",
        title: "First, tell us who we’re building around.",
        helper: "This gives us the basic workspace identity: company, contact, and what the business does.",
      },
      {
        label: "Audience",
        title: "Who are we trying to move?",
        helper: "Good marketing starts with the buyer, the problem, and the market context.",
      },
      {
        label: "Offer",
        title: "What should Markethink help sell or move first?",
        helper: "We focus the first motion instead of trying to boil the ocean.",
      },
      {
        label: "Marketing",
        title: "What is already happening today?",
        helper: "We look for what is working, what is stuck, and where momentum can start fastest.",
      },
      {
        label: "Assets",
        title: "Share the useful brand and marketing references.",
        helper: "Links and files help us avoid restarting from zero.",
      },
      {
        label: "Approvals",
        title: "Last step: how should reviews and guardrails work?",
        helper: "Approval style becomes memory for the work that follows.",
      },
    ];

    const form = document.getElementById("onboarding-form");
    const steps = Array.from(document.querySelectorAll(".form-step"));
    const railSteps = Array.from(document.querySelectorAll("[data-rail-step]"));
    const previousButton = document.getElementById("prev-step");
    const nextButton = document.getElementById("next-step");
    const submitButton = document.getElementById("submit-step");
    const stepCount = document.getElementById("step-count");
    const stepLabel = document.getElementById("step-label");
    const stepTitle = document.getElementById("step-title");
    const stepHelper = document.getElementById("step-helper");
    const progressBar = document.getElementById("progress-bar");
    let currentStep = 0;

    function fieldsForStep(step) {
      return Array.from(step.querySelectorAll("input, select, textarea"));
    }

    function validateStep() {
      const fields = fieldsForStep(steps[currentStep]);
      return fields.every((field) => {
        if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement)) return true;
        return field.reportValidity();
      });
    }


    function renderStep() {
      const meta = stepMeta[currentStep];
      steps.forEach((step, index) => step.classList.toggle("is-active", index === currentStep));
      railSteps.forEach((step, index) => {
        step.classList.toggle("active", index === currentStep);
        step.classList.toggle("complete", index < currentStep);
      });
      if (stepCount) stepCount.textContent = `Step ${currentStep + 1} of ${steps.length}`;
      if (stepLabel) stepLabel.textContent = meta.label;
      if (stepTitle) stepTitle.textContent = meta.title;
      if (stepHelper) stepHelper.textContent = meta.helper;
      if (progressBar) progressBar.style.width = `${Math.round(((currentStep + 1) / steps.length) * 100)}%`;
      if (previousButton) previousButton.disabled = currentStep === 0;
      const isLast = currentStep === steps.length - 1;
      nextButton?.classList.toggle("hidden", isLast);
      submitButton?.classList.toggle("hidden", !isLast);
    }

    previousButton?.addEventListener("click", () => {
      currentStep = Math.max(0, currentStep - 1);
      renderStep();
    });

    nextButton?.addEventListener("click", () => {
      if (!validateStep()) return;
      currentStep = Math.min(steps.length - 1, currentStep + 1);
      renderStep();
    });

    renderStep();
  </script>
</Layout>

<style>
  .setup-page {
    min-height: 100dvh;
    background: #0f1213;
    color: var(--text-invert);
    overflow: hidden;
  }

  .setup-screen {
    position: relative;
    min-height: 100dvh;
    height: 100dvh;
    padding: clamp(0.85rem, 1.7vw, 1.4rem);
    isolation: isolate;
    overflow: hidden;
  }

  .screen-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background:
      linear-gradient(118deg, rgba(15, 18, 19, 0.97) 0%, rgba(15, 18, 19, 0.86) 52%, rgba(15, 18, 19, 0.72) 100%),
      url("/images/hero-office-background.svg") center top / cover no-repeat,
      #0f1213;
  }

  .screen-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 72% 20%, rgba(105, 210, 84, 0.18), transparent 28rem),
      linear-gradient(180deg, rgba(15, 18, 19, 0.1), rgba(15, 18, 19, 0.94));
  }

  .screen-grid {
    position: absolute;
    inset: 0;
    opacity: 0.14;
    background-image:
      linear-gradient(rgba(245, 245, 241, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245, 245, 241, 0.08) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: radial-gradient(circle at 58% 45%, black, transparent 68%);
  }

  .soft-orb {
    position: absolute;
    width: 24rem;
    height: 24rem;
    border-radius: 999px;
    filter: blur(44px);
    opacity: 0.26;
    animation: drift 10s ease-in-out infinite alternate;
  }

  .orb-a {
    top: 4%;
    right: 9%;
    background: rgba(105, 210, 84, 0.38);
  }

  .orb-b {
    left: 2%;
    bottom: 8%;
    background: rgba(237, 244, 234, 0.11);
    animation-delay: -4s;
  }

  .setup-header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(1280px, 100%);
    height: 4.6rem;
    margin: 0 auto;
    padding: 0.82rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 1.25rem;
    background: rgba(15, 18, 19, 0.54);
    backdrop-filter: blur(18px) saturate(1.08);
    -webkit-backdrop-filter: blur(18px) saturate(1.08);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
  }

  .setup-logo img {
    width: clamp(148px, 12vw, 205px);
    height: auto;
  }

  .setup-status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    color: rgba(245, 245, 241, 0.76);
    font-size: 0.82rem;
    font-weight: 650;
  }

  .setup-status span {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: #69d254;
    box-shadow: 0 0 0 6px rgba(105, 210, 84, 0.14);
  }

  .setup-layout {
    width: min(1160px, 100%);
    height: calc(100dvh - 6.2rem);
    margin: 1rem auto 0;
    display: grid;
    grid-template-columns: minmax(260px, 0.58fr) minmax(520px, 1.42fr);
    gap: clamp(0.85rem, 1.6vw, 1.35rem);
    align-items: stretch;
  }

  .setup-rail,
  .setup-card {
    min-height: 0;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 1.55rem;
    background: rgba(15, 18, 19, 0.5);
    backdrop-filter: blur(22px) saturate(1.08);
    -webkit-backdrop-filter: blur(22px) saturate(1.08);
    box-shadow: 0 26px 80px rgba(0, 0, 0, 0.26);
  }

  .setup-rail {
    display: flex;
    flex-direction: column;
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .rail-kicker {
    color: rgba(245, 245, 241, 0.5);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .setup-rail h1 {
    margin-top: 0.8rem;
    font-size: clamp(2rem, 3.3vw, 3.8rem);
    line-height: 0.96;
    letter-spacing: -0.055em;
  }

  .rail-copy {
    margin-top: 0.95rem;
    color: rgba(245, 245, 241, 0.64);
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .rail-steps {
    list-style: none;
    display: grid;
    gap: 0.56rem;
    margin-top: auto;
  }

  .rail-steps li {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.68rem;
    padding: 0.64rem;
    border-radius: 0.95rem;
    color: rgba(245, 245, 241, 0.56);
    transition: background 0.22s ease, color 0.22s ease;
  }

  .rail-steps li span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 999px;
    background: rgba(245, 245, 241, 0.08);
    color: rgba(245, 245, 241, 0.62);
    font-size: 0.72rem;
    font-weight: 850;
  }

  .rail-steps li strong {
    font-size: 0.86rem;
  }

  .rail-steps li.active,
  .rail-steps li.complete {
    background: rgba(245, 245, 241, 0.075);
    color: rgba(245, 245, 241, 0.9);
  }

  .rail-steps li.active span,
  .rail-steps li.complete span {
    background: #69d254;
    color: #0f1213;
  }

  .setup-card {
    display: grid;
    grid-template-rows: auto auto minmax(0, 1fr) auto;
    padding: clamp(1rem, 2vw, 1.35rem);
    background: #f5f5f1;
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .hidden,
  .hidden-field {
    display: none !important;
  }

  .card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem;
    border: 1px solid rgba(15, 18, 19, 0.09);
    border-radius: 1.05rem;
    background: rgba(237, 244, 234, 0.7);
  }

  .card-topline span {
    display: block;
    color: rgba(15, 18, 19, 0.5);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .card-topline strong {
    display: block;
    margin-top: 0.1rem;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: 1.42rem;
    font-weight: 400;
    letter-spacing: -0.03em;
  }

  .progress-pill {
    width: min(38%, 13rem);
    height: 0.55rem;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(15, 18, 19, 0.1);
  }

  .progress-pill span {
    display: block;
    width: 16.66%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #69d254, #0f1213);
    transition: width 0.28s ease;
  }

  .step-copy {
    padding: clamp(0.95rem, 1.8vw, 1.25rem) 0 0.8rem;
  }

  .step-copy h2 {
    max-width: 42rem;
    font-size: clamp(2rem, 3.5vw, 3.35rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .step-copy p {
    max-width: 38rem;
    margin-top: 0.65rem;
    color: rgba(15, 18, 19, 0.62);
    line-height: 1.58;
    font-size: 0.94rem;
  }

  .step-viewport {
    position: relative;
    min-height: 0;
    overflow: hidden;
  }

  .form-step {
    display: none;
    border: 0;
    margin: 0;
    padding: 0;
  }

  .form-step.is-active {
    display: grid;
    gap: 0.82rem;
    animation: step-in 0.24s ease both;
  }

  .form-step legend {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .field-grid.two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.78rem;
  }

  label {
    display: grid;
    gap: 0.36rem;
  }

  label span {
    color: rgba(15, 18, 19, 0.7);
    font-size: 0.78rem;
    font-weight: 750;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgba(15, 18, 19, 0.12);
    border-radius: 0.84rem;
    background: #fff;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 0.92rem;
    padding: 0.82rem 0.88rem;
    outline: none;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  textarea {
    min-height: 5.15rem;
    resize: none;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: rgba(105, 210, 84, 0.95);
    box-shadow: 0 0 0 4px rgba(105, 210, 84, 0.15);
  }

  .confirm-row {
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 0.68rem;
    padding: 0.82rem;
    border: 1px solid rgba(15, 18, 19, 0.09);
    border-radius: 0.96rem;
    background: rgba(237, 244, 234, 0.7);
  }

  .confirm-row input {
    width: 1rem;
    height: 1rem;
    margin-top: 0.18rem;
  }

  .confirm-row span {
    line-height: 1.45;
  }

  .card-actions {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.78rem;
    padding-top: 1rem;
  }

  .step-button {
    border: 0;
    border-radius: 999px;
    padding: 0.95rem 1.15rem;
    background: #69d254;
    color: #0f1213;
    font-family: var(--font-body);
    font-weight: 850;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .step-button:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(105, 210, 84, 0.22);
  }

  .step-button:disabled {
    cursor: not-allowed;
    opacity: 0.42;
  }

  .back-button {
    background: transparent;
    border: 1px solid rgba(15, 18, 19, 0.14);
    color: rgba(15, 18, 19, 0.72);
  }

  .next-button {
    grid-column: 2;
  }


  @keyframes step-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes drift {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(-1rem, 1rem, 0) scale(1.05); }
  }

  @media (prefers-reduced-motion: reduce) {
    .soft-orb,
    .form-step.is-active {
      animation: none;
    }

    .progress-pill span,
    .step-button,
    input,
    select,
    textarea {
      transition: none;
    }
  }

  @media (max-width: 1100px) {
    .setup-layout {
      grid-template-columns: minmax(210px, 0.48fr) minmax(0, 1fr);
    }
  }

