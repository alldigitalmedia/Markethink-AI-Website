---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import FinalCTA from "../../components/FinalCTA.astro";
import { insightPosts } from "../../data/blogPosts";

const title = "Marketing Insights for AI, Brand Memory, and Campaign Growth | Markethink";
const description =
  "Read Markethink insights on consistent marketing, brand memory, AI workflows, campaign systems, and turning ideas into client opportunities.";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Markethink Marketing Insights",
    description,
    url: "https://markethink.ai/blog/",
    publisher: {
      "@type": "Organization",
      name: "Markethink",
      url: "https://markethink.ai/",
      logo: "https://markethink.ai/images/logo.svg",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://markethink.ai/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Blog",
        item: "https://markethink.ai/blog/",
      },
    ],
  },
];
---

<Layout title={title} description={description} canonical="https://markethink.ai/blog/" structuredData={structuredData}>
  <Navbar />
  <main class="blog-index">
    <section class="blog-hero">
      <div class="container">
        <p class="subtitle animate-fade-up">MARKETHINK INSIGHTS</p>
        <h1 class="animate-fade-up">Better marketing systems for businesses that want to grow consistently.</h1>
        <p class="blog-hero-copy animate-fade-up">
          Practical thinking on AI marketing, brand memory, campaign workflow, content systems, and turning scattered ideas into client opportunities.
        </p>
      </div>
    </section>

    <section class="section dark">
      <div class="container">
        <a class="featured-guide animate-fade-up" href="/ai-marketing-for-small-business/">
          <span>Start here</span>
          <div>
            <h2>AI marketing for small business</h2>
            <p>How to turn scattered tools, prompts, approvals, and follow-up into a marketing system that ships every week.</p>
          </div>
        </a>
        <div class="insight-grid animate-stagger">
          {insightPosts.map((post) => (
            <article class="insight-card">
              <a href={`/blog/${post.slug}/`} aria-label={`Read ${post.title}`}>
                <div class="insight-image">
                  <img src={post.image} alt={post.imageAlt} loading="lazy" />
                </div>
                <div class="insight-content">
                  <span>{post.category}</span>
                  <h2>{post.title}</h2>
                  <p>{post.excerpt}</p>
                  <div class="insight-meta">
                    <span>{post.readingTime}</span>
                    <span>Updated {new Date(post.updatedDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <FinalCTA />
  <Footer />
</Layout>

<style>
  .blog-index {
    background: var(--bg-primary);
  }

  .blog-hero {
    padding: 10rem 0 4rem;
  }

  .blog-hero h1 {
    max-width: 54rem;
    margin-top: 1rem;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .blog-hero-copy {
    max-width: 43rem;
    margin-top: 1.5rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 1.05rem;
  }

  .featured-guide {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid rgba(105, 210, 84, 0.28);
    border-radius: var(--radius-medium);
    background: rgba(105, 210, 84, 0.07);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .featured-guide:hover {
    transform: translateY(-3px);
    border-color: rgba(105, 210, 84, 0.52);
  }

  .featured-guide span {
    color: var(--color-secondary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .featured-guide h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .featured-guide p {
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.66);
    max-width: 44rem;
  }

  .insight-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .insight-card {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-medium);
    background: rgba(255, 255, 255, 0.02);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .insight-card:hover {
    transform: translateY(-4px);
    border-color: rgba(105, 210, 84, 0.34);
  }

  .insight-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .insight-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .insight-content {
    padding: 1.5rem;
  }

  .insight-content span {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--color-secondary);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .insight-content h2 {
    font-size: clamp(1.7rem, 3vw, 2.35rem);
    line-height: 1.08;
  }

  .insight-content p {
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.64);
  }

  .insight-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.35rem;
  }

  .insight-meta span {
    margin: 0;
    color: rgba(255, 255, 255, 0.44);
    font-size: 0.75rem;
    letter-spacing: 0;
    text-transform: none;
  }

  @media (max-width: 767px) {
    .blog-hero {
      padding-top: 8rem;
    }

    .featured-guide {
      grid-template-columns: 1fr;
    }

    .insight-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
