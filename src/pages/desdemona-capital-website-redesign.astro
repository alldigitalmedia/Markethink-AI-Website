---
import Layout from "../layouts/Layout.astro";

const pageUrl = "https://markethink.ai/desdemona-capital-website-redesign/";
const markethinkLogo = "/images/logo-white.svg";

const slides = [
  {
    n: "01",
    id: "opportunity",
    nav: "Opportunity",
    kicker: "DESDEMONA CAPITAL · WEBSITE REDESIGN",
    title: "A sharper digital front door for the group behind InList and The 0.07%.",
    lead: "Desdemona Capital should feel like the parent company behind serious, high-access brands: clear, current, premium, and easy to understand in the first few seconds.",
    chips: ["Parent company clarity", "Portfolio connection", "Premium trust signal", "Clear next step"],
    details: [
      "Explain Desdemona Capital with more authority and less friction",
      "Connect InList and The 0.07% into a more intentional company story",
      "Make the site feel current, polished, and serious without overbuilding it",
      "Create a better foundation for future announcements, partner conversations, and portfolio growth",
    ],
  },
  {
    n: "02",
    id: "direction",
    nav: "Direction",
    kicker: "DESIGN DIRECTION",
    title: "Premium, minimal, and built around the company’s portfolio gravity.",
    lead: "The redesign should feel like a private capital and brand platform: dark, architectural, restrained, with subtle technology cues and a stronger hierarchy around what Desdemona owns and where it is going.",
    chips: ["Dark editorial system", "Portfolio-led structure", "Luxury-tech restraint", "Sharper hierarchy"],
    details: [
      "A cleaner hero that immediately says what Desdemona Capital is",
      "A portfolio section that treats InList and The 0.07% as high-value assets, not loose links",
      "A visual system with Desdemona blue, charcoal, steel, and controlled light accents",
      "Custom background imagery and interface-style compositions instead of low-resolution borrowed images",
    ],
  },
  {
    n: "03",
    id: "investment",
    nav: "Investment",
    kicker: "INITIAL WEBSITE REDESIGN",
    title: "A focused redesign with a clean investment structure.",
    lead: "The first phase is intentionally scoped: redesign and rebuild the core Desdemona Capital web presence so it looks sharper, reads clearly, works on mobile, and gives the company a stronger base for future content.",
    chips: ["One-time project", "Design + copy", "Responsive build", "Launch-ready review"],
    details: [
      "Investment: USD 2,000 for the initial redesign and rebuild",
      "Homepage structure, refined copy, visual direction, and portfolio flow",
      "Responsive desktop and mobile implementation",
      "Basic SEO setup, metadata, structured sections, and clear contact path",
      "Review version prepared before publishing so final polish is controlled",
    ],
  },
  {
    n: "04",
    id: "tech-layer",
    nav: "Tech layer",
    kicker: "MODERN TECH LAYER",
    title: "Built on current web infrastructure, not a fragile static brochure.",
    lead: "The new site can be built with a modern front-end foundation: fast pages, clean component structure, flexible content sections, strong metadata, analytics-ready events, and room to add richer technology-driven features later.",
    chips: ["Fast front end", "Clean components", "Analytics-ready", "Future pages"],
    details: [
      "Modern architecture for speed, responsive polish, and future expansion",
      "Structured content blocks so new portfolio updates and announcements are easier to add",
      "SEO and social metadata handled cleanly from the start",
      "Analytics-ready interaction structure so future traffic and inquiry paths can be understood",
      "Room for AI-assisted content workflows, richer landing pages, and portfolio storytelling as the company grows",
    ],
  },
  {
    n: "05",
    id: "ongoing",
    nav: "Ongoing",
    kicker: "ONGOING MANAGEMENT",
    title: "After launch, the site can stay active instead of going stale.",
    lead: "The redesign creates the foundation. Ongoing management can keep the site alive with edits, new sections, AI-assisted article drafts, blog posts, technical SEO refreshes, and new pages as Desdemona keeps moving.",
    chips: ["Website management", "AI-assisted content", "Blog posts", "SEO refreshes"],
    details: [
      "Monthly support can be scoped after the redesign based on how active the site needs to be",
      "Blog posts, announcements, and thought-leadership drafts prepared with AI assistance and human review",
      "New portfolio sections, landing pages, and content updates as opportunities come up",
      "Technical SEO and conversion-path improvements over time",
      "A cleaner operating rhythm so the website reflects what the company is actually building",
    ],
  },
];
---

<Layout
  title="Desdemona Capital · Website Redesign Proposal"
  description="A private Markethink proposal for a focused Desdemona Capital website redesign and optional ongoing website management."
  canonical={pageUrl}
  noindex={true}
>
  <main class="proposal" aria-label="Desdemona Capital website redesign proposal">
    <header class="topbar">
      <a href="#opportunity" class="brand-pair" aria-label="Desdemona Capital and Markethink proposal home">
        <span class="desdemona-logo" aria-label="Desdemona Capital">
          <strong>desdemona</strong>
          <em>capital</em>
        </span>
        <span class="pair-x" aria-hidden="true">×</span>
        <img class="markethink-logo" src={markethinkLogo} alt="Markethink" loading="eager" decoding="async" />
      </a>
      <span class="label">Private proposal · website redesign</span>
    </header>

    <aside class="rail" aria-label="Proposal sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`}>
          <span>{slide.n}</span>
          <strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} class:list={["slide", slide.id]}>
        <div class="custom-visual" aria-hidden="true">
          <span class="frame frame-a"></span>
          <span class="frame frame-b"></span>
          <span class="frame frame-c"></span>
          <span class="beam beam-a"></span>
          <span class="beam beam-b"></span>
          <span class="node node-a"></span>
          <span class="node node-b"></span>
          <span class="node node-c"></span>
        </div>
        <div class="gridline" aria-hidden="true"></div>
        <div class="inner">
          <p class="kicker">{slide.kicker}</p>
          <h1>{slide.title}</h1>
          <p class="lead">{slide.lead}</p>
          <div class="chips">
            {slide.chips.map((chip) => <span>{chip}</span>)}
          </div>
          <div class="details">
            {slide.details.map((detail) => <article>{detail}</article>)}
          </div>
        </div>
        <footer class="footer">
          <span>{slide.n} / {slides.length.toString().padStart(2, "0")}</span>
          <span>Desdemona Capital × Markethink</span>
        </footer>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; background: #0f1213; }

  .proposal {
    --charcoal: #0f1213;
    --cream: #f5f5f1;
    --muted: #b4b6b6;
    --green: #69d254;
    --desdemona-blue: #0d72b6;
    --desdemona-ice: #8cc6ea;
    --desdemona-slate: #3e3d40;
    --desdemona-steel: #696969;
    min-height: 100vh;
    background: var(--charcoal);
    color: var(--cream);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    overflow-x: hidden;
  }

  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 34px;
    pointer-events: none;
  }

  .brand-pair {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--cream);
    text-decoration: none;
  }

  .desdemona-logo {
    display: grid;
    line-height: 0.84;
    text-transform: lowercase;
    letter-spacing: -0.06em;
  }

  .desdemona-logo strong,
  .desdemona-logo em {
    font-family: "Century Gothic", Inter, ui-sans-serif, system-ui, sans-serif;
    font-style: normal;
    font-weight: 700;
  }

  .desdemona-logo strong { font-size: 23px; }
  .desdemona-logo em { font-size: 16px; color: rgba(245,245,241,0.72); }
  .pair-x { color: rgba(245,245,241,0.42); font-size: 18px; }
  .markethink-logo { display: block; width: 152px; height: auto; }

  .label {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245,245,241,0.58);
  }

  .rail {
    position: fixed;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 45;
    display: grid;
    gap: 12px;
  }

  .rail a {
    color: rgba(245,245,241,0.42);
    text-decoration: none;
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 8px;
    align-items: center;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .rail span {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border: 1px solid rgba(140,198,234,0.24);
    border-radius: 999px;
    color: var(--desdemona-ice);
  }

  .rail strong { font-weight: 500; }

  .slide {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .slide::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 76% 22%, rgba(13,114,182,0.30), transparent 28%),
      radial-gradient(circle at 20% 82%, rgba(105,210,84,0.10), transparent 34%),
      linear-gradient(115deg, rgba(15,18,19,0.98) 0%, rgba(15,18,19,0.92) 44%, rgba(16,38,53,0.84) 100%);
    z-index: -5;
  }

  .slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15,18,19,0.96), rgba(15,18,19,0.70) 52%, rgba(15,18,19,0.34)),
      repeating-linear-gradient(90deg, rgba(245,245,241,0.035) 0 1px, transparent 1px 84px),
      repeating-linear-gradient(0deg, rgba(245,245,241,0.028) 0 1px, transparent 1px 84px);
    z-index: -4;
  }

  .direction::before { background: radial-gradient(circle at 74% 28%, rgba(140,198,234,0.25), transparent 28%), linear-gradient(120deg, #0f1213 0%, #111619 46%, #22313d 100%); }
  .investment::before { background: radial-gradient(circle at 78% 24%, rgba(105,210,84,0.15), transparent 25%), linear-gradient(120deg, #0f1213 0%, #171716 42%, #33312e 100%); }
  .tech-layer::before { background: radial-gradient(circle at 77% 24%, rgba(13,114,182,0.36), transparent 26%), linear-gradient(120deg, #0f1213 0%, #0d1c27 48%, #173a56 100%); }
  .ongoing::before { background: radial-gradient(circle at 80% 22%, rgba(140,198,234,0.18), transparent 26%), radial-gradient(circle at 58% 72%, rgba(105,210,84,0.09), transparent 28%), linear-gradient(120deg, #0f1213 0%, #181b1d 44%, #30343a 100%); }

  .custom-visual {
    position: absolute;
    right: 6vw;
    top: 17vh;
    width: min(520px, 42vw);
    height: min(560px, 62vh);
    z-index: -2;
    opacity: 0.95;
  }

  .frame,
  .beam,
  .node { position: absolute; display: block; }

  .frame {
    border: 1px solid rgba(140,198,234,0.28);
    background: linear-gradient(135deg, rgba(245,245,241,0.13), rgba(13,114,182,0.12));
    box-shadow: 0 28px 80px rgba(0,0,0,0.38), inset 0 1px 0 rgba(245,245,241,0.14);
    backdrop-filter: blur(12px);
  }

  .frame-a { width: 74%; height: 40%; right: 0; top: 0; border-radius: 30px; }
  .frame-b { width: 52%; height: 46%; left: 6%; top: 28%; border-radius: 26px; }
  .frame-c { width: 64%; height: 24%; right: 8%; bottom: 4%; border-radius: 999px; }

  .beam {
    height: 2px;
    transform-origin: left center;
    background: linear-gradient(90deg, transparent, rgba(140,198,234,0.75), rgba(105,210,84,0.54), transparent);
    box-shadow: 0 0 28px rgba(140,198,234,0.35);
  }

  .beam-a { width: 78%; left: 12%; top: 50%; transform: rotate(-18deg); }
  .beam-b { width: 62%; left: 22%; top: 66%; transform: rotate(14deg); }

  .node {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: var(--green);
    box-shadow: 0 0 0 9px rgba(105,210,84,0.10), 0 0 28px rgba(105,210,84,0.52);
  }

  .node-a { right: 12%; top: 12%; }
  .node-b { left: 18%; top: 48%; background: var(--desdemona-ice); box-shadow: 0 0 0 9px rgba(140,198,234,0.10), 0 0 28px rgba(140,198,234,0.52); }
  .node-c { right: 26%; bottom: 12%; }

  .investment .frame-a::after {
    content: "Investment";
    position: absolute;
    left: 24px;
    top: 22px;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245,245,241,0.62);
  }

  .investment .frame-b::after {
    content: "Initial redesign · one-time project";
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 22px;
    color: rgba(245,245,241,0.72);
    font-size: 18px;
    line-height: 1.25;
  }

  .gridline {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(245,245,241,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(245,245,241,0.04) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at 70% 45%, black, transparent 62%);
    z-index: -1;
  }

  .inner {
    position: relative;
    z-index: 2;
    width: min(920px, calc(100vw - 240px));
    margin-left: clamp(34px, 8vw, 116px);
    padding: 110px 0 86px;
  }

  .kicker {
    margin: 0 0 20px;
    color: var(--desdemona-ice);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 880px;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: clamp(52px, 7.6vw, 104px);
    line-height: 0.92;
    letter-spacing: -0.055em;
    font-weight: 400;
  }

  .lead {
    max-width: 720px;
    margin: 26px 0 0;
    color: rgba(245,245,241,0.76);
    font-size: clamp(18px, 1.8vw, 25px);
    line-height: 1.42;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
    max-width: 760px;
  }

  .chips span {
    border: 1px solid rgba(140,198,234,0.24);
    border-radius: 999px;
    padding: 10px 14px;
    background: rgba(13,114,182,0.16);
    color: rgba(245,245,241,0.86);
    font-size: 13px;
  }

  .details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    max-width: 820px;
    margin-top: 34px;
  }

  .details article {
    padding: 18px 18px 18px 20px;
    border: 1px solid rgba(245,245,241,0.12);
    border-radius: 22px;
    background: rgba(245,245,241,0.055);
    color: rgba(245,245,241,0.72);
    line-height: 1.42;
    box-shadow: inset 3px 0 0 rgba(140,198,234,0.30);
  }

  .investment .details article:first-child {
    background: rgba(140,198,234,0.14);
    border-color: rgba(140,198,234,0.32);
    color: var(--cream);
    font-weight: 700;
  }

  .footer {
    position: absolute;
    left: clamp(34px, 8vw, 116px);
    right: 34px;
    bottom: 24px;
    display: flex;
    justify-content: space-between;
    color: rgba(245,245,241,0.42);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .topbar { padding: 18px; }
    .markethink-logo { width: 124px; }
    .desdemona-logo strong { font-size: 18px; }
    .desdemona-logo em { font-size: 13px; }
    .label, .rail { display: none; }
    .custom-visual { right: -28vw; top: 10vh; width: 74vw; opacity: 0.48; }
    .inner { width: calc(100vw - 36px); margin-left: 18px; padding-top: 120px; }
    h1 { font-size: clamp(44px, 14vw, 72px); }
    .details { grid-template-columns: 1fr; }
    .footer { left: 18px; right: 18px; }
  }
</style>
