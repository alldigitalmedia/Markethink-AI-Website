---
import Layout from "../layouts/Layout.astro";

const pageUrl = "https://markethink.ai/desdemona-capital-website-redesign/";
const markethinkLogo = "/images/logo-white.svg";
const desdemonaAssetBase = "https://www.desdemonacapital.com";

const slides = [
  {
    n: "01",
    id: "opportunity",
    nav: "Opportunity",
    kicker: "DESDEMONA CAPITAL · WEBSITE REDESIGN",
    title: "Desdemona needs a sharper digital front door for the group behind InList and The 0.07%.",
    lead: "The current site should do more than exist. It should quickly explain the parent company, connect the portfolio, signal credibility, and give the right visitor a clear path to the next conversation.",
    image: `${desdemonaAssetBase}/equity/the007.webp`,
    chips: ["Parent company clarity", "Portfolio connection", "Premium trust signal", "Clear next step"],
    details: [
      "Create a cleaner first impression for Desdemona Capital",
      "Position InList and The 0.07% as part of a more intentional company ecosystem",
      "Make the site feel current, premium, and serious without becoming overbuilt",
      "Prepare the structure for future content, announcements, and investor or partner conversations",
    ],
  },
  {
    n: "02",
    id: "redesign",
    nav: "Redesign",
    kicker: "ONE-TIME WEBSITE REFRESH",
    title: "$2,000 one-time redesign and rebuild.",
    lead: "A focused redesign to give Desdemona Capital a modern, high-end website foundation: stronger page structure, sharper copy, refined visual direction, mobile polish, and a clearer path into the brands it owns.",
    image: `${desdemonaAssetBase}/equity/villazzo.webp`,
    chips: ["Strategy", "Design", "Copy", "Build"],
    details: [
      "Homepage redesign with a stronger company narrative and portfolio flow",
      "Premium visual system: typography, spacing, dark luxury palette, brand-level polish",
      "Responsive build for desktop and mobile",
      "Basic SEO setup, metadata, structured sections, and clear contact path",
      "Launch-ready review version before publishing",
    ],
  },
  {
    n: "03",
    id: "ongoing",
    nav: "Ongoing",
    kicker: "ONGOING MANAGEMENT + MODERN TECH LAYER",
    title: "After launch, the site can become a managed content and technology surface.",
    lead: "The redesign creates the foundation. Ongoing management keeps it alive: updates, AI-assisted article production, blog posts, technical SEO, analytics-ready improvements, and new pages as the company keeps moving.",
    image: `${desdemonaAssetBase}/press/prestige.webp`,
    chips: ["AI-assisted content", "Blog posts", "Technical SEO", "Website management"],
    details: [
      "Modern front-end foundation built for speed, clean structure, and future page expansion",
      "AI-assisted content workflow for blog posts, announcements, and thought-leadership drafts — with human review before anything goes live",
      "Ongoing website management for edits, new sections, portfolio updates, and conversion improvements",
      "Analytics-ready event structure so future traffic, inquiry, and content performance can be understood",
      "Optional monthly support can be scoped after the redesign: content, blog posts, SEO refreshes, and new page creation",
    ],
  },
];
---

<Layout
  title="Desdemona Capital · Website Redesign Proposal"
  description="A private Markethink proposal for a focused Desdemona Capital website redesign and optional ongoing website management."
  canonical={pageUrl}
  noindex={true}
>
  <main class="proposal" aria-label="Desdemona Capital website redesign proposal">
    <header class="topbar">
      <a href="#opportunity" class="brand-pair" aria-label="Desdemona Capital and Markethink proposal home">
        <span class="desdemona-logo" aria-label="Desdemona Capital">
          <strong>desdemona</strong>
          <em>capital</em>
        </span>
        <span class="pair-x" aria-hidden="true">×</span>
        <img class="markethink-logo" src={markethinkLogo} alt="Markethink" loading="eager" decoding="async" />
      </a>
      <span class="label">Private proposal · website redesign</span>
    </header>

    <aside class="rail" aria-label="Proposal sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`}>
          <span>{slide.n}</span>
          <strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} class:list={["slide", slide.id]} style={`--slide-image: url('${slide.image}')`}>
        <div class="orb orb-a" aria-hidden="true"></div>
        <div class="orb orb-b" aria-hidden="true"></div>
        <div class="gridline" aria-hidden="true"></div>
        <div class="inner">
          <p class="kicker">{slide.kicker}</p>
          <h1>{slide.title}</h1>
          <p class="lead">{slide.lead}</p>
          <div class="chips">
            {slide.chips.map((chip) => <span>{chip}</span>)}
          </div>
          <div class="details">
            {slide.details.map((detail) => <article>{detail}</article>)}
          </div>
        </div>
        <footer class="footer">
          <span>{slide.n} / {slides.length.toString().padStart(2, "0")}</span>
          <span>Desdemona Capital × Markethink</span>
        </footer>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; background: #0f1213; }

  .proposal {
    --charcoal: #0f1213;
    --cream: #f5f5f1;
    --muted: #b4b6b6;
    --green: #69d254;
    --desdemona-blue: #0d72b6;
    --desdemona-slate: #3e3d40;
    --desdemona-steel: #696969;
    --wash: #edf4ea;
    min-height: 100vh;
    background: var(--charcoal);
    color: var(--cream);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    overflow-x: hidden;
  }

  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 34px;
    pointer-events: none;
  }

  .brand-pair {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--cream);
    text-decoration: none;
  }

  .desdemona-logo {
    display: grid;
    line-height: 0.84;
    text-transform: lowercase;
    letter-spacing: -0.06em;
  }

  .desdemona-logo strong,
  .desdemona-logo em {
    font-family: "Century Gothic", Inter, ui-sans-serif, system-ui, sans-serif;
    font-style: normal;
    font-weight: 700;
  }

  .desdemona-logo strong { font-size: 23px; }
  .desdemona-logo em { font-size: 16px; color: rgba(245,245,241,0.72); }

  .pair-x {
    color: rgba(245,245,241,0.42);
    font-size: 18px;
  }

  .markethink-logo {
    display: block;
    width: 152px;
    height: auto;
  }

  .label {
    color: rgba(245,245,241,0.72);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .rail {
    position: fixed;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 15;
    display: grid;
    gap: 10px;
  }

  .rail a {
    width: 108px;
    padding: 10px 12px;
    border: 1px solid rgba(245,245,241,0.12);
    border-radius: 999px;
    color: rgba(245,245,241,0.78);
    text-decoration: none;
    background: rgba(15,18,19,0.5);
    backdrop-filter: blur(14px);
    display: flex;
    justify-content: space-between;
    gap: 8px;
    font-size: 11px;
  }

  .rail strong { font-weight: 600; }

  .slide {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 120px 120px 80px;
    isolation: isolate;
    overflow: hidden;
  }

  .slide::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15,18,19,0.92) 0%, rgba(15,18,19,0.82) 42%, rgba(15,18,19,0.54) 100%),
      linear-gradient(180deg, rgba(15,18,19,0.36), rgba(15,18,19,0.82)),
      var(--slide-image) center / cover no-repeat,
      var(--charcoal);
    z-index: -4;
  }

  .slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 20%, rgba(13,114,182,0.30), transparent 28%),
      radial-gradient(circle at 18% 80%, rgba(105,210,84,0.10), transparent 34%),
      linear-gradient(90deg, rgba(35,111,159,0.16), transparent 42%);
    mix-blend-mode: screen;
    opacity: 0.78;
    z-index: -3;
  }

  .redesign::before {
    background:
      linear-gradient(90deg, rgba(15,18,19,0.92) 0%, rgba(15,18,19,0.76) 48%, rgba(15,18,19,0.48) 100%),
      linear-gradient(135deg, rgba(13,114,182,0.16), rgba(105,210,84,0.06)),
      var(--slide-image) center / cover no-repeat,
      #0f1213;
  }

  .ongoing::before {
    background:
      linear-gradient(90deg, rgba(15,18,19,0.94) 0%, rgba(15,18,19,0.82) 44%, rgba(15,18,19,0.50) 100%),
      linear-gradient(135deg, rgba(62,61,64,0.36), rgba(13,114,182,0.18)),
      var(--slide-image) center / cover no-repeat,
      #0f1213;
  }

  .gridline {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(245,245,241,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,245,241,0.05) 1px, transparent 1px);
    background-size: 82px 82px;
    mask-image: radial-gradient(circle at 50% 50%, black, transparent 72%);
    z-index: -1;
  }

  .orb {
    position: absolute;
    border: 1px solid rgba(105,210,84,0.22);
    border-radius: 999px;
    z-index: -1;
  }

  .orb-a { width: 540px; height: 540px; right: -140px; top: 14%; }
  .orb-b { width: 300px; height: 300px; left: 7%; bottom: 10%; opacity: 0.55; }

  .inner {
    width: min(1040px, 100%);
  }

  .kicker {
    margin: 0 0 24px;
    color: #8cc6ea;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 960px;
    margin: 0;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: clamp(54px, 7vw, 108px);
    line-height: 0.9;
    letter-spacing: -0.055em;
    font-weight: 400;
  }

  .lead {
    max-width: 820px;
    margin: 30px 0 0;
    color: rgba(245,245,241,0.78);
    font-size: clamp(19px, 2vw, 27px);
    line-height: 1.35;
    letter-spacing: -0.035em;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }

  .chips span {
    border: 1px solid rgba(140,198,234,0.24);
    border-radius: 999px;
    padding: 10px 14px;
    background: rgba(13,114,182,0.16);
    color: rgba(245,245,241,0.86);
    font-size: 13px;
    font-weight: 600;
  }

  .details {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
    margin-top: 54px;
  }

  .details article {
    min-height: 116px;
    border: 1px solid rgba(245,245,241,0.12);
    border-radius: 24px;
    padding: 20px;
    background: rgba(245,245,241,0.075);
    color: rgba(245,245,241,0.82);
    line-height: 1.38;
    font-size: 14px;
  }

  .redesign .details article:nth-child(1),
  .ongoing .details article:nth-child(2) {
    background: rgba(13,114,182,0.22);
    border-color: rgba(140,198,234,0.38);
  }

  .footer {
    position: absolute;
    left: 34px;
    right: 34px;
    bottom: 26px;
    display: flex;
    justify-content: space-between;
    color: rgba(245,245,241,0.42);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .topbar { padding: 18px; }
    .markethink-logo { width: 124px; }
    .desdemona-logo strong { font-size: 18px; }
    .desdemona-logo em { font-size: 13px; }
    .label, .rail { display: none; }
    .slide { padding: 96px 22px 70px; place-items: start; }
    h1 { font-size: clamp(44px, 15vw, 74px); }
    .details { grid-template-columns: 1fr; margin-top: 34px; }
    .details article { min-height: auto; }
    .footer { left: 22px; right: 22px; }
  }
</style>

