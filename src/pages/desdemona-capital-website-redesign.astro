---
import Layout from "../layouts/Layout.astro";

const pageUrl = "https://markethink.ai/desdemona-capital-website-redesign/";
const markethinkLogo = "/images/logo-white.svg";
const customAssetBase = "https://dashboard.markethink.ai/generated/landing/markethink/desdemona-capital-website-redesign";

const slides = [
  {
    n: "01",
    id: "opportunity",
    nav: "Opportunity",
    kicker: "DESDEMONA CAPITAL · WEBSITE REDESIGN",
    title: "A more credible first impression for Desdemona Capital.",
    lead: "The website should make the company feel as strong as the brands behind it: clear ownership, a polished portfolio story, and a professional path for partners, investors, and future opportunities.",
    image: `${customAssetBase}/01-opportunity.png`,
    chips: ["Parent company clarity", "Portfolio connection", "Premium trust signal", "Clear next step"],
    details: [
      "Clarify what Desdemona Capital is and why the portfolio belongs together",
      "Present InList and The 0.07% as deliberate assets, not isolated links",
      "Replace a thin web presence with a controlled, executive-grade narrative",
      "Create a stronger base for partner conversations, announcements, and future portfolio growth",
    ],
  },
  {
    n: "02",
    id: "direction",
    nav: "Direction",
    kicker: "DESIGN DIRECTION",
    title: "A private-capital site, not a generic company page.",
    lead: "The design should feel disciplined and current: restrained typography, dark editorial surfaces, discreet technology cues, and a portfolio structure that makes Desdemona look intentional from the first screen.",
    image: `${customAssetBase}/02-direction.png`,
    chips: ["Dark editorial system", "Portfolio-led structure", "Luxury-tech restraint", "Sharper hierarchy"],
    details: [
      "A hero section that explains the company without making the visitor work",
      "A portfolio narrative that gives each brand context and strategic weight",
      "A visual system using Desdemona blue, charcoal, steel, and controlled light accents",
      "Custom high-end imagery and interface-style compositions instead of low-resolution borrowed assets",
    ],
  },
  {
    n: "03",
    id: "investment",
    nav: "Investment",
    kicker: "INITIAL WEBSITE REDESIGN",
    title: "Initial investment: a focused redesign and rebuild.",
    lead: "The first phase keeps the scope tight: rebuild the core website so it looks credible, reads clearly, works properly on mobile, and gives Desdemona a better foundation without turning this into an oversized project.",
    image: `${customAssetBase}/03-investment.png`,
    chips: ["One-time project", "Design + copy", "Responsive build", "Launch-ready review"],
    details: [
      "Investment: USD 2,000 for the initial redesign and rebuild",
      "Homepage structure, refined copy, visual direction, and portfolio flow",
      "Responsive desktop and mobile implementation",
      "Basic SEO setup, metadata, structured sections, and a clear contact path",
      "Private review version before publishing so final polish stays controlled",
    ],
  },
  {
    n: "04",
    id: "tech-layer",
    nav: "Tech layer",
    kicker: "MODERN TECH LAYER",
    title: "Modern infrastructure, with room to grow.",
    lead: "The rebuild can use a fast, component-based front end with clean metadata, analytics-ready sections, and flexible content blocks — so the site can support future articles, portfolio updates, landing pages, and technology-led features without starting over.",
    image: `${customAssetBase}/04-tech.png`,
    chips: ["Fast front end", "Clean components", "Analytics-ready", "Future pages"],
    details: [
      "Modern architecture for speed, responsive polish, and future expansion",
      "Structured content blocks for portfolio updates, announcements, and future pages",
      "SEO and social metadata handled cleanly from the start",
      "Analytics-ready interaction structure for traffic, inquiry, and content visibility",
      "Room for AI-assisted content workflows and richer portfolio storytelling as the company grows",
    ],
  },
  {
    n: "05",
    id: "ongoing",
    nav: "Ongoing",
    kicker: "ONGOING MANAGEMENT",
    title: "Optional ongoing management after launch.",
    lead: "Once the redesign is live, Desdemona can keep the site current with a light monthly support layer: updates, blog/article drafts, technical SEO refreshes, new pages, and content improvements as the company has more to say.",
    image: `${customAssetBase}/05-ongoing.png`,
    chips: ["Website management", "AI-assisted content", "Blog posts", "SEO refreshes"],
    details: [
      "Monthly support scoped after the redesign based on how active the site needs to be",
      "Blog posts, announcements, and thought-leadership drafts prepared with AI assistance and human review",
      "New portfolio sections, landing pages, and content updates as opportunities come up",
      "Technical SEO and conversion-path improvements over time",
      "A cleaner rhythm so the website reflects what the company is actually building",
    ],
  },
];
---

<Layout
  title="Desdemona Capital · Website Redesign Proposal"
  description="A private Markethink proposal for a focused Desdemona Capital website redesign and optional ongoing website management."
  canonical={pageUrl}
  noindex={true}
>
  <main class="proposal" aria-label="Desdemona Capital website redesign proposal">
    <header class="topbar">
      <a href="#opportunity" class="brand-pair" aria-label="Desdemona Capital and Markethink proposal home">
        <span class="desdemona-logo" aria-label="Desdemona Capital">
          <strong>desdemona</strong>
          <em>capital</em>
        </span>
        <span class="pair-x" aria-hidden="true">×</span>
        <img class="markethink-logo" src={markethinkLogo} alt="Markethink" loading="eager" decoding="async" />
      </a>
      <span class="label">Private proposal · website redesign</span>
    </header>

    <aside class="rail" aria-label="Proposal sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`}>
          <span>{slide.n}</span>
          <strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} class:list={["slide", slide.id]} style={`--slide-image: url('${slide.image}')`}>
        <div class="gridline" aria-hidden="true"></div>
        <div class="inner">
          <p class="kicker">{slide.kicker}</p>
          <h1>{slide.title}</h1>
          <p class="lead">{slide.lead}</p>
          <div class="chips">
            {slide.chips.map((chip) => <span>{chip}</span>)}
          </div>
          <div class="details">
            {slide.details.map((detail) => <article>{detail}</article>)}
          </div>
        </div>
        <footer class="footer">
          <span>{slide.n} / {slides.length.toString().padStart(2, "0")}</span>
          <span>Desdemona Capital × Markethink</span>
        </footer>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; background: #0f1213; }

  .proposal {
    --charcoal: #0f1213;
    --cream: #f5f5f1;
    --muted: #b4b6b6;
    --green: #69d254;
    --desdemona-blue: #0d72b6;
    --desdemona-ice: #8cc6ea;
    --desdemona-slate: #3e3d40;
    --desdemona-steel: #696969;
    min-height: 100vh;
    background: var(--charcoal);
    color: var(--cream);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    overflow-x: hidden;
  }

  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 34px;
    pointer-events: none;
  }

  .brand-pair {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--cream);
    text-decoration: none;
  }

  .desdemona-logo {
    display: grid;
    line-height: 0.84;
    text-transform: lowercase;
    letter-spacing: -0.06em;
  }

  .desdemona-logo strong,
  .desdemona-logo em {
    font-family: "Century Gothic", Inter, ui-sans-serif, system-ui, sans-serif;
    font-style: normal;
    font-weight: 700;
  }

  .desdemona-logo strong { font-size: 23px; }
  .desdemona-logo em { font-size: 16px; color: rgba(245,245,241,0.72); }
  .pair-x { color: rgba(245,245,241,0.42); font-size: 18px; }
  .markethink-logo { display: block; width: 152px; height: auto; }

  .label {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245,245,241,0.58);
  }

  .rail {
    position: fixed;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 45;
    display: grid;
    gap: 12px;
  }

  .rail a {
    color: rgba(245,245,241,0.42);
    text-decoration: none;
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 8px;
    align-items: center;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .rail span {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border: 1px solid rgba(140,198,234,0.24);
    border-radius: 999px;
    color: var(--desdemona-ice);
  }

  .rail strong { font-weight: 500; }

  .slide {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .slide::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15,18,19,0.98) 0%, rgba(15,18,19,0.88) 42%, rgba(15,18,19,0.44) 100%),
      linear-gradient(180deg, rgba(15,18,19,0.32), rgba(15,18,19,0.82)),
      var(--slide-image) center / cover no-repeat,
      var(--charcoal);
    z-index: -5;
  }

  .slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15,18,19,0.96), rgba(15,18,19,0.70) 52%, rgba(15,18,19,0.34)),
      repeating-linear-gradient(90deg, rgba(245,245,241,0.035) 0 1px, transparent 1px 84px),
      repeating-linear-gradient(0deg, rgba(245,245,241,0.028) 0 1px, transparent 1px 84px);
    z-index: -4;
  }

  .direction::before,
  .investment::before,
  .tech-layer::before,
  .ongoing::before {
    background:
      linear-gradient(90deg, rgba(15,18,19,0.98) 0%, rgba(15,18,19,0.86) 40%, rgba(15,18,19,0.42) 100%),
      linear-gradient(180deg, rgba(15,18,19,0.25), rgba(15,18,19,0.82)),
      var(--slide-image) center / cover no-repeat,
      var(--charcoal);
  }

  .gridline {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(245,245,241,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(245,245,241,0.04) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at 70% 45%, black, transparent 62%);
    z-index: -1;
  }

  .inner {
    position: relative;
    z-index: 2;
    width: min(920px, calc(100vw - 240px));
    margin-left: clamp(34px, 8vw, 116px);
    padding: 110px 0 86px;
  }

  .kicker {
    margin: 0 0 20px;
    color: var(--desdemona-ice);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    max-width: 760px;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: clamp(42px, 5.8vw, 78px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    font-weight: 400;
  }

  .lead {
    max-width: 760px;
    margin: 26px 0 0;
    color: rgba(245,245,241,0.76);
    font-size: clamp(17px, 1.45vw, 22px);
    line-height: 1.42;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
    max-width: 760px;
  }

  .chips span {
    border: 1px solid rgba(140,198,234,0.24);
    border-radius: 999px;
    padding: 10px 14px;
    background: rgba(13,114,182,0.16);
    color: rgba(245,245,241,0.86);
    font-size: 13px;
  }

  .details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    max-width: 820px;
    margin-top: 34px;
  }

  .details article {
    padding: 18px 18px 18px 20px;
    border: 1px solid rgba(245,245,241,0.12);
    border-radius: 22px;
    background: rgba(245,245,241,0.055);
    color: rgba(245,245,241,0.72);
    line-height: 1.42;
    box-shadow: inset 3px 0 0 rgba(140,198,234,0.30);
  }

  .investment .details article:first-child {
    background: rgba(140,198,234,0.14);
    border-color: rgba(140,198,234,0.32);
    color: var(--cream);
    font-weight: 700;
  }

  .footer {
    position: absolute;
    left: clamp(34px, 8vw, 116px);
    right: 34px;
    bottom: 24px;
    display: flex;
    justify-content: space-between;
    color: rgba(245,245,241,0.42);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .topbar { padding: 18px; }
    .markethink-logo { width: 124px; }
    .desdemona-logo strong { font-size: 18px; }
    .desdemona-logo em { font-size: 13px; }
    .label, .rail { display: none; }
    .inner { width: calc(100vw - 36px); margin-left: 18px; padding-top: 120px; }
    h1 { font-size: clamp(36px, 10vw, 58px); }
    .details { grid-template-columns: 1fr; }
    .footer { left: 18px; right: 18px; }
  }
</style>
