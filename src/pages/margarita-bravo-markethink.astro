---
import Layout from "../layouts/Layout.astro";

const deckUrl = "https://markethink.ai/margarita-bravo-markethink/";
const assetBase = "https://dashboard.markethink.ai/generated/landing/markethink/margarita-bravo-markethink";
const margaritaLogo = `${assetBase}/margarita-bravo-logo-light.png`;
const markethinkLogo = `${assetBase}/markethink-logo-white.svg`;

const images = {
  opening: `${assetBase}/custom-01-opening.png`,
  opportunity: `${assetBase}/custom-02-opportunity.png`,
  system: `${assetBase}/custom-03-system.png`,
  memory: `${assetBase}/custom-04-memory-v2.png`,
  foundation: `${assetBase}/custom-06-foundation.png`,
  growth: `${assetBase}/custom-07-growth.png`,
  revenue: `${assetBase}/custom-08-revenue.png`,
  alignment: `${assetBase}/custom-09-alignment.png`,
  next: `${assetBase}/custom-10-next.png`,
};

const slides = [
  {
    n: "01",
    id: "opening",
    nav: "Opening",
    kicker: "MARGARITA BRAVO × MARKETHINK",
    title: "A marketing and sales system for Margarita Bravo, built to turn brand strength into signed client relationships.",
    lead: "Markethink learns the business, organizes campaigns, keeps approval memory, supports sales follow-up, and helps the team ship polished marketing every week. The work stays connected from first impression to signed client relationship.",
    image: images.opening,
    tone: "hero",
    chips: ["Marketing and sales system", "Approval memory", "Weekly rhythm", "Signed relationships"],
  },
  {
    n: "02",
    id: "opportunity",
    nav: "Opportunity",
    kicker: "THE OPPORTUNITY",
    title: "Margarita Bravo already has the taste, reputation, and body of work. Now marketing and sales need the same discipline.",
    lead: "The brand does not need more noise. It needs a calmer operating rhythm: stronger visibility, clearer inquiry paths, better follow-up, and campaigns that carry the same level of taste as the work itself.",
    image: images.opportunity,
    tone: "light",
    chips: ["Refined visibility", "Qualified inquiries", "Sharper sales language", "Follow-up structure"],
    details: [
      "Keep content, approvals, campaign notes, and opportunities in one place",
      "Turn existing assets into a steady marketing rhythm",
      "Support qualified client conversations, sales material, and follow-up without adding internal complexity",
      "Let each approved piece inform the next one",
    ],
  },
  {
    n: "03",
    id: "markethink-system",
    nav: "System",
    kicker: "MARKETING AND SALES",
    title: "A working layer for Margarita Bravo’s marketing and sales.",
    lead: "Markethink becomes the working layer behind the marketing and sales motion. It helps shape messaging, prepare social and website updates, draft email and outreach, organize inquiries and opportunities, and keep every follow-up connected to the brand.",
    image: images.system,
    tone: "system",
    chips: ["Brand language", "Campaign planning", "Sales follow-up", "Opportunity tracking"],
    details: [
      "Markethink learns the brand, services, tone, client profiles, and sales preferences",
      "Campaigns, content, inquiries, proposals, approvals, and follow-up stay connected",
      "The system remembers what was approved, who needs follow-up, and what should move next",
      "Markethink supports the work, while the humans keep control of every decision",
    ],
  },
  {
    n: "04",
    id: "marketing-memory",
    nav: "Memory",
    kicker: "MARKETING AND SALES MEMORY",
    title: "The marketing and sales memory stays with the business.",
    lead: "Teams change. Vendors change. Priorities change. Markethink keeps the brand voice, approvals, campaign context, client signals, and follow-up history from disappearing every time the setup changes.",
    image: images.memory,
    tone: "warm",
    chips: ["Brand voice", "Approved sales language", "Client signals", "Opportunity history"],
    details: [
      "Learns the brand, services, assets, approvals, and preferences",
      "Remembers what language should be repeated and what should be avoided",
      "Keeps inquiry notes, sales context, and follow-up next steps from getting scattered",
      "Gets sharper as more real work moves through it",
    ],
  },
  {
    n: "05",
    id: "foundation",
    nav: "Foundation",
    kicker: "PACKAGE 01",
    title: "Foundation system",
    lead: "A polished monthly operating base for keeping the brand visible, organized, and easier to follow up with, without asking the team to manage every moving part."
    image: images.foundation,
    tone: "package light",
    package: {
      standardPrice: "$1,500/mo",
      launchPrice: "$1,000/mo",
      note: "Preferred launch rate",
      socialLabel: "Core social presence",
      channels: [
        { name: "Instagram", key: "instagram" },
        { name: "Pinterest", key: "pinterest" },
        { name: "Facebook", key: "facebook" },
      ],
    },
    chips: ["Polished monthly content", "Search-friendly blog", "Website priority list", "Inquiry follow-up notes"],
    details: [
      "Dedicated Margarita Bravo workspace with brand voice, approvals, assets, and sales context organized",
      "Monthly content calendar with refined post concepts, captions, and campaign priorities",
      "Website and search hygiene so services, calls to action, and inquiry paths stay current",
      "Inquiry notes and follow-up context captured so promising conversations do not disappear",
    ],
  },
  {
    n: "06",
    id: "growth",
    nav: "Growth",
    kicker: "PACKAGE 02 · RECOMMENDED",
    title: "Growth system",
    lead: "The recommended starting point: enough weekly activity to keep the brand visible, create more reasons to inquire, and turn interest into organized sales follow-up.",
    image: images.growth,
    tone: "package system",
    package: {
      standardPrice: "$2,000/mo",
      launchPrice: "$1,500/mo",
      note: "Preferred launch rate · recommended",
      socialLabel: "Expanded social presence",
      channels: [
        { name: "Instagram", key: "instagram" },
        { name: "Pinterest", key: "pinterest" },
        { name: "Facebook", key: "facebook" },
        { name: "LinkedIn", key: "linkedin" },
        { name: "YouTube", key: "youtube" },
      ],
    },
    chips: ["5 posts weekly", "1 light video weekly", "2 blogs monthly", "1 email campaign monthly"],
    details: [
      "Everything in Foundation, with deeper brand, audience, service, and approval memory",
      "Website management support, page refreshes, stronger inquiry paths, and better conversion flow",
      "Newsletter or email campaign each month, connected to the content rhythm",
      "Opportunity tracking, inquiry organization, sales follow-up drafts, and source notes",
    ],
  },
  {
    n: "07",
    id: "revenue-visibility",
    nav: "Revenue",
    kicker: "PACKAGE 03",
    title: "Revenue and visibility system",
    lead: "The most complete option for daily visibility, stronger sales support, outreach, paid campaign coordination, and a closer connection between marketing activity and signed opportunities.",
    image: images.revenue,
    tone: "package dark",
    package: {
      standardPrice: "$2,500/mo",
      launchPrice: "$2,000/mo",
      note: "Preferred launch rate",
      socialLabel: "Full visibility and follow-up mix",
      channels: [
        { name: "Instagram", key: "instagram" },
        { name: "Pinterest", key: "pinterest" },
        { name: "Facebook", key: "facebook" },
        { name: "LinkedIn", key: "linkedin" },
        { name: "YouTube", key: "youtube" },
        { name: "Email", key: "email" },
        { name: "Search", key: "search" },
      ],
    },
    chips: ["Daily posting", "2 videos weekly", "Sales outreach support", "Ads management support"],
    details: [
      "Everything in Growth, expanded into a fuller marketing and sales operating rhythm",
      "Two email campaigns monthly plus priority campaign, landing-page, and sales-message support",
      "Deeper opportunity management, prospect notes, follow-up tracking, sales outreach drafts, and reactivation support",
      "Light office support connected to marketing workflows, inquiries, and client opportunities. Ad spend stays separate",
    ],
  },
  {
    n: "08",
    id: "performance-alignment",
    nav: "Alignment",
    kicker: "PREFERRED PRICING + PERFORMANCE ALIGNMENT",
    title: "Lower fixed cost, with upside tied to real signed relationships.",
    lead: "The preferred launch pricing keeps the monthly commitment efficient. The upside is tied to sales movement: the success fee only applies when Markethink helps generate, advance, or materially support a new client relationship that signs and pays.",
    image: images.alignment,
    tone: "light",
    chips: ["Signed relationships", "Sales movement", "Clear attribution", "3% of first paid engagement"],
    details: [
      "Applies across all packages",
      "Tied to a new client relationship that is generated, advanced, signs, and pays",
      "Can come through website inquiries, email, search, social, ads, outreach, sales follow-up, or reactivation",
      "Recommended structure: 3% of the first paid engagement, payable only after Margarita Bravo receives payment",
    ],
  },
  {
    n: "09",
    id: "next-step",
    nav: "Next step",
    kicker: "RECOMMENDED PATH",
    title: "Start with the Growth system and build Margarita Bravo’s marketing and sales memory with care.",
    lead: "The Growth system gives Markethink enough weekly activity to produce useful work from the first cycle: content, website support, email, inquiry organization, opportunity tracking, and sales follow-up.",
    image: images.next,
    tone: "closing",
    chips: ["$1,500 per month preferred launch", "Marketing and sales memory", "Weekly visibility", "Success fee alignment"],
    details: [
      "Approve the package and first month priorities",
      "Confirm the first social channels and content sources",
      "Train Markethink on the brand, offer, services, audience, assets, approvals, sales language, and follow-up preferences",
      "Begin the first content, website, campaign, inquiry, and sales follow-up cycle",
    ],
  },
];
---

<Layout
  title="Margarita Bravo × Markethink · Private Proposal"
  description="A private Markethink proposal presentation for Margarita Bravo."
  image={images.opening}
  canonical={deckUrl}
  noindex={true}
>
  <main class="mb-deck" aria-label="Margarita Bravo and Markethink private proposal presentation">
    <header class="deck-topbar">
      <a href="#opening" class="brand-pair" aria-label="Margarita Bravo and Markethink presentation home">
        <img class="brand-logo brand-logo-mb" src={margaritaLogo} alt="Margarita Bravo" loading="eager" decoding="async" />
        <span class="pair-x" aria-hidden="true">×</span>
        <img class="brand-logo brand-logo-mt" src={markethinkLogo} alt="Markethink" loading="eager" decoding="async" />
      </a>
      <span class="deck-label">Private proposal · marketing and sales system</span>
    </header>

    <aside class="slide-rail" aria-label="Presentation sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} data-slide-link={slide.id}>
          <span>{slide.n}</span>
          <strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} class:list={["deck-slide", slide.tone]} style={`--slide-image: url('${slide.image}')`}>
        <div class="slide-bg" aria-hidden="true"></div>
        <div class="slide-vignette" aria-hidden="true"></div>
        <div class="slide-inner">
          <p class="slide-kicker">{slide.kicker}</p>
          <h1>{slide.title}</h1>
          <p class="slide-lead">{slide.lead}</p>
          {slide.package && (
            <div class="package-offer" aria-label={`${slide.title} pricing and included value`}>
              <div class="price-panel">
                <span class="standard-label">Standard rate</span>
                <span class="standard-price">{slide.package.standardPrice}</span>
                <span class="launch-label">{slide.package.note}</span>
                <strong>{slide.package.launchPrice}</strong>
                <small>plus success-fee alignment on signed client relationships</small>
              </div>
              <div class="value-panel">
                <span class="value-label">What’s included</span>
                <div class="chip-row package-chips">
                  {slide.chips.map((chip) => <span>{chip}</span>)}
                </div>
                <div class="channel-strip" aria-label={slide.package.socialLabel}>
                  <b>{slide.package.socialLabel}</b>
                  <div class="channel-icons">
                    {slide.package.channels.map((channel) => (
                      <span title={channel.name} aria-label={channel.name}>
                        {channel.key === "instagram" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5.2" y="5.2" width="13.6" height="13.6" rx="4.2" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3.3" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="16.3" cy="7.7" r="1.1" fill="currentColor"/></svg>
                        )}
                        {channel.key === "pinterest" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.2 4.5c-4.1 0-6.4 2.7-6.4 5.7 0 1.9 1 3.4 2.5 4 .3.1.5 0 .6-.4l.3-1.2c.1-.4.1-.5-.2-.9-.5-.6-.8-1.3-.8-2.1 0-2.1 1.6-3.7 4-3.7 2.2 0 3.5 1.3 3.5 3.2 0 2.5-1.2 4.3-2.8 4.3-.9 0-1.6-.8-1.4-1.7.3-1.1.8-2.3.8-3.1 0-.7-.4-1.3-1.2-1.3-.9 0-1.7 1-1.7 2.3 0 .8.3 1.4.3 1.4l-1.2 5.1c-.3 1.3-.2 2.8-.1 3.8 0 .3.4.4.5.1.5-.8 1.2-2.1 1.5-3.4l.6-2.3c.5.9 1.5 1.5 2.7 1.5 3.5 0 6-3.2 6-7.1 0-3.4-2.8-6.2-7.1-6.2Z" fill="currentColor"/></svg>
                        )}
                        {channel.key === "facebook" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8.2h2.2V4.8c-.4-.1-1.7-.2-3.2-.2-3.2 0-5.3 1.9-5.3 5.4v3H4.4v3.8h3.3v7h4.1v-7h3.3l.5-3.8h-3.8v-2.6c0-1.1.3-2.2 2.2-2.2Z" fill="currentColor"/></svg>
                        )}
                        {channel.key === "linkedin" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.8 9.4H3.4v10.9h3.4V9.4ZM5.1 4.1a2 2 0 1 0 0 4.1 2 2 0 0 0 0-4.1Zm14.8 10.1c0-3.3-1.8-5.1-4.3-5.1-2 0-2.9 1.1-3.4 1.9V9.4H8.9v10.9h3.4v-5.4c0-1.5.3-2.9 2.1-2.9 1.7 0 1.8 1.6 1.8 3v5.3h3.4v-6.1Z" fill="currentColor"/></svg>
                        )}
                        {channel.key === "youtube" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.3 8.2a3 3 0 0 0-2.1-2.1C17.4 5.6 12 5.6 12 5.6s-5.4 0-7.2.5a3 3 0 0 0-2.1 2.1 31 31 0 0 0-.5 3.8c0 1.3.2 2.6.5 3.8a3 3 0 0 0 2.1 2.1c1.8.5 7.2.5 7.2.5s5.4 0 7.2-.5a3 3 0 0 0 2.1-2.1c.3-1.2.5-2.5.5-3.8 0-1.3-.2-2.6-.5-3.8ZM10.1 15.3V8.7l5.7 3.3-5.7 3.3Z" fill="currentColor"/></svg>
                        )}
                        {channel.key === "email" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3.8" y="6.2" width="16.4" height="11.6" rx="2.3" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="m5.1 8 6.9 5.1L18.9 8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        )}
                        {channel.key === "search" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.7" cy="10.7" r="5.8" fill="none" stroke="currentColor" stroke-width="1.9"/><path d="m15.1 15.1 4.5 4.5" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>
                        )}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          )}
          {!slide.package && (
            <div class="chip-row">
              {slide.chips.map((chip) => <span>{chip}</span>)}
            </div>
          )}
          {slide.details && (
            <div class:list={["detail-grid", slide.package && "package-detail-grid"]}>
              {slide.details.map((detail) => <article>{detail}</article>)}
            </div>
          )}
        </div>
        <footer class="slide-footer">
          <span>{slide.n} / {slides.length.toString().padStart(2, "0")}</span>
          <span>Margarita Bravo × Markethink</span>
        </footer>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: #0f1213;
  }

  .mb-deck {
    --charcoal: #0f1213;
    --ink: #231f1d;
    --cream: #f5f1e9;
    --warm: #eee5d8;
    --stone: #c9b7a2;
    --taupe: #8d7968;
    --green: #69d254;
    --green-soft: #edf4ea;
    --panel: rgba(245, 241, 233, 0.9);
    color: var(--cream);
    min-height: 100vh;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    overflow-x: hidden;
  }

  .deck-topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 34px;
    color: var(--cream);
    pointer-events: none;
  }

  .brand-pair {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    border: 1px solid rgba(245, 241, 233, 0.2);
    border-radius: 999px;
    background: rgba(15, 18, 19, 0.58);
    backdrop-filter: blur(18px);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.16);
  }

  .brand-logo {
    display: block;
    object-fit: contain;
    height: auto;
    filter: none;
  }

  .brand-logo-mb {
    width: 176px;
    max-height: 18px;
  }

  .brand-logo-mt {
    width: 138px;
    max-height: 18px;
  }

  .pair-x {
    color: rgba(245, 241, 233, 0.56);
    font-family: Georgia, serif;
    font-size: 14px;
    line-height: 1;
    transform: translateY(-1px);
  }

  .deck-label {
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(15, 18, 19, 0.45);
    border: 1px solid rgba(245, 241, 233, 0.18);
    color: rgba(245, 241, 233, 0.72);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    backdrop-filter: blur(18px);
  }

  .slide-rail {
    position: fixed;
    right: 26px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 42;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .slide-rail a {
    width: 118px;
    display: grid;
    grid-template-columns: 26px 1fr;
    align-items: center;
    gap: 9px;
    padding: 8px 10px;
    border-radius: 999px;
    color: rgba(245, 241, 233, 0.62);
    text-decoration: none;
    font-size: 10px;
    background: rgba(15, 18, 19, 0.34);
    border: 1px solid rgba(245, 241, 233, 0.14);
    backdrop-filter: blur(16px);
    transition: transform 0.2s ease, color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .slide-rail a:hover,
  .slide-rail a.is-active {
    color: var(--cream);
    border-color: rgba(105, 210, 84, 0.7);
    background: rgba(15, 18, 19, 0.7);
    transform: translateX(-5px);
  }

  .slide-rail span {
    color: var(--green);
    font-weight: 750;
  }

  .slide-rail strong {
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .deck-slide {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
    isolation: isolate;
    overflow: hidden;
    padding: 120px 160px 86px 88px;
  }

  .slide-bg,
  .slide-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .slide-bg {
    z-index: -3;
    background-image: var(--slide-image);
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
    filter: saturate(0.92) contrast(1.02);
  }

  .slide-vignette {
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(15, 18, 19, 0.9) 0%, rgba(15, 18, 19, 0.72) 38%, rgba(15, 18, 19, 0.28) 68%, rgba(15, 18, 19, 0.5) 100%),
      linear-gradient(180deg, rgba(15, 18, 19, 0.36), rgba(15, 18, 19, 0.5));
  }

  .light .slide-vignette,
  .package.light .slide-vignette {
    background:
      linear-gradient(90deg, rgba(245, 241, 233, 0.96) 0%, rgba(245, 241, 233, 0.84) 39%, rgba(245, 241, 233, 0.34) 70%, rgba(35, 31, 29, 0.26) 100%),
      linear-gradient(180deg, rgba(245, 241, 233, 0.18), rgba(15, 18, 19, 0.18));
  }

  .warm .slide-vignette {
    background:
      linear-gradient(90deg, rgba(45, 38, 32, 0.88) 0%, rgba(45, 38, 32, 0.66) 42%, rgba(45, 38, 32, 0.24) 72%, rgba(15, 18, 19, 0.45) 100%);
  }

  .cinema .slide-vignette,
  .closing .slide-vignette,
  .package.dark .slide-vignette {
    background:
      linear-gradient(90deg, rgba(15, 18, 19, 0.94) 0%, rgba(15, 18, 19, 0.75) 42%, rgba(15, 18, 19, 0.3) 72%, rgba(15, 18, 19, 0.62) 100%);
  }

  .slide-inner {
    width: min(840px, 86vw);
    position: relative;
    z-index: 2;
  }

  .system .slide-inner,
  .package .slide-inner,
  .package.system .slide-inner {
    width: min(1040px, 88vw);
  }

  .slide-kicker {
    margin: 0 0 18px;
    color: var(--green);
    font-size: 12px;
    letter-spacing: 0.19em;
    text-transform: uppercase;
    font-weight: 800;
  }

  h1 {
    margin: 0;
    font-family: "Times New Roman", Georgia, serif;
    font-size: clamp(36px, 5.2vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    max-width: 940px;
    color: var(--cream);
    text-wrap: balance;
  }

  .light h1,
  .package.light h1 {
    color: var(--ink);
  }

  .slide-lead {
    margin: 26px 0 0;
    max-width: 760px;
    color: rgba(245, 241, 233, 0.82);
    font-size: clamp(18px, 2vw, 25px);
    line-height: 1.42;
    text-wrap: pretty;
  }

  .light .slide-lead,
  .package.light .slide-lead {
    color: rgba(35, 31, 29, 0.74);
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
    max-width: 860px;
  }

  .chip-row span {
    padding: 10px 13px;
    border-radius: 999px;
    background: rgba(245, 241, 233, 0.12);
    border: 1px solid rgba(245, 241, 233, 0.2);
    color: rgba(245, 241, 233, 0.82);
    font-size: 12px;
    font-weight: 680;
  }

  .light .chip-row span,
  .package.light .chip-row span {
    background: rgba(15, 18, 19, 0.06);
    border-color: rgba(35, 31, 29, 0.12);
    color: rgba(35, 31, 29, 0.74);
  }

  .chip-row span:first-child {
    background: rgba(105, 210, 84, 0.18);
    border-color: rgba(105, 210, 84, 0.42);
    color: var(--cream);
  }

  .light .chip-row span:first-child,
  .package.light .chip-row span:first-child {
    color: #193019;
  }

