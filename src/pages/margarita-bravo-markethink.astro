---
import Layout from "../layouts/Layout.astro";

const deckUrl = "https://markethink.ai/margarita-bravo-markethink/";
const assetBase = "https://dashboard.markethink.ai/generated/landing/markethink/margarita-bravo-markethink";
const margaritaLogo = `${assetBase}/margarita-bravo-logo-light.png`;
const markethinkLogo = `${assetBase}/markethink-logo-white.svg`;

const images = {
  opening: `${assetBase}/custom-01-opening.png`,
  opportunity: `${assetBase}/custom-02-opportunity.png`,
  system: `${assetBase}/custom-03-system.png`,
  memory: `${assetBase}/custom-04-memory-v2.png`,
  foundation: `${assetBase}/custom-06-foundation.png`,
  growth: `${assetBase}/custom-07-growth.png`,
  revenue: `${assetBase}/custom-08-revenue.png`,
  alignment: `${assetBase}/custom-09-alignment.png`,
  next: "/images/hero-office-background.svg",
};

const slides = [
  {
    n: "01",
    id: "opening",
    nav: "Opening",
    kicker: "MARGARITA BRAVO × MARKETHINK",
    title: "A marketing and sales system for Margarita Bravo, built to turn brand strength into signed client relationships.",
    lead: "Markethink learns the business, organizes campaigns, keeps approval memory, supports sales follow-up, and helps the team ship polished marketing every week. The work stays connected from first impression to signed client relationship.",
    image: images.opening,
    tone: "hero",
    chips: ["Marketing and sales system", "Approval memory", "Weekly rhythm", "Signed relationships"],
  },
  {
    n: "02",
    id: "opportunity",
    nav: "Opportunity",
    kicker: "THE OPPORTUNITY",
    title: "Margarita Bravo already has the taste, reputation, and body of work. Now marketing and sales need the same discipline.",
    lead: "The brand does not need more noise. It needs a calmer operating rhythm: stronger visibility, clearer inquiry paths, better follow-up, and campaigns that carry the same level of taste as the work itself.",
    image: images.opportunity,
    tone: "light",
    chips: ["Refined visibility", "Qualified inquiries", "Sharper sales language", "Follow-up structure"],
    details: [
      "Keep content, approvals, campaign notes, and opportunities in one place",
      "Turn existing assets into a steady marketing rhythm",
      "Support qualified client conversations, sales material, and follow-up without adding internal complexity",
      "Let each approved piece inform the next one",
    ],
  },
  {
    n: "03",
    id: "markethink-system",
    nav: "System",
    kicker: "MARKETING AND SALES",
    title: "A working layer for Margarita Bravo’s marketing and sales.",
    lead: "Markethink becomes the working layer behind the marketing and sales motion. It helps shape messaging, prepare social and website updates, draft email and outreach, organize inquiries and opportunities, and keep every follow-up connected to the brand.",
    image: images.system,
    tone: "system",
    chips: ["Brand language", "Campaign planning", "Sales follow-up", "Opportunity tracking"],
    details: [
      "Markethink learns the brand, services, tone, client profiles, and sales preferences",
      "Campaigns, content, inquiries, proposals, approvals, and follow-up stay connected",
      "The system remembers what was approved, who needs follow-up, and what should move next",
      "Markethink supports the work, while the humans keep control of every decision",
    ],
  },
  {
    n: "04",
    id: "marketing-memory",
    nav: "Memory",
    kicker: "MARKETING AND SALES MEMORY",
    title: "The marketing and sales memory stays with the business.",
    lead: "Teams change. Vendors change. Priorities change. Markethink keeps the brand voice, approvals, campaign context, client signals, and follow-up history from disappearing every time the setup changes.",
    image: images.memory,
    tone: "warm",
    chips: ["Brand voice", "Approved sales language", "Client signals", "Opportunity history"],
    details: [
      "Learns the brand, services, assets, approvals, and preferences",
      "Remembers what language should be repeated and what should be avoided",
      "Keeps inquiry notes, sales context, and follow-up next steps from getting scattered",
      "Gets sharper as more real work moves through it",
    ],
  },
  {
    n: "05",
    id: "foundation",
    nav: "Foundation",
    kicker: "PACKAGE 01",
    title: "Foundation system",
    lead: "A polished monthly operating base for keeping the brand visible, organized, and easier to follow up with, without asking the team to manage every moving part.",
    image: images.foundation,
    tone: "package light",
    package: {
      standardPrice: "$1,500/mo",
      launchPrice: "$1,000/mo",
      note: "Preferred launch rate",
      feeNote: "Plus performance success fee",
      scopeLabel: "Includes",
      intro: "Built for consistent brand activity, core content, and marketing organization.",
      groups: [
        {
          title: "System",
          items: [
            "Dedicated Margarita Bravo workspace inside Markethink",
            "24/7 trained operating memory dedicated solely to Margarita Bravo",
            "Brand, voice, and campaign memory",
            "Monthly marketing priorities, content calendar, and review rhythm",
          ],
        },
        {
          title: "Social",
          items: [
            "Posting across up to 3 core social channels",
            "3 polished social media posts per month",
          ],
        },
        {
          title: "Search",
          items: ["1 blog post per month", "Basic SEO hygiene"],
        },
        {
          title: "Web",
          items: ["Light website cleanup and content updates"],
        },
        {
          title: "CRM",
          items: ["Basic opportunity tracking inside Markethink"],
        },
      ],
      learningLabel: "The workspace begins learning",
      learning: [
        "brand voice",
        "services",
        "portfolio categories",
        "ideal clients",
        "approved language",
        "recurring content themes",
        "basic lead/opportunity notes",
      ],
      iconLabel: "Core mix",
      icons: [
        { name: "Instagram", key: "instagram" },
        { name: "Pinterest", key: "pinterest" },
        { name: "Facebook", key: "facebook" },
        { name: "Blog", key: "blog" },
        { name: "SEO", key: "search" },
        { name: "Web", key: "web" },
        { name: "Calendar", key: "calendar" },
        { name: "Approvals", key: "approval" },
        { name: "Tracking", key: "tracking" },
      ],
    },
    chips: ["Core activity", "Marketing organization", "Approval workflow", "Opportunity notes"],
    details: [
      "Foundation keeps the brand active and organized without making the offer feel like a social-media-only service.",
      "Markethink starts building the operating memory around the brand, approvals, content rhythm, website basics, and early opportunities.",
    ],
  },
  {
    n: "06",
    id: "growth",
    nav: "Growth",
    kicker: "PACKAGE 02 · RECOMMENDED",
    title: "Growth system",
    lead: "The recommended starting point: enough weekly activity to keep the brand visible, create more reasons to inquire, and turn interest into organized sales follow-up.",
    image: images.growth,
    tone: "package system",
    package: {
      standardPrice: "$2,000/mo",
      launchPrice: "$1,500/mo",
      note: "Preferred launch rate · recommended",
      feeNote: "Plus performance success fee",
      scopeLabel: "Includes",
      intro: "Built for stronger weekly visibility, website movement, email, CRM, and organized outreach.",
      groups: [
        {
          title: "System",
          items: [
            "Everything in Foundation, with deeper brand, audience, service, and approval memory",
            "Monthly learning loop so approved language, client signals, and performance notes shape the next cycle",
          ],
        },
        {
          title: "Social",
          items: ["Everything in Foundation social, expanded into a weekly rhythm: 5 refined posts and 1 light video per week"],
        },
        {
          title: "Search",
          items: ["Everything in Foundation search, expanded to two search-friendly blogs/articles per month connected to services, projects, and expertise"],
        },
        {
          title: "Email",
          items: ["One monthly email campaign or newsletter with audience-specific messaging"],
        },
        {
          title: "Web",
          items: ["Everything in Foundation web, plus website management support, page refreshes, stronger inquiry paths, and better conversion flow"],
        },
        {
          title: "Campaigns",
          items: ["Campaign messaging, content angles, and offer language prepared for review"],
        },
        {
          title: "CRM + Outreach",
          items: [
            "Inquiry organization, source notes, opportunity tracking, and sales follow-up drafts",
            "AI Agent prospecting and daily outreach support for qualified targets",
          ],
        },
      ],
      iconLabel: "Expanded mix",
      icons: [
        { name: "Instagram", key: "instagram" },
        { name: "Pinterest", key: "pinterest" },
        { name: "Facebook", key: "facebook" },
        { name: "LinkedIn", key: "linkedin" },
        { name: "YouTube", key: "youtube" },
        { name: "Blog", key: "blog" },
        { name: "Email", key: "email" },
        { name: "SEO", key: "search" },
        { name: "Web", key: "web" },
        { name: "Outreach", key: "outreach" },
        { name: "Tracking", key: "tracking" },
      ],
    },
    chips: ["Recommended system", "Weekly production", "Website management", "CRM + outreach"],
    details: [
      "The recommended starting point because it gives Markethink enough weekly activity to support the full motion: visibility, website, email, inquiries, and sales follow-up.",
      "It creates a real operating cadence, not a content bundle. The team gets prepared work, clearer priorities, and better continuity around every opportunity.",
    ],
  },
  {
    n: "07",
    id: "revenue-visibility",
    nav: "Revenue",
    kicker: "PACKAGE 03",
    title: "Revenue and visibility system",
    lead: "The most complete option for daily visibility, stronger sales support, outreach, paid campaign coordination, and a closer connection between marketing activity and signed opportunities.",
    image: images.revenue,
    tone: "package dark",
    package: {
      standardPrice: "$2,500/mo",
      launchPrice: "$2,000/mo",
      note: "Preferred launch rate",
      feeNote: "Plus performance success fee",
      scopeLabel: "Includes",
      intro: "Built for the fullest marketing and sales rhythm: visibility, campaigns, outreach, and follow-up.",
      groups: [
        {
          title: "System",
          items: [
            "Everything in Growth, expanded into a fuller marketing and sales operating rhythm",
            "Light office support connected to marketing workflows, inquiries, and client opportunities",
          ],
        },
        {
          title: "Social",
          items: [
            "Everything in Growth social, expanded into a daily visibility rhythm with polished publishing-ready content",
            "Two light videos per week for higher-touch visibility and campaign momentum",
          ],
        },
        {
          title: "Search",
          items: [
            "Everything in Growth search: service, project, and expertise content connected to search visibility",
            "Ongoing SEO hygiene so website updates and content support qualified discovery",
          ],
        },
        {
          title: "Email",
          items: ["Everything in Growth email, expanded to two email campaigns per month connected to audience segments and service priorities"],
        },
        {
          title: "Web",
          items: ["Everything in Growth web, with priority page refreshes, landing-page support, and stronger inquiry paths"],
        },
        {
          title: "Campaigns",
          items: ["Everything in Growth campaigns, plus priority sales-message and offer support when a new push needs to move"],
        },
        {
          title: "CRM + Outreach",
          items: [
            "Deeper opportunity management: inquiry notes, prospect context, source tracking, and next steps",
            "Daily AI Agent prospecting and outreach support for qualified opportunities",
            "Sales outreach drafts, reactivation language, and follow-up organization for qualified conversations",
          ],
        },
        {
          title: "Ads",
          items: ["Paid campaign coordination and ad-management support, with ad spend kept separate"],
        },
      ],
      iconLabel: "Full mix",
      icons: [
        { name: "Instagram", key: "instagram" },
        { name: "Pinterest", key: "pinterest" },
        { name: "Facebook", key: "facebook" },
        { name: "LinkedIn", key: "linkedin" },
        { name: "YouTube", key: "youtube" },
        { name: "Email", key: "email" },
        { name: "SEO", key: "search" },
        { name: "Web", key: "web" },
        { name: "Ads", key: "ads" },
        { name: "Outreach", key: "outreach" },
        { name: "Tracking", key: "tracking" },
      ],
    },
    chips: ["Full operating rhythm", "Campaign support", "Opportunity management", "Outreach support"],
    details: [
      "This is the most complete option: Markethink supports the brand’s daily visibility while also keeping the sales motion, follow-up, and opportunity context organized.",
      "It is designed for a team that wants more consistent movement across marketing, website, email, campaigns, and qualified client conversations.",
    ],
  },
  {
    n: "08",
    id: "performance-alignment",
    nav: "Alignment",
    kicker: "PREFERRED PRICING + PERFORMANCE ALIGNMENT",
    title: "Lower fixed cost, with upside tied to real signed relationships.",
    lead: "The preferred launch pricing keeps the monthly commitment efficient. The upside structure should be discussed with the Margarita Bravo team so the arrangement feels fair, clear, and aligned for everyone when new signed relationships move forward.",
    image: images.alignment,
    tone: "light",
    chips: ["Signed relationships", "Sales movement", "Clear attribution", "Success structure to discuss"],
    details: [
      "Applies across all packages",
      "Tied to a new client relationship that is generated, advanced, signs, and pays",
      "Can come through website inquiries, email, search, social, ads, outreach, sales follow-up, or reactivation",
      "Final success structure to be discussed with the Margarita Bravo team so incentives are aligned for everyone",
    ],
  },
  {
    n: "09",
    id: "next-step",
    nav: "Next step",
    kicker: "",
    title: "It feels like having a full marketing and sales team dedicated to Margarita Bravo, every day.",
    lead: "Markethink brings strategy, production, follow-up organization, and approval memory into one evolving system, powered by marketing experts and built to keep getting sharper as the business moves.",
    image: images.next,
    tone: "closing",
    chips: ["Marketing team rhythm", "Sales follow-up", "24/7 operating memory", "Keeps evolving"],
    details: [
      "Approve the package and first month priorities",
      "Confirm the first social channels and content sources",
      "Train Markethink on the brand, offer, services, audience, assets, approvals, sales language, and follow-up preferences",
      "Begin the first content, website, campaign, inquiry, and sales follow-up cycle with the system learning from every approval",
    ],
  },
];
---

<Layout
  title="Margarita Bravo × Markethink · Private Proposal"
  description="A private Markethink proposal presentation for Margarita Bravo."
  image={images.opening}
  canonical={deckUrl}
  noindex={true}
>
  <main class="mb-deck" aria-label="Margarita Bravo and Markethink private proposal presentation">
    <header class="deck-topbar">
      <a href="#opening" class="brand-pair" aria-label="Margarita Bravo and Markethink presentation home">
        <img class="brand-logo brand-logo-mb" src={margaritaLogo} alt="Margarita Bravo" loading="eager" decoding="async" />
        <span class="pair-x" aria-hidden="true">×</span>
        <img class="brand-logo brand-logo-mt" src={markethinkLogo} alt="Markethink" loading="eager" decoding="async" />
      </a>
      <span class="deck-label">Private proposal · marketing and sales system</span>
    </header>

    <aside class="slide-rail" aria-label="Presentation sections">
      {slides.map((slide) => (
        <a href={`#${slide.id}`} data-slide-link={slide.id}>
          <span>{slide.n}</span>
          <strong>{slide.nav}</strong>
        </a>
      ))}
    </aside>

    {slides.map((slide) => (
      <section id={slide.id} class:list={["deck-slide", slide.tone]} style={`--slide-image: url('${slide.image}')`}>
        <div class="slide-bg" aria-hidden="true"></div>
        <div class="slide-vignette" aria-hidden="true"></div>
        <div class="slide-inner">
          {slide.kicker && <p class="slide-kicker">{slide.kicker}</p>}
          <h1>{slide.title}</h1>
          <p class="slide-lead">{slide.lead}</p>
          {slide.package && (
            <div class="package-offer" aria-label={`${slide.title} pricing and included value`}>
              <div class="price-panel">
                <span class="standard-label">Standard rate</span>
                <span class="rate-value standard-price">{slide.package.standardPrice}</span>
                <span class="launch-label">{slide.package.note}</span>
                <strong class="rate-value launch-price">{slide.package.launchPrice}</strong>
                <small>{slide.package.feeNote}</small>
              </div>
              <div class="value-panel">
                <p class="package-intro">{slide.package.intro}</p>
                <span class="value-label">{slide.package.scopeLabel}</span>
                {slide.package.groups ? (
                  <div class="package-group-list">
                    {slide.package.groups.map((group) => (
                      <section class="package-group">
                        <strong>{group.title}</strong>
                        <ul>
                          {group.items.map((item) => <li>{item}</li>)}
                        </ul>
                      </section>
                    ))}
                  </div>
                ) : (
                  <ul class="package-item-list">
                    {slide.package.items.map((item) => <li>{item}</li>)}
                  </ul>
                )}
                {slide.package.learning && (
                  <div class="learning-block">
                    <span>{slide.package.learningLabel}</span>
                    <p>{slide.package.learning.join(" · ")}</p>
                  </div>
                )}
                <div class="service-icon-strip" aria-label={slide.package.iconLabel}>
                  <b>{slide.package.iconLabel}</b>
                  <div class="service-icons">
                    {slide.package.icons.map((icon) => (
                      <span title={icon.name} aria-label={icon.name}>
                        {icon.key === "instagram" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5.2" y="5.2" width="13.6" height="13.6" rx="4.2" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3.3" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="16.3" cy="7.7" r="1.1" fill="currentColor"/></svg>
                        )}
                        {icon.key === "pinterest" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.2 4.5c-4.1 0-6.4 2.7-6.4 5.7 0 1.9 1 3.4 2.5 4 .3.1.5 0 .6-.4l.3-1.2c.1-.4.1-.5-.2-.9-.5-.6-.8-1.3-.8-2.1 0-2.1 1.6-3.7 4-3.7 2.2 0 3.5 1.3 3.5 3.2 0 2.5-1.2 4.3-2.8 4.3-.9 0-1.6-.8-1.4-1.7.3-1.1.8-2.3.8-3.1 0-.7-.4-1.3-1.2-1.3-.9 0-1.7 1-1.7 2.3 0 .8.3 1.4.3 1.4l-1.2 5.1c-.3 1.3-.2 2.8-.1 3.8 0 .3.4.4.5.1.5-.8 1.2-2.1 1.5-3.4l.6-2.3c.5.9 1.5 1.5 2.7 1.5 3.5 0 6-3.2 6-7.1 0-3.4-2.8-6.2-7.1-6.2Z" fill="currentColor"/></svg>
                        )}
                        {icon.key === "facebook" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8.2h2.2V4.8c-.4-.1-1.7-.2-3.2-.2-3.2 0-5.3 1.9-5.3 5.4v3H4.4v3.8h3.3v7h4.1v-7h3.3l.5-3.8h-3.8v-2.6c0-1.1.3-2.2 2.2-2.2Z" fill="currentColor"/></svg>
                        )}
                        {icon.key === "linkedin" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.8 9.4H3.4v10.9h3.4V9.4ZM5.1 4.1a2 2 0 1 0 0 4.1 2 2 0 0 0 0-4.1Zm14.8 10.1c0-3.3-1.8-5.1-4.3-5.1-2 0-2.9 1.1-3.4 1.9V9.4H8.9v10.9h3.4v-5.4c0-1.5.3-2.9 2.1-2.9 1.7 0 1.8 1.6 1.8 3v5.3h3.4v-6.1Z" fill="currentColor"/></svg>
                        )}
                        {icon.key === "youtube" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.3 8.2a3 3 0 0 0-2.1-2.1C17.4 5.6 12 5.6 12 5.6s-5.4 0-7.2.5a3 3 0 0 0-2.1 2.1 31 31 0 0 0-.5 3.8c0 1.3.2 2.6.5 3.8a3 3 0 0 0 2.1 2.1c1.8.5 7.2.5 7.2.5s5.4 0 7.2-.5a3 3 0 0 0 2.1-2.1c.3-1.2.5-2.5.5-3.8 0-1.3-.2-2.6-.5-3.8ZM10.1 15.3V8.7l5.7 3.3-5.7 3.3Z" fill="currentColor"/></svg>
                        )}
                        {icon.key === "email" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3.8" y="6.2" width="16.4" height="11.6" rx="2.3" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="m5.1 8 6.9 5.1L18.9 8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        )}
                        {icon.key === "search" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.7" cy="10.7" r="5.8" fill="none" stroke="currentColor" stroke-width="1.9"/><path d="m15.1 15.1 4.5 4.5" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>
                        )}
                        {icon.key === "web" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5.5" width="16" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M4 9h16M8 15.5h4.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                        )}
                        {icon.key === "blog" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4.8h9.5L19 8.3v10.9H6V4.8Z" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M15.2 5v3.6h3.6M8.8 12h6.4M8.8 15.5h5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                        )}
                        {icon.key === "calendar" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4.5" y="6" width="15" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M8 4.5v3M16 4.5v3M4.8 10h14.4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                        )}
                        {icon.key === "approval" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="7" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="m8.7 12.1 2.1 2.1 4.7-5" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        )}
                        {icon.key === "tracking" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 18.5h14M7 16v-4M12 16V7M17 16v-6" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>
                        )}
                        {icon.key === "ads" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 13.5 15.5 7v10L5 13.5Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M8 14.5 9.5 19" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
                        )}
                        {icon.key === "outreach" && (
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 12h9M13.5 12l-3-3M13.5 12l-3 3M15.5 6.5h4v11h-4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        )}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          )}
          {!slide.package && (
            <div class="chip-row">
              {slide.chips.map((chip) => <span>{chip}</span>)}
            </div>
          )}
          {slide.details && (
            <div class:list={["detail-grid", slide.package && "package-detail-grid"]}>
              {slide.details.map((detail) => <article>{detail}</article>)}
            </div>
          )}
        </div>
        <footer class="slide-footer">
          <span>{slide.n} / {slides.length.toString().padStart(2, "0")}</span>
          <span>Margarita Bravo × Markethink</span>
        </footer>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: #0f1213;
  }

  .mb-deck {
    --charcoal: #0f1213;
    --ink: #231f1d;
    --cream: #f5f1e9;
    --warm: #eee5d8;
    --stone: #c9b7a2;
    --taupe: #8d7968;
    --light-brown: #c9b7a2;
    --light-brown-soft: #eee5d8;
    --panel: rgba(245, 241, 233, 0.9);
    color: var(--cream);
    min-height: 100vh;
